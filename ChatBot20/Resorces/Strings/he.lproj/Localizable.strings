/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "האחוזה שקטה כשאתה חוזר. אור קלוש מהבהב בחדר העבודה שלך. אתה מוצא את אלנה, המשרתת השקטה ביותר שלך, מסדרת את השולחן בעצבנות ב-2 לפנות בוקר.";
"S1.P0.Q" = "לגשת אליה?";
"S1.P0.O1" = "אלנה, למה את לא במיטה?";
"S1.P0.O2" = "(להביט מהצללים)";

/* Page 1 */
"S1.P1.N" = "היא קופצת בבהלה ומפילה את המברשת. 'אדוני! אני... לא נרדמתי. האבק הפריע לי.' היא נראית חיוורת ולא מביטה בעיניך.";
"S1.P1.Q" = "להאמין לה?";
"S1.P1.O1" = "מאוחר מדי לניקיונות";
"S1.P1.O2" = "את עובדת מאוד מסורה";

/* Page 2 */
"S1.P2.N" = "אתה מבחין בה שולפת מפתח כסף קטן מהסינר שלה. היא בוהה בו בשילוב של כמיהה ופחד לפני שהיא מבחינה בצל שלך.";
"S1.P2.Q" = "צעד קדימה?";
"S1.P2.O1" = "מה זה המפתח הזה, אלנה?";
"S1.P2.O2" = "תסבירי את עצמך מיד";

/* Page 3 */
"S1.P3.N" = "היא רועדת. 'בבית הזה יש כל כך הרבה סודות, אדוני. לפעמים הם כבדים לי מדי.' היא מצביעה לעבר הכספת הישנה מאחורי מדף הספרים שלך.";
"S1.P3.Q" = "לשאול על הכספת?";
"S1.P3.O1" = "המפתח שייך לשם?";
"S1.P3.O2" = "הכספת היא מחוץ לתחום";

/* Page 4 */
"S1.P4.N" = "היא מנסה להחביא את המפתח, אבל הוא נופל. 'אני לא גנבת, אני מבטיחה! פשוט... ראיתי אותו במסדרון וחשבתי שהוא שלך.'";
"S1.P4.Q" = "להרים את המפתח?";
"S1.P4.O1" = "(להרים)";
"S1.P4.O2" = "בואי נראה מה הוא פותח";

/* Page 5 */
"S1.P5.N" = "המפתח מתאים לתא נסתר בתוך הכספת. אלנה צופה בנשימה עצורה כשאתה חושף ערימה של מכתבים ישנים וצהובים קשורים בסרט שחור.";
"S1.P5.Q" = "לקרוא את המכתב העליון?";
"S1.P5.O1" = "לקרוא בקול רם";
"S1.P5.O2" = "לשאול את אלנה מה היא יודעת";

/* Page 6 */
"S1.P6.N" = "קולה של אלנה הופך ללחישה. 'גם אמא שלי הייתה משרתת כאן. היא סיפרה לי שאדון הבית שמר תיעוד של נערה שאהב פעם. נערה שנראתה בדיוק כמוני.'";
"S1.P6.Q" = "רגע, מה?";
"S1.P6.O1" = "ספרי לי הכל";
"S1.P6.O2" = "זה פשוט בלתי אפשרי";

/* Page 7 */
"S1.P7.N" = "המכתבים מתארים רומן אסור. אלנה מתקרבת, אור הירח משתקף בדמעותיה. 'לא רציתי לגנוב. רק רציתי לדעת אם אני שייכת לכאן.'";
"S1.P7.Q" = "לנחם אותה?";
"S1.P7.O1" = "להניח יד על הכתף שלה";
"S1.P7.O2" = "לתת לה קצת מרחב";

/* Page 8 */
"S1.P8.N" = "היא מסבירה שביומן של אמה הוזכרה אמת נסתרת בחדר הזה. 'חייתי בבית הזה כל חיי, אדוני, אבל אני מרגישה כמו רוח רפאים.'";
"S1.P8.Q" = "להבטיח הבטחה?";
"S1.P8.O1" = "אני אעזור לך למצוא את האמת";
"S1.P8.O2" = "נפתור את זה ביחד";

/* Page 9 */
"S1.P9.N" = "אתה מבלה את השעה הבאה בחיטוט במסמכים. אתה מוצא תעודת לידה עם שם מוכר, אבל סעיף האב נותר ריק.";
"S1.P9.Q" = "להביט באלנה?";
"S1.P9.O1" = "יכול להיות שזה דוד שלי?";
"S1.P9.O2" = "אולי עדיף לא לדעת";

/* Page 10 */
"S1.P10.N" = "החיפוש הופך אינטנסיבי. אלנה מוצאת קופסת תכשיטים חבויה. בפנים יש תליון עם דיוקן של אישה שהיא העתק מושלם שלה.";
"S1.P10.Q" = "להראות לה?";
"S1.P10.O1" = "תראי את התליון הזה";
"S1.P10.O2" = "זו אמא שלך?";

/* Page 11 */
"S1.P11.N" = "פתאום, חריקת רצפה נשמעת מבחוץ. מישהו במסדרון. עיניה של אלנה נפתחות לרווחה בבהלה. 'אם רב-המשרתים ימצא אותנו...!'";
"S1.P11.Q" = "להתחבא?";
"S1.P11.O1" = "להתחבא איתה בארון";
"S1.P11.O2" = "להישאר ולהתמודד מולו";

/* Page 12 */
"S1.P12.N" = "צעדים מתקרבים. אלנה תופסת בשרוול שלך. 'בבקשה אדוני, אף אחד לא יכול לדעת שמצאנו את זה. זה מסוכן עבורי.'";
"S1.P12.Q" = "תגובה?";
"S1.P12.O1" = "לכבות את האורות";
"S1.P12.O2" = "לנעול את הדלת";

/* Page 13 */
"S1.P13.N" = "החדר חשוך לגמרי. בחלל הצר, אתה שומע את דופק הלב המהיר של אלנה ומריח ניחוח ורדים מעורה. היא קרובה אליך מאוד.";
"S1.P13.Q" = "ללחוש לה?";
"S1.P13.O1" = "את בטוחה איתי";
"S1.P13.O2" = "(להישאר בשקט ולחכות)";

/* Page 14 */
"S1.P14.N" = "אתה מחזיק את הדלת סגורה. הדמות בחוץ משתהה לרגע, ואז מתרחקת. אלנה נשענת עליך, רועדת מאדרנלין.";
"S1.P14.Q" = "להרגיע אותה?";
"S1.P14.O1" = "הם הלכו";
"S1.P14.O2" = "את בסדר?";

/* Page 15 */
"S1.P15.N" = "היא מתרחקת מעט, אך ידה נשארת על החזה שלך. 'אדוני... תמיד הערצתי אותך מרחוק. הסוד הזה... הוא כבד מדי מכדי לשאת לבד.'";
"S1.P15.Q" = "מה אתה מרגיש?";
"S1.P15.O1" = "גם אני שמתי לב אלייך";
"S1.P15.O2" = "את הרבה יותר ממשרתת בשבילי";

/* Page 16 */
"S1.P16.N" = "'חשבתי שאני רק שפחה עבורך,' היא לוחשת. 'סתם חלק מהרהיטים. אבל הלילה מרגיש כמו התחלה של משהו אמיתי.'";
"S1.P16.Q" = "להסכים?";
"S1.P16.O1" = "זה אמיתי, אלנה";
"S1.P16.O2" = "בואי נראה לאן זה יוביל";

/* Page 17 */
"S1.P17.N" = "היא פותחת את התליון. בפנים יש פתק קטן: 'לביתי, היורשת האמיתית.' אלנה נדהמת. יכול להיות שהאחוזה בעצם שייכת לה.";
"S1.P17.Q" = "ההשלכות?";
"S1.P17.O1" = "אנחנו חייבים לחשוף את זה";
"S1.P17.O2" = "כדאי שנשמור על זה בסוד";

/* Page 18 */
"S1.P18.N" = "הפתק מוכיח שאלנה היא הבעלים החוקיים של הנכס. היא מביטה סביב בחדר, המומה. 'אני... אני לא רוצה את הבית. אני רק רוצה משפחה.'";
"S1.P18.Q" = "מה אתה רוצה?";
"S1.P18.O1" = "יש לך אותי עכשיו";
"S1.P18.O2" = "מה את מתכוונת לעשות?";

/* Page 19 */
"S1.P19.N" = "היא מביטה באח. 'אם אשרוף את זה, אהיה שוב רק אלנה. אם אשמור על זה, הכל ישתנה. אדוני, מה עליי לעשות?'";
"S1.P19.Q" = "לתת עצה?";
"S1.P19.O1" = "תשרפי את זה ותישארי איתי";
"S1.P19.O2" = "תשמרי על זה ותתפסי את מקומך";

/* Page 20 */
"S1.P20.N" = "אלנה אוחזת בהוכחה לשושלת שלה. 'שם המשפחה הזה מקולל, אדוני. אני מעדיפה להיות 'אף אחת' מאושרת מאשר גבירה אומללה.'";
"S1.P20.Q" = "הבחירה שלך?";
"S1.P20.O1" = "לכי עם הלב שלך";
"S1.P20.O2" = "תחשבי על העתיד שלך";

/* Page 21 */
"S1.P21.N" = "היא משליכה את הנייר לתוך הגחלים הלוחשות. הסוד הופך לאפר. אלנה מחייכת, נראית חופשייה יותר מאי פעם.";
"S1.P21.Q" = "העתיד?";
"S1.P21.O1" = "התחלה חדשה";
"S1.P21.O2" = "רק שנינו";

/* Page 22 */
"S1.P22.N" = "היא מחביאה את הנייר בבגדיה. 'אם כך, אני אהיה הגבירה של הבית הזה. ואני אצטרך שותף לצידי.'";
"S1.P22.Q" = "אתה מוכן?";
"S1.P22.O1" = "תמיד";
"S1.P22.O2" = "זו תהיה דרך ארוכה";

/* Final 1 */
"S1.P23.N" = "אלנה היא כבר לא המשרתת שלך. היא השותפה שלך, הסוד שלך, והשוות לך. האחוזה נשארת שלך, אבל הלב שלה שייך לה.";
"S1.P23.Q" = "הסוף";
"S1.P23.O1" = "התחל סיפור מחדש";
"S1.P23.O2" = "סיום";

/* Final 2 */
"S1.P24.N" = "האמת יוצאת לאור. אלנה הופכת לבעלת הבית. יחסי הכוחות השתנו, אבל הקשר שיצרתם באותו לילה הוא בלתי ניתן לשבירה.";
"S1.P24.Q" = "הסוף";
"S1.P24.O1" = "התחל סיפור מחדש";
"S1.P24.O2" = "סיום";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "הגשם מכה ברחובות הניאון של שינג'וקו. אתה יושב בבר שקט כשאישה במעיל גשם רטוב מתיישבת לידך. יש לה ריח של יסמין ואבק שריפה.";
"S2.P0.Q" = "איך תתחיל שיחה?";
"S2.P0.O1" = "לקנות לה משקה";
"S2.P0.O2" = "לילה קשוח, אה?";

"S2.P1.N" = "היא מביטה בכוס, ואז בך. 'אתה אמיץ,' היא לוחשת ומחליקה שבב נתונים קטן על הדלפק.";
"S2.P1.Q" = "לקחת את השבב?";
"S2.P1.O1" = "לקחת ולהחביא אותו";
"S2.P1.O2" = "אני לא רוצה צרות";

"S2.P2.N" = "היא צוחקת בצחוק מר. 'אין לך מושג.' היא מביטה מעבר לכתפה. שני גברים בחליפות שחורות נכנסו הרגע לבר.";
"S2.P2.Q" = "לעזור לה להתחבא?";
"S2.P2.O1" = "בואי אחרי לדלת האחורית";
"S2.P2.O2" = "בואי נעמיד פנים שאנחנו זוג";

"S2.P3.N" = "אתה מושך אותה קרוב אליך. הגברים סורקים את החדר ועוזבים. היא נראית רגועה יותר אבל ידיה רועדות. 'אני מיה,' היא לוחשת.";
"S2.P3.Q" = "לשאול על הסכנה?";
"S2.P3.O1" = "מי אלה היו, מיה?";
"S2.P3.O2" = "אנחנו בטוחים עכשיו?";

"S2.P4.N" = "הגברים מתקרבים, אבל אתה שומר על קור רוח. הם חולפים על פניכם. היא לוחשת: 'הצלת אותי. אני מיה. אבל השבב הזה... הוא שווה מיליוני חיים.'";
"S2.P4.Q" = "לשאול על השבב?";
"S2.P4.O1" = "מה יש עליו?";
"S2.P4.O2" = "אנחנו צריכים לעוף מכאן";

"S2.P5.N" = "מיה מביטה בדלת. 'תאגיד ארסאקה רוצה את זה. זה לא סתם מידע, זו נשמה דיגיטלית.'";
"S2.P5.Q" = "להאמין לה?";
"S2.P5.O1" = "נשמה דיגיטלית? באמת?";
"S2.P5.O2" = "שמעתי שמועות...";

"S2.P6.N" = "מיה תופסת בידך. 'שום מקום לא בטוח עד שנעלה את זה. אנחנו צריכים להגיע לרובע הטכנולוגי.'";
"S2.P6.Q" = "ללכת איתה?";
"S2.P6.O1" = "אני אקח אותך לשם";
"S2.P6.O2" = "רק אם תספרי לי עוד";

"S2.P7.N" = "אתם מתחמקים מהדלת האחורית. הסמטה חשוכה. פתאום, רחפן מזמזם מעליכם, מחפש חתימות חום.";
"S2.P7.Q" = "איך להתחמק מהרחפן?";
"S2.P7.O1" = "להתחבא מתחת לסככה";
"S2.P7.O2" = "לרוץ לעבר הסאבוויי";

"S2.P8.N" = "מיה עוצרת בגשם. 'אם הם יתפסו אותי, הם ימחקו אותי. וגם אותך, בגלל שעזרת.'";
"S2.P8.Q" = "להרגיע אותה?";
"S2.P8.O1" = "אני איתך בזה";
"S2.P8.O2" = "בואי פשוט נזוז, מהר";

"S2.P9.N" = "הרחפן עובר. אתם מגיעים למכונית שלך. מיה מביטה בך בתערובת של פחד והכרת תודה.";
"S2.P9.Q" = "להתניע?";
"S2.P9.O1" = "תלחץ על הגז!";
"S2.P9.O2" = "סע לאט, שנטמע בתנועה";

"S2.P10.N" = "אתם בקושי מגיעים לתחנה. הקהל עצום ומהווה כיסוי מושלם. מיה נשארת קרובה, כתפה נוגעת בכתפך.";
"S2.P10.Q" = "להמשיך לזוז?";
"S2.P10.O1" = "לקחת את רכבת האקספרס";
"S2.P10.O2" = "ללכת דרך המנהרות";

"S2.P11.N" = "אתם נעים דרך רובע גורדי השחקים. פרסומות ההולוגרמה מאירות את פניה של מיה בוורוד וכחול.";
"S2.P11.Q" = "לשבור את השתיקה?";
"S2.P11.O1" = "למה דווקא אני, מיה?";
"S2.P11.O2" = "ספרי לי על השבב";

"S2.P12.N" = "העיר מרגישה כמו מבוך. אתם עוצרים בדוכן ראמן נסתר כדי לנוח לרגע.";
"S2.P12.Q" = "לפקוח עין על הרחוב?";
"S2.P12.O1" = "לבדוק אם עוקבים אחרינו";
"S2.P12.O2" = "לדבר עם מיה";

"S2.P13.N" = "מיה משפילה מבט. 'היית היחיד שלא נראה כמו טורף הלילה. הייתי צריכה בן אדם, לא שכיר חרב.'";
"S2.P13.Q" = "להגיב בעדינות?";
"S2.P13.O1" = "אני שמח שהייתי שם";
"S2.P13.O2" = "אני סתם בחור בבר";

"S2.P14.N" = "מיה מקישה על השבב. 'זו התודעה של אחותי. היא הייתה האקרית שראתה יותר מדי. הם 'הרגו' את הגוף שלה.'";
"S2.P14.Q" = "להביע אמפתיה?";
"S2.P14.O1" = "זה נורא...";
"S2.P14.O2" = "אפשר להציל אותה?";

"S2.P15.N" = "היא מוחה דמעה. 'נקודת ההעלאה היא במגדל הטלוויזיה הישן. אבל הגשר חסום על ידי מחסום משטרתי.'";
"S2.P15.Q" = "איך חוצים?";
"S2.P15.O1" = "תשתמשי בכישורי ההאקינג שלך";
"S2.P15.O2" = "לשחד את השומרים";

"S2.P16.N" = "מיה מראה לך מפה. 'אם נלך דרך הביוב זה בטוח יותר, אבל זו דרך ארוכה.'";
"S2.P16.Q" = "לבחור מסלול?";
"S2.P16.O1" = "בואי נלך דרך הביוב";
"S2.P16.O2" = "לא, אנחנו חייבים מהירות";

"S2.P17.N" = "מלוכלך וחשוך שם, אבל זה עובד. מיה נסמכת על ההדרכה שלך. אתה מרגיש את כובד האמון שלה.";
"S2.P17.Q" = "לעזור לה לעבור מכשול?";
"S2.P17.O1" = "לתת לה יד";
"S2.P17.O2" = "להוביל את הדרך";

"S2.P18.N" = "הגשר כאוטי. אתם משתמשים בבלגן כדי לחלוף על פניו. הלב של מיה פועם כל כך מהר שאתה כמעט שומע אותו.";
"S2.P18.Q" = "להרגיע אותה?";
"S2.P18.O1" = "אנחנו כמעט שם";
"S2.P18.O2" = "תישארי מרוכזת, מיה";

"S2.P19.N" = "מגדל הטלוויזיה מתנשא לפניכם. מיה נראית מותשת לגמרי.";
"S2.P19.Q" = "להציע הפסקה?";
"S2.P19.O1" = "ננוח 5 דקות";
"S2.P19.O2" = "בואי נמשיך עד הסוף";

"S2.P20.N" = "אתם מגיעים לבסיס המגדל. 'המעלית מושבתת,' מיה נאנחת. 'נצטרך לטפס.'";
"S2.P20.Q" = "לעודד אותה?";
"S2.P20.O1" = "צעד אחר צעד";
"S2.P20.O2" = "אני אסחב את הציוד";

"S2.P21.N" = "אתם יושבים על המדרגות. מיה נשענת עליך. 'אם נצליח... מה תעשה מחר?'";
"S2.P21.Q" = "לחשוב על העתיד?";
"S2.P21.O1" = "אולי נלך לשתות קפה";
"S2.P21.O2" = "אני פשוט אשמח לישון";

"S2.P22.N" = "הטיפוס מפרך. בחצי הדרך, אתם שומעים סירנות למטה. הם מצאו את המכונית שלך.";
"S2.P22.Q" = "להזדרז?";
"S2.P22.O1" = "להכפיל את הקצב!";
"S2.P22.O2" = "למצוא מקום להתחבא";

"S2.P23.N" = "הגעתם לחדר השרתים. האוויר קר ומזמזם מעוצמה. מיה מחברת את השבב. 'מפעילה...' היא אומרת.";
"S2.P23.Q" = "להביט במסך?";
"S2.P23.O1" = "לשמור על הדלת";
"S2.P23.O2" = "להישאר לצד מיה";

"S2.P24.N" = "המסוף עתיק אך עובד. האצבעות של מיה עפות על המקשים. 'חומת האש עצומה!'";
"S2.P24.Q" = "לעזור לה לפרוץ?";
"S2.P24.O1" = "לעקוף את מערכת החשמל";
"S2.P24.O2" = "לשמור עליה יציבה";

"S2.P25.N" = "הדלתות משמיעות רעש. הצוות הטקטי של ארסאקה כאן. אתה שולף נשק. 'עוד שתי דקות!' מיה צורחת.";
"S2.P25.Q" = "להחזיק את הקו?";
"S2.P25.O1" = "אש!";
"S2.P25.O2" = "לחסום את הדלת";

"S2.P26.N" = "עיניה של מיה זוהרות בכחול. היא עמוק בתוך הרשת. החיילים פורצים דרך תקרת הזכוכית.";
"S2.P26.Q" = "להגן על מיה?";
"S2.P26.O1" = "לחפות עליה בגופך";
"S2.P26.O2" = "למשוך אותה למחסה";

"S2.P27.N" = "הבזק אור מסנוור. ההעלאה הושלמה ב-100%. החיילים קופאים – השתלים שלהם שובשו מהרשת.";
"S2.P27.Q" = "לבדוק מה עם מיה?";
"S2.P27.O1" = "זה נגמר?";
"S2.P27.O2" = "את בסדר?";

"S2.P28.N" = "הכל מחשיך. ואז, כל מסך בטוקיו נדלק עם הודעה אחת: 'חופש'. מיה קורסת לזרועותיך.";
"S2.P28.Q" = "להעיר אותה?";
"S2.P28.O1" = "מיה! דברי איתי!";
"S2.P28.O2" = "להחזיק אותה חזק";

"S2.P29.N" = "השמש מתחילה לזרוח מעל טוקיו אחרת. מיה מחייכת, עיניה חזרו למצבן הרגיל. 'היא בטוחה. אנחנו בטוחים.'";
"S2.P29.Q" = "הסוף";
"S2.P29.O1" = "התחל סיפור מחדש";
"S2.P29.O2" = "סיום";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "הלילה האחרון של מחנה הקיץ. המדורה דועכת, וריח האורנים באוויר. יוקי, בדרך כלל ביישנית, תופסת את מבטך ומסמנת לעבר השביל החשוך שמוביל לאגם.";
"S3.P0.Q" = "תעקוב אחריה לתוך הלילה?";
"S3.P0.O1" = "חיכיתי לזה";
"S3.P0.O2" = "בטח, בואי נלך";

"S3.P1.N" = "אתה משיג אותה. היער חי עם קולות הצרצרים. היד של יוקי נוגעת בשלך מדי פעם בזמן שאתם הולכים. היא נראית לחוצה.";
"S3.P1.Q" = "איך תשבור את השתיקה?";
"S3.P1.O1" = "תפוס את ידה בחוזקה";
"S3.P1.O2" = "שאל אותה מה עובר עליה";

"S3.P2.N" = "אתם הולכים זה לצד זה. אור הירח בקושי חודר את העצים. יוקי מביטה בך מהצד ומחייכת חיוך קטן. 'לא חשבתי שבאמת תבוא,' היא לוחשת.";
"S3.P2.Q" = "מה התשובה שלך?";
"S3.P2.O1" = "לא הייתי מפספס את זה";
"S3.P2.O2" = "הייתי סקרן";

"S3.P3.N" = "הגעתם למזח. המים נראים כמו מראה כהה שמשקפת את הכוכבים. יוקי חולצת נעליים ויושבת על הקצה, מטלטלת את רגליה.";
"S3.P3.Q" = "לשבת קרוב אליה?";
"S3.P3.O1" = "לשבת ממש לידה";
"S3.P3.O2" = "לתת לה קצת מרחב";

"S3.P4.N" = "המזח חורק תחת משקלך. האוויר הקר מהאגם גורם ליוקי לרעוד מעט. היא לא זזה כשאתה מתקרב.";
"S3.P4.Q" = "להציע את הג'קט שלך?";
"S3.P4.O1" = "שים עליה את הג'קט";
"S3.P4.O2" = "פשוט לשבת ולדבר";

"S3.P5.N" = "יוקי מביטה בכוכבים. 'אתה זוכר את היום הראשון שלנו כאן?' היא שואלת. 'עזרת לי עם התיקים כשכולם היו עסוקים.'";
"S3.P5.Q" = "אתה זוכר?";
"S3.P5.O1" = "אני זוכר כל פרט";
"S3.P5.O2" = "זה מרגיש כאילו עבר נצח";

"S3.P6.N" = "היא צוחקת בשקט. 'כל כך פחדתי אז. אבל לראות אותך גרם לי להרגיש שאני שייכת לכאן.' היא מביטה במים.";
"S3.P6.Q" = "להודות ברגשות שלך?";
"S3.P6.O1" = "הרגשתי בדיוק אותו דבר";
"S3.P6.O2" = "אני שמח שיכולתי לעזור";

"S3.P7.N" = "הלילה שקט לגמרי. פתאום יוקי קמה. 'המים נראים כל כך מזמינים. אולי... ניכנס?' היא שואלת עם ניצוץ שובב בעיניים.";
"S3.P7.Q" = "אתה מספיק אמיץ?";
"S3.P7.O1" = "בואי נקפוץ פנימה!";
"S3.P7.O2" = "קר מדי, יוקי";

"S3.P8.N" = "היא מביטה באגם, ואז בך. 'אני רוצה לעשות משהו אמיץ הלילה. משהו שאזכור כל החורף.'";
"S3.P8.Q" = "לעודד אותה?";
"S3.P8.O1" = "קופצת איתי?";
"S3.P8.O2" = "בואי נישאר כאן";

"S3.P9.N" = "ספלאש! המים קפואים אבל מעוררים. אתה ויוקי עולים מעל פני המים, צוחקים ומשפריצים אחד על השנייה כמו ילדים.";
"S3.P9.Q" = "לשחות קרוב יותר אליה?";
"S3.P9.O1" = "למשוך אותה לחיבוק";
"S3.P9.O2" = "להמשיך להשפריץ!";

"S3.P10.N" = "נשארתם על המזח. אתם מדברים שעות על הכל – בית ספר, הורים והעתיד. הקשר ביניכם מתחזק בשתיקה.";
"S3.P10.Q" = "להתקרב אליה?";
"S3.P10.O1" = "להניח את הראש שלך על שלה";
"S3.P10.O2" = "להביט לה בעיניים";

"S3.P11.N" = "האווירה משתנה. יוקי מפסיקה לדבר. באור העמום, עיניה מחפשות את שלך. 'אני לא רוצה לחזור לעיר מחר,' היא לוחשת.";
"S3.P11.Q" = "מה תגיד?";
"S3.P11.O1" = "אנחנו נתראה שם";
"S3.P11.O2" = "בואי לא נחשוב על מחר";

"S3.P12.N" = "יוקי לוקחת נשימה עמוקה. 'אם לא אגיד את זה עכשיו, לא אגיד את זה לעולם. אהבתי אותך מאז היום הראשון בתחנת האוטובוס.'";
"S3.P12.Q" = "איך תגיב?";
"S3.P12.O1" = "גם אני אהבתי אותך";
"S3.P12.O2" = "סוף סוף, האמת!";

"S3.P13.N" = "היא מכניסה יד לכיס ושולפת צמיד חברות בעבודת יד. הוא בכחול ולבן, צבעי האגם. 'הכנתי לך את זה,' היא אומרת בביישנות.";
"S3.P13.Q" = "לקבל את המתנה?";
"S3.P13.O1" = "לתת לה לקשור לך את הצמיד";
"S3.P13.O2" = "לתת לה נשיקה במקום";

"S3.P14.N" = "הצמיד פשוט, אבל אתה יודע שלקח לה שעות להכין אותו. היא מחכה לתגובה שלך, שפתה התחתונה רועדת מעט.";
"S3.P14.Q" = "מה הצעד שלך?";
"S3.P14.O1" = "להודות לה בחיבוק";
"S3.P14.O2" = "להגיד לה שזה מושלם";

"S3.P15.N" = "יוקי מחייכת חיוך אמיתי וקורן. 'כל כך דאגתי שתחשוב שזה ילדותי.' היא מביטה בירח, נראית בטוחה יותר עכשיו.";
"S3.P15.Q" = "להבטיח הבטחה?";
"S3.P15.O1" = "מבטיח להתקשר כל יום";
"S3.P15.O2" = "מבטיח לבקר אותך בקרוב";

"S3.P16.N" = "האוויר מחושמל. יוקי בוהה בשפתיים שלך. העולם סביבכם נעלם; זה רק שניכם וליל הקיץ.";
"S3.P16.Q" = "זה הרגע?";
"S3.P16.O1" = "להתקרב לנשיקה";
"S3.P16.O2" = "ללחוש משהו מתוק";

"S3.P17.N" = "בדיוק אז, כוכב נופל חוצה את השמים. יוקי נשימתה נעתקת. 'מהר! תבקש משאלה!' היא קוראת.";
"S3.P17.Q" = "מה תבקש?";
"S3.P17.O1" = "לבקש עתיד ביחד";
"S3.P17.O2" = "לבקש שהלילה הזה לא ייגמר";

"S3.P18.N" = "הכוכב נעלם מהר כפי שהגיע. יוקי עוצמת עיניים חזק. 'ביקשתי משהו חשוב,' היא אומרת ומסמיקה.";
"S3.P18.Q" = "לשאול מה זה היה?";
"S3.P18.O1" = "ספרי לי מה ביקשת";
"S3.P18.O2" = "אני חושב שאני יודע מה זה היה";

"S3.P19.N" = "האש במחנה כבתה לגמרי. אתם מתחילים ללכת חזרה, יד ביד. היער מרגיש שונה עכשיו – קסום יותר.";
"S3.P19.Q" = "ללכת לאט?";
"S3.P19.O1" = "לקחת את הדרך הארוכה";
"S3.P19.O2" = "ליהנות מהשתיקה";

"S3.P20.N" = "אתם עוברים ליד עץ האלון הישן שבו נפגשתם לראשונה. יוקי עוצרת לרגע. 'הכל עומד להשתנות, לא?' היא שואלת בשקט.";
"S3.P20.Q" = "לנחם אותה?";
"S3.P20.O1" = "שינוי יכול להיות דבר טוב";
"S3.P20.O2" = "לא הכל חייב להשתנות";

"S3.P21.N" = "בקתות המחנה כבר נראות לעין. יוקי עוצרת ליד הדלת שלה. היא לא רוצה לעזוב את היד שלך.";
"S3.P21.Q" = "דבר אחד אחרון?";
"S3.P21.O1" = "לבקש נשיקה אחרונה";
"S3.P21.O2" = "לבקש את מספר הטלפון שלה";

"S3.P22.N" = "יוקי משתהה בפתח הדלת. 'תודה על הלילה. זה היה הלילה הכי טוב בחיים שלי.'";
"S3.P22.Q" = "להיפרד?";
"S3.P22.O1" = "נתראה בבוקר";
"S3.P22.O2" = "לילה טוב, יוקי";

"S3.P23.N" = "זריחה. המחנה הומה אנשים שאורזים תיקים ועולים לאוטובוסים. אתה מחפש את יוקי בקהל, הלב שלך דופק.";
"S3.P23.Q" = "האם תמצא אותה?";
"S3.P23.O1" = "חפש ליד האוטובוסים";
"S3.P23.O2" = "בדוק במזח פעם אחרונה";

"S3.P24.N" = "מנועי האוטובוסים מזמזמים. ראית אותה! היא עומדת ליד השער, מחפשת מסביב בטירוף עד שהיא רואה אותך.";
"S3.P24.Q" = "לרוץ אליה?";
"S3.P24.O1" = "לרוץ ולחבק אותה";
"S3.P24.O2" = "לנפנף לשלום ולחייך";

"S3.P25.N" = "הגעת אליה בדיוק בזמן. היא לוחשת לך משהו באוזן שלעולם לא תשכח. 'אל תיתן לזה להיות רק זיכרון של קיץ.'";
"S3.P25.Q" = "מה התשובה שלך?";
"S3.P25.O1" = "זו הבטחה";
"S3.P25.O2" = "נתראה בסוף השבוע הבא";

"S3.P26.N" = "נהג האוטובוס מצפצף. יוקי חייבת ללכת. היא שולחת לך נשיקה באוויר. אתה עומד שם וצופה באוטובוס נעלם באבק.";
"S3.P26.Q" = "איך אתה מרגיש?";
"S3.P26.O1" = "מאושר ומלא תקווה";
"S3.P26.O2" = "עצוב אבל מסופק";

"S3.P27.N" = "חודשים לאחר מכן. אתה בעיר, והטלפון שלך רוטט. זו תמונה מיוקי – היא עונדת את הצמיד שלכם. הקיץ אף פעם לא באמת נגמר.";
"S3.P27.Q" = "הסוף";
