"S3.P21.N" = "कैंप के केबिन दिखने लगे हैं। बाकी सब सो रहे हैं। युकी अपने दरवाजे पर रुकती है। वह आपका हाथ नहीं छोड़ना चाहती।";
"S3.P21.Q" = "एक आखिरी चीज़?";
"S3.P21.O1" = "एक आखिरी किस के लिए पूछें";
"S3.P21.O2" = "उसका फोन नंबर मांगें";

"S3.P22.N" = "युकी दरवाजे पर रुकी रहती है। बरामदे की रोशनी उसके चेहरे पर हल्की चमक बिखेर रही है। 'आज के लिए शुक्रिया। यह मेरी ज़िंदगी की सबसे अच्छी रात थी।'";
"S3.P22.Q" = "अलविदा कहेंगे?";
"S3.P22.O1" = "सुबह मिलते हैं";
"S3.P22.O2" = "गुडनाइट, युकी";

"S3.P23.N" = "सूर्योदय। कैंप में भीड़भाड़ है, लोग बैग पैक कर रहे हैं और बसों में चढ़ रहे हैं। आप भीड़ में युकी को तलाश रहे हैं, आपका दिल तेज़ी से धड़क रहा है।";
"S3.P23.Q" = "क्या आप उसे ढूंढ पाएंगे?";
"S3.P23.O1" = "बस के पास देखें";
"S3.P23.O2" = "एक आखिरी बार घाट पर चेक करें";

"S3.P24.N" = "बसों के इंजन की आवाज़ आ रही है। वह दिख गई! वह गेट के पास खड़ी होकर पागलों की तरह यहाँ-वहाँ देख रही है जब तक कि उसकी नज़र आप पर नहीं पड़ती।";
"S3.P24.Q" = "उसकी तरफ दौड़ें?";
"S3.P24.O1" = "दौड़कर उसे गले लगा लें";
"S3.P24.O2" = "हाथ हिलाएं और मुस्कुराएं";

"S3.P25.N" = "आप बिल्कुल सही समय पर उसके पास पहुँचते हैं। वह आपके कान में कुछ फुसफुसाती है जिसे आप कभी नहीं भूलेंगे। 'इसे सिर्फ एक गर्मियों की याद बनकर मत रहने देना।'";
"S3.P25.Q" = "अपना जवाब दें?";
"S3.P25.O1" = "यह मेरा वादा है";
"S3.P25.O2" = "मैं तुम्हें अगले हफ्ते मिलूँगा";

"S3.P26.N" = "बस ड्राइवर हॉर्न बजाता है। युकी को जाना है। बस में चढ़ते हुए वह आपको 'फ्लाइंग किस' देती है। आप वहीं खड़े धूल में बस को गायब होते हुए देखते रहते हैं।";
"S3.P26.Q" = "आप कैसा महसूस कर रहे हैं?";
"S3.P26.O1" = "खुश और उम्मीद से भरा हुआ";
"S3.P26.O2" = "दुखी पर संतुष्ट";

"S3.P27.N" = "महीनों बाद। आप शहर में हैं और आपका फोन बजता है। यह युकी की फोटो है—उसने वही ब्रेसलेट पहना हुआ है। समर कभी खत्म नहीं हुआ।";
"S3.P27.Q" = "समाप्त";
"S3.P27.O1" = "कहानी फिर से शुरू करें";
"S3.P27.O2" = "खत्म करें";

"S3.P28.N" = "आप अपनी कलाई पर बंधे ब्रेसलेट को देखते हैं। यह थोड़ा घिस गया है, पर यादें आज भी ताज़ा हैं। कभी-कभी, एक समर ही पूरी ज़िंदगी के लिए काफी होता है।";
