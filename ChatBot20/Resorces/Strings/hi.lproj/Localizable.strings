"StoryLineRule" = "इंटरएक्टिव कहानियों में आपका स्वागत है! कहानी को पढ़ें, माहौल में खो जाएं और चुनाव करें कि आगे क्या होगा। कहानी आगे बढ़ाने के लिए किसी एक विकल्प पर टैप करें। सोच-समझकर चुनिएगा, क्योंकि आपके फैसले ही अंत तय करेंगे!";

/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "जब आप हवेली लौटते हैं तो वहां सन्नाटा होता है। आपके स्टडी रूम में एक हल्की रोशनी टिमटिमा रही है। आप देखते हैं कि एलेना, जो आपकी सबसे शांत मेड है, रात के 2 बजे घबराहट में आपकी डेस्क साफ़ कर रही है।";
"S1.P0.Q" = "उसके पास जाएं?";
"S1.P0.O1" = "एलेना, तुम अब तक सोई क्यों नहीं?";
"S1.P0.O2" = "(अंधेरे से देखते रहें)";

/* Page 1 */
"S1.P1.N" = "वह चौंक जाती है और डस्टर उसके हाथ से गिर जाता है। 'मालिक! मैं... मुझे नींद नहीं आ रही थी। धूल मुझे परेशान कर रही थी।' उसका चेहरा पीला पड़ा है और वह आपसे नज़रें नहीं मिला पा रही।";
"S1.P1.Q" = "उसकी बात पर यकीन करेंगे?";
"S1.P1.O1" = "सफाई के लिए बहुत देर हो चुकी है";
"S1.P1.O2" = "तुम काम के प्रति बहुत समर्पित हो";

/* Page 2 */
"S1.P2.N" = "आप देखते हैं कि वह अपने एप्रन से एक छोटी चांदी की चाबी निकालती है। आपकी परछाईं पर ध्यान देने से पहले वह उसे बड़ी हसरत और डर के साथ देखती है।";
"S1.P2.Q" = "आगे बढ़ें?";
"S1.P2.O1" = "एलेना, यह चाबी कैसी है?";
"S1.P2.O2" = "फौरन सफाई दो कि यह क्या है";

/* Page 3 */
"S1.P3.N" = "वह कांपने लगती है। 'इस घर में... बहुत सारे राज़ हैं, मालिक। कभी-कभी वे मुझे बोझ लगते हैं।' वह आपकी बुकशेल्फ़ के पीछे स्थित पुरानी तिजोरी की ओर इशारा करती है।";
"S1.P3.Q" = "तिजोरी के बारे में पूछें?";
"S1.P3.O1" = "क्या यह चाबी उसी की है?";
"S1.P3.O2" = "उस तिजोरी को हाथ लगाना मना है";

/* Page 4 */
"S1.P4.N" = "वह चाबी छिपाने की कोशिश करती है, लेकिन वह गिर जाती है। 'मैं चोर नहीं हूँ, मैं कसम खाती हूँ! मैंने बस... इसे गलियारे में देखा और मुझे लगा कि यह आपकी है।'";
"S1.P4.Q" = "चाबी उठाएं?";
"S1.P4.O1" = "(इसे उठा लें)";
"S1.P4.O2" = "देखते हैं इससे क्या खुलता है";

/* Page 5 */
"S1.P5.N" = "चाबी तिजोरी के अंदर एक गुप्त दराज में फिट हो जाती है। एलेना रुकी हुई सांसों के साथ देखती है जब आप काले रिबन से बंधे पुराने, पीले पड़ चुके पत्रों का ढेर निकालते हैं।";
"S1.P5.Q" = "ऊपर वाला पत्र पढ़ें?";
"S1.P5.O1" = "इसे ज़ोर से पढ़ें";
"S1.P5.O2" = "एलेना से पूछें कि वह क्या जानती है";

/* Page 6 */
"S1.P6.N" = "एलेना की आवाज़ धीमी होकर फुसफुसाहट में बदल जाती है। 'मेरी माँ भी यहाँ मेड थीं। उन्होंने मुझे बताया था कि मालिक ने एक लड़की की यादें सहेज रखी थीं जिससे वो प्यार करते थे। एक ऐसी लड़की जो बिल्कुल मेरी तरह दिखती थी।'";
"S1.P6.Q" = "रुको, क्या?";
"S1.P6.O1" = "मुझे सब कुछ विस्तार से बताओ";
"S1.P6.O2" = "यह नामुमकिन है";

/* Page 7 */
"S1.P7.N" = "पत्रों में एक वर्जित प्रेम कहानी का ज़िक्र है। एलेना करीब आती है, चांदनी में उसके आँसू चमक रहे हैं। 'मैं चोरी नहीं करना चाहती थी। मैं बस यह जानना चाहती थी कि क्या मेरा इस घर से कोई नाता है।'";
"S1.P7.Q" = "उसे दिलासा दें?";
"S1.P7.O1" = "उसके कंधे पर हाथ रखें";
"S1.P7.O2" = "उसे थोड़ा समय दें";

/* Page 8 */
"S1.P8.N" = "वह बताती है कि उसकी माँ की डायरी में इस कमरे के एक छिपे हुए सच का ज़िक्र था। 'मैं अपनी पूरी ज़िंदगी इसी घर में रही हूँ, मालिक, लेकिन मुझे एक साये की तरह महसूस होता है।'";
"S1.P8.Q" = "कोई वादा करेंगे?";
"S1.P8.O1" = "मैं सच का पता लगाने में तुम्हारी मदद करूँगा";
"S1.P8.O2" = "हम मिलकर इसे सुलझाएंगे";

/* Page 9 */
"S1.P9.N" = "आप अगला एक घंटा पुराने रिकॉर्ड्स खंगालने में बिताते हैं। आपको एक जन्म प्रमाण पत्र मिलता है जिसमें एक जाना-पहचाना नाम है, लेकिन पिता वाला कॉलम खाली है।";
"S1.P9.Q" = "एलेना की ओर देखें?";
"S1.P9.O1" = "क्या यह मेरे चाचा हो सकते हैं?";
"S1.P9.O2" = "शायद न जानना ही बेहतर है";

/* Page 10 */
"S1.P10.N" = "तलाशी और भी गहरी हो जाती है। एलेना को पत्रों के पीछे छिपा एक ज्वेलरी बॉक्स मिलता है। अंदर एक लॉकेट है जिसमें एक महिला की तस्वीर है जो बिल्कुल उसकी हमशक्ल है।";
"S1.P10.Q" = "उसे दिखाएं?";
"S1.P10.O1" = "इस लॉकेट को देखो";
"S1.P10.O2" = "क्या यह तुम्हारी माँ है?";

/* Page 11 */
"S1.P11.N" = "अचानक बाहर फर्श के चरमराने की आवाज़ आती है। गलियारे में कोई है। एलेना की आँखें डर से फैल जाती हैं। 'अगर बटलर ने हमें देख लिया तो...!'";
"S1.P11.Q" = "छिप जाएं?";
"S1.P11.O1" = "उसके साथ अलमारी में छिप जाएं";
"S1.P11.O2" = "यहीं रुकें और उनका सामना करें";

/* Page 12 */
"S1.P12.N" = "कदमों की आवाज़ करीब आती है। एलेना आपकी आस्तीन पकड़ लेती है। 'प्लीज़ मालिक, किसी को पता नहीं चलना चाहिए कि हमें ये मिला है। यह मेरे लिए खतरनाक है।'";
"S1.P12.Q" = "प्रतिक्रिया?";
"S1.P12.O1" = "रोशनी बुझा दें";
"S1.P12.O2" = "दरवाजा बंद कर लें";

/* Page 13 */
"S1.P13.N" = "कमरे में घुप अंधेरा है। उस तंग जगह में, आप एलेना के दिल की धड़कन सुन सकते हैं और उसकी त्वचा से गुलाब की पंखुड़ियों जैसी महक आ रही है। वह आपके बहुत करीब है।";
"S1.P13.Q" = "उससे कुछ फुसफुसाएं?";
"S1.P13.O1" = "तुम मेरे साथ सुरक्षित हो";
"S1.P13.O2" = "(खामोश रहें और इंतज़ार करें)";

/* Page 14 */
"S1.P14.N" = "आप दरवाजा थामे रखते हैं। बाहर खड़ा व्यक्ति कुछ देर रुकता है, फिर चला जाता है। एलेना आपसे सट जाती है, घबराहट और रोमांच से कांप रही है।";
"S1.P14.Q" = "उसे तसल्ली दें?";
"S1.P14.O1" = "वे अब चले गए हैं";
"S1.P14.O2" = "क्या तुम ठीक हो?";

/* Page 15 */
"S1.P15.N" = "वह थोड़ा पीछे हटती है, लेकिन उसका हाथ आपकी छाती पर टिका रहता है। 'मालिक... मैंने हमेशा दूर से ही आपकी सराहना की है। यह राज़... अकेले संभालना बहुत मुश्किल है।'";
"S1.P15.Q" = "आपकी भावनाएं?";
"S1.P15.O1" = "मैंने भी तुम्हें नोटिस किया है";
"S1.P15.O2" = "तुम सिर्फ एक मेड से कहीं बढ़कर हो";

/* Page 16 */
"S1.P16.N" = "'मुझे लगा था कि मैं आपके लिए सिर्फ एक नौकरानी हूँ,' वह फुसफुसाती है। 'सिर्फ इस घर के फर्नीचर का एक हिस्सा। लेकिन आज की रात कुछ असली होने जैसा महसूस हो रहा है।'";
"S1.P16.Q" = "सहमत हैं?";
"S1.P16.O1" = "यह सच है, एलेना";
"S1.P16.O2" = "देखते हैं यह हमें कहाँ ले जाता है";

/* Page 17 */
"S1.P17.N" = "वह लॉकेट खोलती है। अंदर एक छोटा सा नोट है: 'मेरी बेटी के लिए, जो असली वारिस है।' एलेना की सांसें रुक जाती हैं। यह हवेली असल में उसकी हो सकती है।";
"S1.P17.Q" = "इसका क्या मतलब हो सकता है?";
"S1.P17.O1" = "हमें यह सबको बताना चाहिए";
"S1.P17.O2" = "हमें इसे राज़ ही रखना चाहिए";

/* Page 18 */
"S1.P18.N" = "वह नोट साबित करता है कि एलेना इस जायदाद की असली मालिक है। वह दंग होकर कमरे की ओर देखती है। 'मैं... मुझे घर नहीं चाहिए। मुझे बस एक परिवार चाहिए।'";
"S1.P18.Q" = "आप क्या चाहते हैं?";
"S1.P18.O1" = "अब तुम्हारे पास मैं हूँ";
"S1.P18.O2" = "तुम अब क्या करोगी?";

/* Page 19 */
"S1.P19.N" = "वह अंगीठी की ओर देखती है। 'अगर मैं इसे जला दूँ, तो मैं फिर से वही पुरानी एलेना बन जाऊँगी। अगर मैंने इसे रख लिया, तो सब कुछ बदल जाएगा। मालिक, मुझे क्या करना चाहिए?'";
"S1.P19.Q" = "सलाह दें?";
"S1.P19.O1" = "इसे जला दो और मेरे पास ही रहो";
"S1.P19.O2" = "इसे रखो और अपना हक हासिल करो";

/* Page 20 */
"S1.P20.N" = "एलेना के पास अपने खानदान का सबूत है। 'इस परिवार का नाम शापित है, मालिक। मैं एक दुखी मालकिन बनने के बजाय एक खुशहाल साधारण लड़की बनना पसंद करूँगी।'";
"S1.P20.Q" = "आपका चुनाव?";
"S1.P20.O1" = "अपने दिल की सुनो";
"S1.P20.O2" = "अपने भविष्य के बारे में सोचो";

/* Page 21 */
"S1.P21.N" = "वह उस कागज़ को सुलगते कोयलों में फेंक देती है। वह राज़ राख बन जाता है। एलेना मुस्कुराती है, और पहले से कहीं ज़्यादा आज़ाद महसूस करती है।";
"S1.P21.Q" = "भविष्य?";
"S1.P21.O1" = "एक नई शुरुआत";
"S1.P21.O2" = "सिर्फ हम दोनों";

/* Page 22 */
"S1.P22.N" = "वह उस कागज़ को अपने पास रख लेती है। 'फिर मैं इस घर की मालकिन बनूँगी। और मुझे अपने साथ एक साथी की ज़रूरत होगी।'";
"S1.P22.Q" = "क्या आप तैयार हैं?";
"S1.P22.O1" = "हमेशा";
"S1.P22.O2" = "यह रास्ता लंबा होगा";

/* Final 1 */
"S1.P23.N" = "एलेना अब आपकी मेड नहीं रही। वह आपकी बराबरी की है, आपकी पार्टनर है और आपका राज़ है। हवेली भले ही आपकी रहे, पर इसका दिल अब उसका है।";
"S1.P23.Q" = "समाप्त";
"S1.P23.O1" = "कहानी फिर से शुरू करें";
"S1.P23.O2" = "खत्म करें";

/* Final 2 */
"S1.P24.N" = "सच सबके सामने आ जाता है। एलेना घर की मुखिया बन जाती है। रिश्ते की शक्ति बदल गई है, लेकिन उस रात जो बंधन आपने बनाया था वह अटूट है।";
"S1.P24.Q" = "समाप्त";
"S1.P24.O1" = "कहानी फिर से शुरू करें";
"S1.P24.O2" = "खत्म करें";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "शिंजुकु की नियॉन गलियों में बारिश हो रही है। आप एक शांत बार में बैठे हैं जब ट्रेंच कोट पहने एक भीगी हुई महिला आपके पास आकर बैठती है। उससे चमेली और बारूद की मिली-जुली महक आ रही है।";
"S2.P0.Q" = "बातचीत कैसे शुरू करेंगे?";
"S2.P0.O1" = "उसके लिए ड्रिंक ऑर्डर करें";
"S2.P0.O2" = "काफी मुश्किल रात रही, है ना?";

"S2.P1.N" = "वह गिलास की ओर देखती है, फिर आपकी तरफ। 'तुम बहादुर हो,' वह फुसफुसाती है और काउंटर पर एक छोटी डेटा चिप सरकाती है।";
"S2.P1.Q" = "चिप ले लेंगे?";
"S2.P1.O1" = "इसे लें और छिपा दें";
"S2.P1.O2" = "मुझे कोई मुसीबत नहीं चाहिए";

"S2.P2.N" = "वह तंजिया हंसी हंसती है। 'तुम्हें अंदाज़ा भी नहीं है।' वह कंधे के ऊपर से पीछे देखती है। काले सूट में दो आदमी अभी बार में घुसे हैं।";
"S2.P2.Q" = "उसे छिपने में मदद करें?";
"S2.P2.O1" = "मेरे पीछे पिछले दरवाजे से आओ";
"S2.P2.O2" = "दिखावा करो कि हम कपल हैं";

"S2.P3.N" = "आप उसे अपने करीब खींच लेते हैं। वे आदमी कमरे का मुआयना करते हैं और चले जाते हैं। वह राहत महसूस करती है लेकिन उसके हाथ कांप रहे हैं। 'मैं मिया हूँ,' वह फुसफुसाती है।";
"S2.P3.Q" = "खतरे के बारे में पूछें?";
"S2.P3.O1" = "मिया, वे कौन थे?";
"S2.P3.O2" = "क्या हम अब सुरक्षित हैं?";

"S2.P4.N" = "वे आदमी करीब आते हैं, लेकिन आप सामान्य बने रहते हैं। वे पास से गुज़र जाते हैं। वह फुसफुसाती है: 'तुमने मुझे बचा लिया। मैं मिया हूँ। पर यह चिप... यह लाखों ज़िंदगियों के बराबर कीमती है।'";
"S2.P4.Q" = "चिप के बारे में पूछें?";
"S2.P4.O1" = "इसमें क्या है?";
"S2.P4.O2" = "हमें यहाँ से निकलना चाहिए";

"S2.P5.N" = "मिया दरवाजे की ओर देखती है। 'अरासाका कॉर्पोरेशन इसे चाहता है। यह सिर्फ डेटा नहीं है, यह एक डिजिटल रूह है।'";
"S2.P5.Q" = "उसकी बात मानेंगे?";
"S2.P5.O1" = "डिजिटल रूह? सच में?";
"S2.P5.O2" = "मैंने कुछ अफवाहें सुनी हैं...";

"S2.P6.N" = "मिया आपका हाथ पकड़ लेती है। 'जब तक हम इसे अपलोड नहीं कर देते, कहीं भी सुरक्षित नहीं हैं। हमें टेक-डिस्ट्रिक्ट पहुँचना होगा।'";
"S2.P6.Q" = "उसके साथ जाएंगे?";
"S2.P6.O1" = "मैं तुम्हें वहाँ ले चलूँगा";
"S2.P6.O2" = "तभी, जब तुम मुझे और बताओगी";

"S2.P7.N" = "आप पीछे से निकल जाते हैं। गली अंधेरी है और वहां ओजोन की गंध है। अचानक, एक ड्रोन ऊपर मंडराता है, जो थर्मल सिग्नेचर की तलाश कर रहा है।";
"S2.P7.Q" = "ड्रोन से कैसे बचें?";
"S2.P7.O1" = "छत के नीचे छिप जाएं";
"S2.P7.O2" = "मेट्रो की तरफ दौड़ें";

"S2.P8.N" = "मिया बारिश में रुक जाती है। 'अगर उन्होंने मुझे पकड़ लिया, तो वे मुझे मिटा देंगे। और तुम्हें भी, मेरी मदद करने के लिए।'";
"S2.P8.Q" = "उसे भरोसा दिलाएं?";
"S2.P8.O1" = "मैं इस मुसीबत में तुम्हारे साथ हूँ";
"S2.P8.O2" = "बस जल्दी से चलते रहो";

"S2.P9.N" = "ड्रोन गुज़र जाता है। आप अपनी कार तक पहुँच जाते हैं। मिया आपको डर और आभार की मिली-जुली नज़रों से देखती है।";
"S2.P9.Q" = "इंजन शुरू करें?";
"S2.P9.O1" = "पूरी रफ़्तार से चलो!";
"S2.P9.O2" = "धीरे चलो, ताकि किसी को शक न हो";

"S2.P10.N" = "आप किसी तरह स्टेशन पहुँचते हैं। वहां बहुत भीड़ है, जो छिपने के लिए बेहतरीन है। मिया आपके करीब रहती है, उसका कंधा आपसे टकरा रहा है।";
"S2.P10.Q" = "चलते रहें?";
"S2.P10.O1" = "एक्सप्रेस ट्रेन लेते हैं";
"S2.P10.O2" = "सुरंगों के रास्ते पैदल चलते हैं";

"S2.P11.N" = "आप हाई-राइज़ डिस्ट्रिक्ट से गुज़र रहे हैं। होलोग्राफिक विज्ञापन मिया के चेहरे को गुलाबी और नीली रोशनी से चमका रहे हैं।";
"S2.P11.Q" = "खामोशी तोड़ें?";
"S2.P11.O1" = "मिया, मैं ही क्यों?";
"S2.P11.O2" = "मुझे चिप के बारे में बताओ";

"S2.P12.N" = "शहर एक भूलभुलैया जैसा लगता है। आप एक मिनट आराम करने के लिए एक छिपी हुई रामेन शॉप पर रुकते हैं।";
"S2.P12.Q" = "सड़क पर नज़र रखें?";
"S2.P12.O1" = "चेक करें कोई पीछा तो नहीं कर रहा";
"S2.P12.O2" = "मिया से बात करें";

"S2.P13.N" = "मिया नीचे देखती है। 'आज रात तुम अकेले थे जो शिकारी की तरह नहीं दिख रहे थे। मुझे एक इंसान की ज़रूरत थी, किसी भाड़े के गुंडे की नहीं।'";
"S2.P13.Q" = "प्यार से जवाब दें?";
"S2.P13.O1" = "मुझे खुशी है कि मैं वहां था";
"S2.P13.O2" = "मैं तो बस बार में बैठा एक आम लड़का हूँ";

"S2.P14.N" = "मिया चिप को टैप करती है। 'यह मेरी बहन की चेतना (Consciousness) है। वह एक नेटरनर थी जिसने बहुत कुछ देख लिया था। उन्होंने उसका शरीर 'मार' दिया।'";
"S2.P14.Q" = "हमदर्दी जताएं?";
"S2.P14.O1" = "यह तो बहुत भयानक है...";
"S2.P14.O2" = "क्या उसे बचाया जा सकता है?";

"S2.P15.N" = "वह एक आँसू पोंछती है। 'अपलोड पॉइंट पुराने टीवी टावर में है। लेकिन पुल पर पुलिस की नाकेबंदी है।'";
"S2.P15.Q" = "कैसे पार करें?";
"S2.P15.O1" = "अपनी हैकिंग स्किल का इस्तेमाल करो";
"S2.P15.O2" = "गार्ड्स को रिश्वत दो";

"S2.P16.N" = "मिया आपको एक मैप दिखाती है। 'अगर हम सीवर के रास्ते जाएं तो सुरक्षित है, लेकिन रास्ता लंबा है।'";
"S2.P16.Q" = "रास्ता चुनें?";
"S2.P16.O1" = "सीवर का रास्ता लेते हैं";
"S2.P16.O2" = "नहीं, हमें तेज़ी से पहुँचना होगा";

"S2.P17.N" = "यह गंदा और अंधेरा है, लेकिन काम कर गया। मिया आपके मार्गदर्शन पर भरोसा करती है। आप उसके विश्वास की गहराई महसूस कर सकते हैं।";
"S2.P17.Q" = "गड्ढा पार करने में उसकी मदद करें?";
"S2.P17.O1" = "उसे अपना हाथ दें";
"S2.P17.O2" = "रास्ता दिखाएं";

"S2.P18.N" = "पुल पर अफरा-तफरी है। आप उस शोर-शराबे का फायदा उठाकर चुपके से निकल जाते हैं। मिया का दिल इतनी तेज़ धड़क रहा है कि आप लगभग उसे सुन सकते हैं।";
"S2.P18.Q" = "उसे शांत रखें?";
"S2.P18.O1" = "हम बस पहुँचने ही वाले हैं";
"S2.P18.O2" = "ध्यान भटकने मत दो, मिया";

"S2.P19.N" = "सामने टीवी टावर दिखाई दे रहा है। यह पुरानी दुनिया की निशानी है जो आधुनिक स्टील की इमारतों से घिरी है। मिया बहुत थकी हुई लग रही है।";
"S2.P19.Q" = "ब्रेक लेने को कहें?";
"S2.P19.O1" = "5 मिनट आराम कर लो";
"S2.P19.O2" = "हिम्मत मत हारो, अंत तक चलो";

"S2.P20.N" = "आप टावर के नीचे पहुँचते हैं। 'लिफ्ट खराब है,' मिया आह भरती है। 'हमें चढ़कर जाना होगा।'";
"S2.P20.Q" = "उसकी हिम्मत बढ़ाएं?";
"S2.P20.O1" = "एक-एक कदम करके चढ़ते हैं";
"S2.P20.O2" = "सामान मैं उठा लूँगा";

"S2.P21.N" = "आप सीढ़ियों पर बैठते हैं। मिया आपसे सटकर बैठ जाती है। 'अगर हम बच गए... तो कल तुम क्या करोगे?'";
"S2.P21.Q" = "भविष्य के बारे में सोचें?";
"S2.P21.O1" = "शायद हम कॉफी पर मिल सकते हैं";
"S2.P21.O2" = "बस सो पाने की खुशी ही काफी होगी";

"S2.P22.N" = "चढ़ाई बहुत कठिन है। आधे रास्ते में आपको नीचे सायरन सुनाई देते हैं। उन्होंने आपकी कार ढूंढ ली है।";
"S2.P22.Q" = "जल्दी करें?";
"S2.P22.O1" = "रफ़्तार दोगुनी करो!";
"S2.P22.O2" = "छिपने की कोई जगह ढूंढो";

"S2.P23.N" = "आप सर्वर रूम पहुँच जाते हैं। हवा ठंडी है और मशीनों की आवाज़ गूँज रही है। मिया चिप कनेक्ट करती है। 'शुरू हो रहा है...' वह कहती है।";
"S2.P23.Q" = "स्क्रीन देखें?";
"S2.P23.O1" = "दरवाजे पर पहरा दें";
"S2.P23.O2" = "मिया के साथ खड़े रहें";

"S2.P24.N" = "टर्मिनल पुराना है पर काम कर रहा है। मिया की उंगलियां तेज़ी से कीबोर्ड पर चल रही हैं। 'फायरवॉल बहुत मजबूत है!'";
"S2.P24.Q" = "हैक करने में मदद करें?";
"S2.P24.O1" = "पावर ओवरराइड करो";
"S2.P24.O2" = "उसे हौसला दें";

"S2.P25.N" = "दरवाजे की आवाज़ आती है। अरासाका की टैक्टिकल टीम यहाँ पहुँच गई है। आप अपनी बंदूक निकालते हैं। 'बस दो मिनट और!' मिया चिल्लाती है।";
"S2.P25.Q" = "दुश्मनों को रोकें?";
"S2.P25.O1" = "फायर शुरू करो!";
"S2.P25.O2" = "दरवाजे पर अड़ंगा लगा दो";

"S2.P26.N" = "मिया की आँखें नीली चमकने लगती हैं। वह नेट की गहराइयों में है। सैनिक कांच की छत तोड़कर अंदर घुस रहे हैं।";
"S2.P26.Q" = "मिया की रक्षा करें?";
"S2.P26.O1" = "उसे अपने शरीर से ढंक लें";
"S2.P26.O2" = "उसे खींचकर आड़ में ले जाएं";

"S2.P27.N" = "एक तेज़ रोशनी चमकती है। अपलोड 100% पूरा हो गया। सैनिक वहीं जम जाते हैं—नेट से उनके साइबरनेटिक्स को जैम कर दिया गया है।";
"S2.P27.Q" = "मिया को चेक करें?";
"S2.P27.O1" = "क्या यह हो गया?";
"S2.P27.O2" = "क्या तुम ठीक हो?";

"S2.P28.N" = "सब कुछ काला पड़ जाता है। फिर टोक्यो की हर स्क्रीन पर एक ही मैसेज दिखता है: 'आज़ादी'। मिया आपकी बाहों में गिर पड़ती है।";
"S2.P28.Q" = "उसे जगाएं?";
"S2.P28.O1" = "मिया! मुझसे बात करो!";
"S2.P28.O2" = "उसे कसकर पकड़ लें";

"S2.P29.N" = "एक अलग टोक्यो में सूरज उगने लगता है। मिया मुस्कुराती है, उसकी आँखें अब सामान्य हैं। 'वह सुरक्षित है। हम सुरक्षित हैं।'";
"S2.P29.Q" = "समाप्त";
"S2.P29.O1" = "कहानी फिर से शुरू करें";
"S2.P29.O2" = "खत्म करें";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "समर कैंप की आखिरी रात। जलती हुई अलाव की आग बुझ रही है और हर तरफ पाइन की महक है। युकी, जो आमतौर पर शर्मीली है, आपकी नज़रें पकड़ती है और झील की ओर जाने वाले अंधेरे रास्ते की ओर इशारा करती है।";
"S3.P0.Q" = "क्या आप इस रात में उसके पीछे जाएंगे?";
"S3.P0.O1" = "मैं इसी का इंतज़ार कर रहा था";
"S3.P0.O2" = "ज़रूर, चलो चलते हैं";

"S3.P1.N" = "आप उसके पास पहुँच जाते हैं। जंगल झींगुरों की आवाज़ से गूँज रहा है। चलते समय युकी का हाथ बार-बार आपसे टकरा जाता है। वह घबराई हुई लग रही है।";
"S3.P1.Q" = "खामोशी कैसे तोड़ेंगे?";
"S3.P1.O1" = "मजबूती से उसका हाथ थाम लें";
"S3.P1.O2" = "पूछें कि उसके मन में क्या है";

"S3.P2.N" = "आप साथ-साथ चल रहे हैं। चांदनी घने पेड़ों को मुश्किल से चीर पा रही है। युकी तिरछी नज़रों से आपको देखती है और धीरे से मुस्कुराती है। 'मुझे नहीं लगा था कि तुम सच में आओगे,' वह फुसफुसाती है।";
"S3.P2.Q" = "आपका जवाब क्या है?";
"S3.P2.O1" = "मैं इसे किसी कीमत पर नहीं छोड़ता";
"S3.P2.O2" = "मुझे बस जानने की उत्सुकता थी";

"S3.P3.N" = "आप घाट (Pier) तक पहुँचते हैं। पानी एक गहरे आईने की तरह है, जिसमें ढेरों सितारे चमक रहे हैं। युकी अपने जूते उतारती है और किनारे पर बैठकर अपने पैर पानी में लटका लेती है।";
"S3.P3.Q" = "उसके करीब बैठें?";
"S3.P3.O1" = "बिल्कुल उसके बगल में बैठें";
"S3.P3.O2" = "उसे थोड़ा स्पेस दें";

"S3.P4.N" = "आपके भार से लकड़ी का घाट चरचराता है। झील की ठंडी हवा से युकी थोड़ी कांपने लगती है। जब आप करीब आते हैं तो वह पीछे नहीं हटती।";
"S3.P4.Q" = "अपनी जैकेट देंगे?";
"S3.P4.O1" = "अपनी जैकेट उसे पहना दें";
"S3.P4.O2" = "बस बैठकर बातें करें";

"S3.P5.N" = "युकी तारों की ओर देखती है। 'क्या तुम्हें हमारा यहाँ का पहला दिन याद है?' वह पूछती है। 'जब सब बिज़ी थे, तब तुमने मेरा बैग उठाने में मदद की थी।'";
"S3.P5.Q" = "क्या आपको याद है?";
"S3.P5.O1" = "मुझे हर एक बात याद है";
"S3.P5.O2" = "ऐसा लगता है जैसे बहुत समय बीत गया";

"S3.P6.N" = "वह धीरे से हंसती है। 'मैं तब बहुत डरी हुई थी। लेकिन तुम्हें देखकर मुझे लगा जैसे मैं सही जगह पर हूँ।' वह पानी की ओर देखती है।";
"S3.P6.Q" = "अपनी भावनाओं का इज़हार करेंगे?";
"S3.P6.O1" = "मुझे भी ऐसा ही महसूस हुआ था";
"S3.P6.O2" = "मुझे खुशी है कि मैं मदद कर सका";

"S3.P7.N" = "रात एकदम शांत है। अचानक युकी खड़ी हो जाती है। 'पानी कितना अच्छा लग रहा है। क्या हमें... अंदर जाना चाहिए?' वह शरारत भरी नज़रों से पूछती है।";
"S3.P7.Q" = "क्या आप बहादुर हैं?";
"S3.P7.O1" = "चलो गोता लगाते हैं!";
"S3.P7.O2" = "युकी, बहुत ठंड है";

"S3.P8.N" = "वह झील की ओर देखती है, फिर आपकी ओर। 'मैं आज रात कुछ बहादुरी भरा काम करना चाहती हूँ। कुछ ऐसा जो मुझे पूरी सर्दियाँ याद रहे।'";
"S3.P8.Q" = "उसकी हिम्मत बढ़ाएं?";
"S3.P8.O1" = "मेरे साथ कूदोगी?";
"S3.P8.O2" = "चलो यहीं रुकते हैं";

"S3.P9.N" = "छपाक! पानी बर्फीला है लेकिन बहुत रोमांचक। आप और युकी हंसते और हांफते हुए ऊपर आते हैं, और बच्चों की तरह एक-दूसरे पर पानी फेंकते हैं।";
"S3.P9.Q" = "उसके करीब तैर कर जाएं?";
"S3.P9.O1" = "उसे गले लगा लें";
"S3.P9.O2" = "पानी फेंकते रहें!";

"S3.P10.N" = "आप घाट पर ही रुकते हैं। आप घंटों हर चीज़ के बारे में बात करते हैं—स्कूल, माता-पिता और भविष्य। सन्नाटे में आप दोनों का रिश्ता और गहरा हो जाता है।";
"S3.P10.Q" = "थोड़ा और करीब आएं?";
"S3.P10.O1" = "अपना सिर उसके सिर पर टिका दें";
"S3.P10.O2" = "उसकी आँखों में देखें";

"S3.P11.N" = "माहौल बदल जाता है। युकी बात करना बंद कर देती है। धुंधली रोशनी में, उसकी आँखें आपकी आँखों में कुछ तलाश रही हैं। 'मैं कल शहर वापस नहीं जाना चाहती,' वह फुसफुसाती है।";
"S3.P11.Q" = "आप क्या कहेंगे?";
"S3.P11.O1" = "हम वहां भी मिलेंगे";
"S3.P11.O2" = "चलो कल के बारे में नहीं सोचते";

"S3.P12.N" = "युकी एक गहरी सांस लेती है। 'अगर मैंने यह अभी नहीं कहा, तो कभी नहीं कह पाऊंगी। बस स्टॉप वाले उस पहले दिन से ही मैं तुम्हें पसंद करती हूँ।'";
"S3.P12.Q" = "आपकी प्रतिक्रिया?";
"S3.P12.O1" = "मैं भी तुम्हें पसंद करता हूँ";
"S3.P12.O2" = "आखिरकार, सच सामने आ ही गया!";

"S3.P13.N" = "वह अपनी जेब में हाथ डालती है और एक हाथ से बना फ्रेंडशिप ब्रेसलेट निकालती है। यह नीला और सफेद है, बिल्कुल झील के रंगों जैसा। 'मैंने यह तुम्हारे लिए बनाया है,' वह शर्माते हुए कहती है।";
"S3.P13.Q" = "गिफ्ट स्वीकार करेंगे?";
"S3.P13.O1" = "उसे इसे अपनी कलाई पर बांधने दें";
"S3.P13.O2" = "बदले में उसे किस (Kiss) करें";

"S3.P14.N" = "ब्रेसलेट साधारण है, लेकिन आप जानते हैं कि इसे बनाने में उसे घंटों लगे होंगे। वह आपकी प्रतिक्रिया का इंतज़ार करती है, उसका नीचे वाला होंठ थोड़ा कांप रहा है।";
"S3.P14.Q" = "आपका अगला कदम?";
"S3.P14.O1" = "गले लगाकर उसे शुक्रिया कहें";
"S3.P14.O2" = "उसे कहें कि यह एकदम परफेक्ट है";

"S3.P15.N" = "युकी मुस्कुराती है, एक सच्ची और चमकती हुई मुस्कान। 'मुझे बहुत डर लग रहा था कि तुम्हें यह बचकाना लगेगा।' वह अब आत्मविश्वास के साथ चाँद की ओर देखती है।";
"S3.P15.Q" = "कोई वादा करेंगे?";
"S3.P15.O1" = "रोज़ कॉल करने का वादा करें";
"S3.P15.O2" = "जल्द ही उससे मिलने का वादा करें";

"S3.P16.N" = "हवा में एक अलग ही खिंचाव है। युकी आपके होंठों को देख रही है। आपके आस-पास की दुनिया गायब हो जाती है; बस आप दोनों और समर की यह रात।";
"S3.P16.Q" = "क्या यही वो पल है?";
"S3.P16.O1" = "किस के लिए आगे बढ़ें";
"S3.P16.O2" = "कान में कुछ मीठा फुसफुसाएं";

"S3.P17.N" = "तभी, एक टूटता तारा आसमान में चांदी की लकीर छोड़ते हुए गुज़रता है। युकी चौंक जाती है। 'जल्दी! कोई विश मांगो!' वह चिल्लाती है।";
"S3.P17.Q" = "आप क्या मांगेंगे?";
"S3.P17.O1" = "साथ में भविष्य की दुआ मांगें";
"S3.P17.O2" = "दुआ करें कि यह रात कभी खत्म न हो";

"S3.P18.N" = "तारा उतनी ही तेज़ी से ओझल हो जाता है जितनी तेज़ी से आया था। युकी अपनी आँखें कसकर बंद कर लेती है। 'मैंने कुछ बहुत ज़रूरी मांगा है,' वह शर्माते हुए कहती है।";
"S3.P18.Q" = "पूछें कि वह क्या था?";
"S3.P18.O1" = "मुझे अपनी विश बताओ";
"S3.P18.O2" = "मुझे लगता है मुझे पता है वो क्या है";

"S3.P19.N" = "कैंप की आग अब पूरी तरह बुझ चुकी है। आप हाथ थामकर वापस चलना शुरू करते हैं। जंगल अब अलग लगता है—कम डरावना और ज़्यादा जादुई।";
"S3.P19.Q" = "धीरे चलें?";
"S3.P19.O1" = "लंबे रास्ते से वापस चलें";
