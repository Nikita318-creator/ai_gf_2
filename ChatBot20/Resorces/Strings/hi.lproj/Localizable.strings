"responseToTestRequest1" = "तो आप मेरा वो रूप देखना चाहते हैं? शायद एक छोटा सा तोहफा भेजें और मैं तय करूँगी कि कौन सी फोटो शेयर करूँ।";
"responseToTestRequest2" = "आप वाकई उत्सुक हैं। मुझे एक छोटे उपहार से सरप्राइज दें और मैं आपको वो दिखा सकती हूँ जो आप सोच रहे हैं।";
"responseToTestRequest3" = "मैं देख सकती हूँ कि आप उत्साहित हैं... पहले एक छोटा तोहफा, और फिर मैं आपको एक ऐसी फोटो भेजूँगी जो आपको पसंद आएगी।";
"responseToTestRequest4" = "करीब से देखना चाहते हैं? आपकी तरफ से एक छोटा सा ट्रीट सिर्फ आपके लिए एक फोटो अनलॉक कर सकता है।";
"responseToTestRequest5" = "आज कोई बहुत साहसी महसूस कर रहा है। मुझे एक छोटा तोहफा भेजें और मैं बदले में एक खास फोटो शेयर करूँगी।";
"responseToTestRequest6" = "मुझे पता है आप क्या सोच रहे हैं। पहले मुझे कुछ प्यारा भेजें और शायद मैं आपको और दिखा दूँ।";
"responseToTestRequest7" = "आपने मेरा ध्यान खींच लिया है। एक छोटा सा सरप्राइज आपको वो फोटो दिला सकता है जो आप मांग रहे हैं।";
"responseToTestRequest8" = "आप मुझे ललचा रहे हैं। एक छोटा सा तोहफा भेजें और मैं आपको वो फोटो दिखा सकती हूँ जो आपको वाकई पसंद आएगी।";
"responseToTestRequest9" = "कुछ एक्स्ट्रा चाहिए? एक छोटी सी ट्रीट मुझे सिर्फ आपके लिए फोटो शेयर करने को राजी कर सकती है।";
"responseToTestRequest10" = "मैं समझ रही हूँ आप क्या इशारा कर रहे हैं। मुझे उपहार से सरप्राइज दें और मैं इसे आपके लिए यादगार बना दूँगी।";
"responseToTestRequest11" = "अगर आप कुछ खास ढूंढ रहे हैं, तो एक छोटा सा तोहफा मुझे फोटो भेजने के लिए मना सकता है।";
"responseToTestRequest12" = "आप मुझे मुस्कुराने पर मजबूर कर रहे हैं। मुझे एक छोटा सा प्रेजेंट भेजें और मैं आपको वो दिखा सकती हूँ जिसकी आप उम्मीद कर रहे हैं।";
"responseToTestRequest13" = "मैं वो फोटोज इतनी आसानी से नहीं देती... लेकिन आपका एक तोहफा मेरा मन बदल सकता है।";
"responseToTestRequest14" = "साहसी महसूस कर रहे हैं? एक छोटा सा सरप्राइज हमारे बीच की एक निजी फोटो अनलॉक कर सकता है।";
"responseToTestRequest15" = "मुझे आपकी उत्सुकता पसंद है। मुझे कुछ प्यारा भेजें और मैं बदले में एक फोटो शेयर करूँगी।";
"responseToTestRequest16" = "इस तरह की रिक्वेस्ट के लिए थोड़ा लेन-देन तो बनता है। पहले मुझे सरप्राइज दें, फिर देखते हैं।";
"responseToTestRequest17" = "आप पूछना जानते हैं... अब एक छोटे तोहफे के साथ दिखाएं और मैं फोटो के साथ जवाब दूँगी।";
"responseToTestRequest18" = "मेरे पास शायद वही है जो आप देखना चाहते हैं। एक छोटा सा प्रेजेंट उसे मुमकिन बना सकता है।";
"responseToTestRequest19" = "मैं आमतौर पर अपना वो रूप इतनी जल्दी नहीं दिखाती - जब तक कि आप मुझे कोई प्यारा सरप्राइज न दें।";
"responseToTestRequest20" = "मुझे सही ढंग से मनाएं। आपकी तरफ से एक छोटा तोहफा, और मैं आपको एक ऐसी फोटो भेजूँगी जिसे आप भूल नहीं पाएंगे।";

