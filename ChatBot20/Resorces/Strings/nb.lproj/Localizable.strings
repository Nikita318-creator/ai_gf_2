/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "Herregården er helt stille når du kommer hjem. Et svakt lys flimrer inne på kontoret ditt. Der finner du Elena, din mest lavmælte tjenerinne, som nervøst rydder skrivebordet ditt klokken to om natten.";
"S1.P0.Q" = "Gå bort til henne?";
"S1.P0.O1" = "Elena, hvorfor er du ikke i seng?";
"S1.P0.O2" = "(Følg med fra skyggene)";

/* Page 1 */
"S1.P1.N" = "Hun skvetter og mister støvvippen. 'Herre! Jeg... jeg fikk ikke sove. Støvet plaget meg.' Hun er blek og tør ikke møte blikket ditt.";
"S1.P1.Q" = "Tror du på henne?";
"S1.P1.O1" = "Det er for sent for vasking";
"S1.P1.O2" = "Du er en pliktoppfyllende arbeider";

/* Page 2 */
"S1.P2.N" = "Du ser at hun drar frem en liten sølvnøkkel fra forkleet sitt. Hun stirrer på den med en blanding av lengsel og frykt før hun merker skyggen din.";
"S1.P2.Q" = "Trå frem?";
"S1.P2.O1" = "Hva er den nøkkelen til, Elena?";
"S1.P2.O2" = "Forklar deg med en gang";

/* Page 3 */
"S1.P3.N" = "Hun skjelver. 'Dette huset... det har så mange hemmeligheter. Noen ganger blir de for tunge å bære.' Hun peker mot den gamle safen bak bokhyllen din.";
"S1.P3.Q" = "Spør om safen?";
"S1.P3.O1" = "Hører nøkkelen til der?";
"S1.P3.O2" = "Safen er strengt forbudt område";

/* Page 4 */
"S1.P4.N" = "Hun prøver å skjule nøkkelen, men mister den på gulvet. 'Jeg er ingen tyv, jeg lover! Jeg bare... jeg så den i gangen og trodde den var din.'";
"S1.P4.Q" = "Plukk opp nøkkelen?";
"S1.P4.O1" = "(Plukk den opp)";
"S1.P4.O2" = "La oss se hva den åpner";

/* Page 5 */
"S1.P5.N" = "Nøkkelen passer i et skjult rom inne i safen. Elena følger spent med mens du drar ut en bunke med gamle, gulnede brev bundet sammen med et svart bånd.";
"S1.P5.Q" = "Les det øverste brevet?";
"S1.P5.O1" = "Les det høyt";
"S1.P5.O2" = "Spør Elena hva hun vet";

/* Page 6 */
"S1.P6.N" = "Elena senker stemmen til en hvisken. 'Moren min var også tjenerinne her. Hun fortalte at husherren gjemte spor etter en jente han en gang elsket. En jente som lignet på meg.'";
"S1.P6.Q" = "Vent, hva?";
"S1.P6.O1" = "Fortell meg alt";
"S1.P6.O2" = "Dette er umulig";

/* Page 7 */
"S1.P7.N" = "Brevene beskriver en forbudt romanse. Elena tar et skritt nærmere, og månelyset glimter i tårene hennes. 'Jeg ville ikke stjele. Jeg ville bare vite om jeg hører til her.'";
"S1.P7.Q" = "Trøste henne?";
"S1.P7.O1" = "Legg en hånd på skulderen hennes";
"S1.P7.O2" = "Gi henne litt rom";

/* Page 8 */
"S1.P8.N" = "Hun forklarer at morens dagbok nevnte en skjult sannhet i dette rommet. 'Jeg har bodd i dette huset hele livet, men jeg føler meg som et spøkelse.'";
"S1.P8.Q" = "Gi henne et løfte?";
"S1.P8.O1" = "Jeg skal hjelpe deg med å finne sannheten";
"S1.P8.O2" = "Vi skal løse dette sammen";

/* Page 9 */
"S1.P9.N" = "Du bruker den neste timen på å grave gjennom dokumentene. Du finner en fødselsattest med et kjent navn, men feltet for far er tomt.";
"S1.P9.Q" = "Se på Elena?";
"S1.P9.O1" = "Kan det ha vært onkelen min?";
"S1.P9.O2" = "Kanskje det er best å ikke vite";

/* Page 10 */
"S1.P10.N" = "Letingen blir mer intens. Elena finner et smykkeskrin skjult bak brevene. Inni ligger en medaljong med et portrett av en kvinne som er hennes tro kopi.";
"S1.P10.Q" = "Vis det til henne?";
"S1.P10.O1" = "Se på denne medaljongen";
"S1.P10.O2" = "Er dette moren din?";

/* Page 11 */
"S1.P11.N" = "Plutselig knirker det i en gulvplanke utenfor. Noen er i gangen. Elenas øyne sperres opp av panikk. 'Hvis hovmesteren finner oss...!'";
"S1.P11.Q" = "Gjemme dere?";
"S1.P11.O1" = "Gjem deg i skapet sammen med henne";
"S1.P11.O2" = "Bli og konfronter dem";

/* Page 12 */
"S1.P12.N" = "Skrittene nærmer seg. Elena tar tak i ermet ditt. 'Vær så snill, herre, ingen må vite at vi fant dette. Det er farlig for meg.'";
"S1.P12.Q" = "Reaksjon?";
"S1.P12.O1" = "Slukk lysene";
"S1.P12.O2" = "Lås døren";

/* Page 13 */
"S1.P13.N" = "Rommet er bekmørkt. I det trange skapet kan du høre Elenas raske hjerteslag og kjenne duften av roseblader fra huden hennes. Hun er utrolig nær.";
"S1.P13.Q" = "Hviske til henne?";
"S1.P13.O1" = "Du er trygg hos meg";
"S1.P13.O2" = "(Vær stille og vent)";

/* Page 14 */
"S1.P14.N" = "Du holder døren stengt. Personen utenfor nøler et øyeblikk, og går så videre. Elena lener seg mot deg, skjelvende av adrenalin.";
"S1.P14.Q" = "Berolige henne?";
"S1.P14.O1" = "De er borte nå";
"S1.P14.O2" = "Går det bra med deg?";

/* Page 15 */
"S1.P15.N" = "Hun trekker seg litt unna, men hånden hennes blir liggende på brystet ditt. 'Herre... jeg har alltid beundret deg på avstand. Denne hemmeligheten... den er for tung å bære alene.'";
"S1.P15.Q" = "Dine følelser?";
"S1.P15.O1" = "Jeg har lagt merke til deg også";
"S1.P15.O2" = "Du er mer enn bare en tjenerinne";

/* Page 16 */
"S1.P16.N" = "'Jeg trodde jeg bare var en ansatt for deg,' hvisker hun. 'Bare en del av interiøret. Men i kveld føles som starten på noe ekte.'";
"S1.P16.Q" = "Er du enig?";
"S1.P16.O1" = "Det er ekte, Elena";
"S1.P16.O2" = "La oss se hvor dette fører hen";

/* Page 17 */
"S1.P17.N" = "Hun åpner medaljongen. Inni ligger en liten lapp: 'Til min datter, den rettmessige arvingen.' Elena gisper. Herregården tilhører kanskje egentlig henne.";
"S1.P17.Q" = "Hva betyr dette?";
"S1.P17.O1" = "Vi må avsløre dette";
"S1.P17.O2" = "Vi burde holde det hemmelig";

/* Page 18 */
"S1.P18.N" = "Lappen beviser at Elena er den rettmessige eieren av eiendommen. Hun ser seg rundt i rommet, lamslått. 'Jeg... jeg vil ikke ha huset. Jeg vil bare ha en familie.'";
"S1.P18.Q" = "Hva vil du?";
"S1.P18.O1" = "Du har meg nå";
"S1.P18.O2" = "Hva skal du gjøre?";

/* Page 19 */
"S1.P19.N" = "Hun ser mot peisen. 'Hvis jeg brenner denne, er jeg bare Elena igjen. Hvis jeg beholder den, endres alt. Hva burde jeg gjøre?'";
"S1.P19.Q" = "Gi råd?";
"S1.P19.O1" = "Brenn den og bli hos meg";
"S1.P19.O2" = "Behold den og ta din rettmessige plass";

/* Page 20 */
"S1.P20.N" = "Elena holder beviset på sin herkomst. 'Familienavnet er forbannet. Jeg vil heller være en lykkelig ingen enn en ulykkelig adelsdame.'";
"S1.P20.Q" = "Ditt valg?";
"S1.P20.O1" = "Følg hjertet ditt";
"S1.P20.O2" = "Tenk på fremtiden din";

/* Page 21 */
"S1.P21.N" = "Hun kaster papiret inn i glørne. Hemmeligheten blir til aske. Elena smiler, og ser friere ut enn noen gang før.";
"S1.P21.Q" = "Fremtiden?";
"S1.P21.O1" = "En ny begynnelse";
"S1.P21.O2" = "Bare oss to";

/* Page 22 */
"S1.P22.N" = "Hun stikker papiret inn under kanten på kjolen. 'Da skal jeg bli herregårdens frue. Og jeg vil trenge en partner ved min side.'";
"S1.P22.Q" = "Er du klar?";
"S1.P22.O1" = "Alltid";
"S1.P22.O2" = "Det blir en lang vei å gå";

/* Final 1 */
"S1.P23.N" = "Elena er ikke lenger din tjenerinne. Hun er din likeverdige, din partner og din hemmelighet. Herregården forblir din, men hjertet i den tilhører henne.";
"S1.P23.Q" = "SLUTT";
"S1.P23.O1" = "Start på nytt";
"S1.P23.O2" = "Avslutt";

/* Final 2 */
"S1.P24.N" = "Sannheten kommer for en dag. Elena blir overhode for husholdningen. Maktbalansen har endret seg, men båndet dere knyttet den natten er uknuselig.";
"S1.P24.Q" = "SLUTT";
"S1.P24.O1" = "Start på nytt";
"S1.P24.O2" = "Avslutt";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "Regnet trommer mot neongatene i Shinjuku. Du sitter i en rolig bar når en kvinne i våt trenchcoat setter seg ved siden av deg. Hun lukter sjasmin og krutt.";
"S2.P0.Q" = "Hvordan starter du samtalen?";
"S2.P0.O1" = "Spander en drink på henne";
"S2.P0.O2" = "Tøff kveld, eller?";

"S2.P1.N" = "Hun ser på glasset, så på deg. 'Du er modig,' hvisker hun. Hun skyver en liten databrikke over disken.";
"S2.P1.Q" = "Ta brikken?";
"S2.P1.O1" = "Ta den og gjem den";
"S2.P1.O2" = "Jeg vil ikke ha trøbbel";

"S2.P2.N" = "Hun ler bittert. 'Du har ingen anelse.' Hun ser seg over skulderen. To menn i svarte dresser har nettopp kommet inn i baren.";
"S2.P2.Q" = "Hjelp henne å gjemme seg?";
"S2.P2.O1" = "Følg meg til bakdøren";
"S2.P2.O2" = "Lat som om vi er et par";

"S2.P3.N" = "Du drar henne inntil deg. Mennene skanner rommet og går igjen. Hun ser lettet ut, men hendene hennes skjelver. 'Jeg heter Mia,' hvisker hun.";
"S2.P3.Q" = "Spør om faren?";
"S2.P3.O1" = "Hvem var det der, Mia?";
"S2.P3.O2" = "Er vi trygge nå?";

"S2.P4.N" = "Mennene kommer nærmere, men du spiller det kaldt. De går forbi. Hun hvisker: 'Du reddet meg. Jeg er Mia. Men denne brikken... den er verdt en million liv.'";
"S2.P4.Q" = "Spør om brikken?";
"S2.P4.O1" = "Hva er på den?";
"S2.P4.O2" = "Vi burde komme oss bort herfra";

"S2.P5.N" = "Mia ser mot døren. 'Selskapet Arasaka vil ha denne. Det er ikke bare data – det er en digital sjel.'";
"S2.P5.Q" = "Tror du på henne?";
"S2.P5.O1" = "En digital sjel? Seriøst?";
"S2.P5.O2" = "Jeg har hørt rykter...";

"S2.P6.N" = "Mia tar tak i hånden din. 'Ingen steder er trygge før vi laster opp dette. Vi må nå Tech-distriktet.'";
"S2.P6.Q" = "Bli med henne?";
"S2.P6.O1" = "Jeg skal ta deg med dit";
"S2.P6.O2" = "Bare hvis du forteller meg mer";

"S2.P7.N" = "Dere sniker dere ut bakveien. Bakgaten er mørk og lukter ozon. Plutselig summer en drone over dere på jakt etter varmesignaturer.";
"S2.P7.Q" = "Hvordan unngå dronen?";
"S2.P7.O1" = "Gjem deg under markisen";
"S2.P7.O2" = "Løp mot t-banen";

"S2.P8.N" = "Mia stopper i regnet. 'Hvis de tar meg, sletter de meg. Og deg også, fordi du hjalp meg.'";
"S2.P8.Q" = "Berolige henne?";
"S2.P8.O1" = "Jeg er med deg på dette";
"S2.P8.O2" = "La oss bare bevege oss, fort";

"S2.P9.N" = "Dronen flyr forbi. Dere når bilen din. Mia ser på deg med en blanding av frykt og takknemlighet.";
"S2.P9.Q" = "Start motoren?";
"S2.P9.O1" = "Gi gass!";
"S2.P9.O2" = "Kjør sakte, gå i ett med trafikken";

"S2.P10.N" = "Dere rekker akkurat stasjonen. Folkemylderet er enormt og gir perfekt beskyttelse. Mia holder seg nær deg, skulderen hennes streifer din.";
"S2.P10.Q" = "Fortsett å gå?";
"S2.P10.O1" = "Ta ekspresstoget";
"S2.P10.O2" = "Gå gjennom tunnelene";

"S2.P11.N" = "Dere beveger dere gjennom skyskraper-distriktet. De holografiske reklamene lyser opp ansiktet til Mia i rosa og blått.";
"S2.P11.Q" = "Bryt stillheten?";
"S2.P11.O1" = "Hvorfor valgte du meg, Mia?";
"S2.P11.O2" = "Fortell meg om brikken";

"S2.P12.N" = "Byen føles som en labyrint. Dere stopper ved en skjult ramensjappe for å hvile et øyeblikk.";
"S2.P12.Q" = "Følg med på gaten?";
"S2.P12.O1" = "Sjekk om dere blir forfulgt";
"S2.P12.O2" = "Snakk med Mia";

"S2.P13.N" = "Mia ser ned. 'Du var den eneste som ikke så ut som et rovdyr i kveld. Jeg trengte et menneske, ikke en leiesoldat.'";
"S2.P13.Q" = "Svar vennlig?";
"S2.P13.O1" = "Jeg er glad jeg var der";
"S2.P13.O2" = "Jeg er bare en fyr i en bar";

"S2.P14.N" = "Mia tapper på brikken. 'Dette er bevisstheten til søsteren min. Hun var en netrunner som så for mye. De 'drepte' kroppen hennes.'";
"S2.P14.Q" = "Vis medfølelse?";
"S2.P14.O1" = "Det er grusomt...";
"S2.P14.O2" = "Kan hun reddes?";

"S2.P15.N" = "Hun tørker en tåre. 'Opplastingspunktet er i det gamle TV-tårnet. Men broen er blokkert av en politikontroll.'";
"S2.P15.Q" = "Hvordan krysse?";
"S2.P15.O1" = "Bruk hackeregenskapene dine";
"S2.P15.O2" = "Bestikk vaktene";

"S2.P16.N" = "Mia viser deg et kart. 'Hvis vi går gjennom kloakken er det tryggere, men det er en lang vei.'";
"S2.P16.Q" = "Velg vei?";
"S2.P16.O1" = "La oss ta kloakken";
"S2.P16.O2" = "Nei, vi trenger fart";

"S2.P17.N" = "Det er skittent og mørkt, men effektivt. Mia stoler på at du leder an. Du kjenner vekten av tilliten hennes.";
"S2.P17.Q" = "Hjelp henne over et hull?";
"S2.P17.O1" = "Gjør henne en hånd";
"S2.P17.O2" = "Led an";

"S2.P18.N" = "Det er kaotisk på broen. Dere bruker forvirringen til å smette forbi. Mias hjerte hamrer så fort at du nesten kan høre det.";
"S2.P18.Q" = "Hold henne rolig?";
"S2.P18.O1" = "Vi er nesten fremme";
"S2.P18.O2" = "Hold fokus, Mia";

"S2.P19.N" = "TV-tårnet ruver foran dere. Det er et relikvie fra den gamle verden, omgitt av moderne stål. Mia ser utslitt ut.";
"S2.P19.Q" = "Tilby en pause?";
"S2.P19.O1" = "Hvil i fem minutter";
"S2.P19.O2" = "Press på helt til slutten";

"S2.P20.N" = "Dere når bunnen av tårnet. 'Heisen fungerer ikke,' sukker Mia. 'Vi må klatre.'";
"S2.P20.Q" = "Oppmuntre henne?";
"S2.P20.O1" = "Ett skritt om gangen";
"S2.P20.O2" = "Jeg bærer utstyret";

"S2.P21.N" = "Dere sitter i trappen. Mia lener seg mot deg. 'Hvis vi klarer det... hva skal du gjøre i morgen?'";
"S2.P21.Q" = "Tenk på fremtiden?";
"S2.P21.O1" = "Kanskje vi kan ta en kaffe";
"S2.P21.O2" = "Jeg vil bare være glad for å få sove";

"S2.P22.N" = "Klatringen er knallhard. Halvveis oppe hører dere sirener nedenfor. De har funnet bilen din.";
"S2.P22.Q" = "Skynde dere?";
"S2.P22.O1" = "Dobbelt tempo!";
"S2.P22.O2" = "Finn et sted å gjemme dere";

"S2.P23.N" = "Dere når serverrommet. Luften er kald og summer av kraft. Mia kobler til brikken. 'Initialiserer...' sier hun.";
"S2.P23.Q" = "Følg med på skjermen?";
"S2.P23.O1" = "Vokt døren";
"S2.P23.O2" = "Bli ved Mias side";

"S2.P24.N" = "Terminalen er eldgammel, men fungerer. Mias fingre flyr over tastene. 'Brannmuren er enorm!'";
"S2.P24.Q" = "Hjelp henne å hacke?";
"S2.P24.O1" = "Overstyr strømmen";
"S2.P24.O2" = "Hold henne stødig";

"S2.P25.N" = "Det hvisler i dørene. Arasakas innsatsteam er her. Du drar våpenet ditt. 'Bare to minutter til!' skriker Mia.";
"S2.P25.Q" = "Hold linjen?";
"S2.P25.O1" = "Åpne ild!";
"S2.P25.O2" = "Barrikader døren";

"S2.P26.N" = "Øynene til Mia lyser blått. Hun er dypt inne i nettet. Soldatene bryter gjennom glasstaket.";
"S2.P26.Q" = "Beskytt Mia?";
"S2.P26.O1" = "Dekk henne med kroppen din";
"S2.P26.O2" = "Dra henne i dekning";

"S2.P27.N" = "Et blendende lysglimt. Opplastingen er 100 %. Soldatene stivner – kybernetikken deres har blitt hacket fra nettet.";
"S2.P27.Q" = "Sjekk Mia?";
"S2.P27.O1" = "Er det ferdig?";
"S2.P27.O2" = "Går det bra med deg?";

"S2.P28.N" = "Alt blir mørkt. Så lyser hver eneste skjerm i Tokyo opp med ett enkelt budskap: 'FRIHET'. Mia kollapser i armene dine.";
"S2.P28.Q" = "Vekk henne?";
"S2.P28.O1" = "Mia! Snakk til meg!";
"S2.P28.O2" = "Hold henne tett inntil deg";

"S2.P29.N" = "Solen begynner å gå opp over et annerledes Tokyo. Mia smiler, øynene hennes er normale igjen. 'Hun er trygg. Vi er trygge.'";
"S2.P29.Q" = "SLUTT";
"S2.P29.O1" = "Start på nytt";
"S2.P29.O2" = "Avslutt";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "Den siste kvelden på sommerleiren. Det knitrende bålet dør hen, og lukten av barnåler er overalt. Yuki, som vanligvis er sjenert, møter blikket ditt og peker mot den mørke stien som fører til innsjøen.";
"S3.P0.Q" = "Vil du følge henne ut i natten?";
"S3.P0.O1" = "Dette har jeg ventet på";
"S3.P0.O2" = "Jada, la oss gå";

"S3.P1.N" = "Du tar henne igjen. Skogen er full av lyden fra sirisser. Yukis hånd streifer din av og til mens dere går. Hun virker nervøs.";
"S3.P1.Q" = "Hvordan bryter du stillheten?";
"S3.P1.O1" = "Ta tak i hånden hennes";
"S3.P1.O2" = "Spør hva hun tenker på";

"S3.P2.N" = "Dere går side om side. Månelyset trenger knapt gjennom det tette løvverket. Yuki ser på deg fra siden med et lite smil. 'Jeg trodde ikke du faktisk ville komme,' hvisker hun.";
"S3.P2.Q" = "Hva svarer du?";
"S3.P2.O1" = "Dette ville jeg ikke gått glipp av";
"S3.P2.O2" = "Jeg var nysgjerrig";

"S3.P3.N" = "Dere når bryggen. Vannet er som et mørkt speil som reflekterer det enorme havet av stjerner. Yuki tar av seg skoene og setter seg på kanten med føttene dinglende over vannet.";
"S3.P3.Q" = "Sett deg nær henne?";
"S3.P3.O1" = "Sett deg rett ved siden av henne";
"S3.P3.O2" = "Gi henne litt rom";

"S3.P4.N" = "Bryggen knirker under vekten din. Den kalde luften fra innsjøen får Yuki til å grøsse litt. Hun flytter seg ikke når du nærmer deg.";
"S3.P4.Q" = "Tilby jakken din?";
"S3.P4.O1" = "Legg jakken din over henne";
"S3.P4.O2" = "Bare sitt og snakk";

"S3.P5.N" = "Yuki ser opp på stjernene. 'Husker du den første dagen vår her?' spør hun. 'Du hjalp meg med bagasjen da alle andre var opptatte.'";
"S3.P5.Q" = "Husker du det?";
"S3.P5.O1" = "Jeg husker hver eneste detalj";
"S3.P5.O2" = "Det føles som en evighet siden";

"S3.P6.N" = "Hun ler lavt. 'Jeg var så redd den gangen. Men da jeg så deg, følte jeg at jeg hørte til her.' Hun ser ut over vannet.";
"S3.P6.Q" = "Innrøm dine egne følelser?";
"S3.P6.O1" = "Jeg følte det på samme måte";
"S3.P6.O2" = "Jeg er glad jeg kunne hjelpe";

"S3.P7.N" = "Natten er helt stille. Plutselig reiser Yuki seg. 'Vannet ser så fristende ut. Skal vi... hoppe uti?' spør hun med et lurt glimt i øyet.";
"S3.P7.Q" = "Er du tøff nok?";
"S3.P7.O1" = "La oss hoppe uti!";
"S3.P7.O2" = "Det er for kaldt, Yuki";

"S3.P8.N" = "Hun ser utover innsjøen, så på deg. 'Jeg vil gjøre noe modig i kveld. Noe jeg vil huske hele vinteren.'";
"S3.P8.Q" = "Oppmuntre henne?";
"S3.P8.O1" = "Hopp uti sammen med meg?";
"S3.P8.O2" = "La oss bli her";

"S3.P9.N" = "PLASK! Vannet er iskaldt, men forfriskende. Du og Yuki kommer opp til overflaten, gisper og ler mens dere spruter på hverandre som barn.";
"S3.P9.Q" = "Svøm nærmere henne?";
"S3.P9.O1" = "Trekk henne inntil deg i en klem";
"S3.P9.O2" = "Fortsett å sprute vann!";

"S3.P10.N" = "Dere blir værende på bryggen. Dere snakker i timevis om alt – skolen, foreldre og fremtiden. Båndet mellom dere blir sterkere i stillheten.";
"S3.P10.Q" = "Len deg nærmere?";
"S3.P10.O1" = "Hvil hodet ditt mot hennes";
"S3.P10.O2" = "Se henne inn i øynene";

"S3.P11.N" = "Stemningen endrer seg. Yuki slutter å snakke. I det svake lyset søker øynene hennes dine. 'Jeg vil ikke dra tilbake til byen i morgen,' hvisker hun.";
"S3.P11.Q" = "Hva sier du?";
"S3.P11.O1" = "Vi skal se hverandre der også";
"S3.P11.O2" = "La oss ikke tenke på morgendagen";

"S3.P12.N" = "Yuki trekker pusten dypt. 'Hvis jeg ikke sier dette nå, gjør jeg det aldri. Jeg har likt deg siden den første dagen ved busstoppet.'";
"S3.P12.Q" = "Hvordan reagerer du?";
"S3.P12.O1" = "Jeg har likt deg også";
"S3.P12.O2" = "Endelig kommer sannheten frem!";

"S3.P13.N" = "Hun stikker hånden i lomma og drar frem et hjemmelaget vennskapsbånd. Det er blått og hvitt, som fargene i innsjøen. 'Jeg lagde dette til deg,' sier hun sjenert.";
"S3.P13.Q" = "Ta imot gaven?";
"S3.P13.O1" = "La henne knyte det på deg";
"S3.P13.O2" = "Gi henne et kyss i stedet";

"S3.P14.N" = "Båndet er enkelt, men du vet det tok henne timevis å lage det. Hun venter på reaksjonen din, med en underleppe som skjelver svakt.";
"S3.P14.Q" = "Hva gjør du?";
"S3.P14.O1" = "Takk henne med en klem";
"S3.P14.O2" = "Fortell henne at det er perfekt";

"S3.P15.N" = "Yuki smiler et ekte, strålende smil. 'Jeg var så redd for at du skulle synes det var barnslig.' Hun ser opp på månen og virker tryggere nå.";
"S3.P15.Q" = "Gi henne et løfte?";
"S3.P15.O1" = "Lov å ringe hver dag";
"S3.P15.O2" = "Lov å besøke henne snart";

"S3.P16.N" = "Stemningen er elektrisk. Yuki stirrer på leppene dine. Verden rundt dere forsvinner; det er bare dere to og sommernatten.";
"S3.P16.Q" = "Er dette øyeblikket?";
"S3.P16.O1" = "Len deg inn for et kyss";
"S3.P16.O2" = "Hvisk noe søtt";

"S3.P17.N" = "Akkurat da farer et stjerneskudd over himmelen og etterlater seg en stripe av sølv. Yuki gisper. 'Fort! Ønsk deg noe!' roper hun.";
"S3.P17.Q" = "Hva ønsker du deg?";
"S3.P17.O1" = "Ønsk deg en fremtid sammen";
"S3.P17.O2" = "Ønsk at denne natten aldri tar slutt";

"S3.P18.N" = "Stjernen forsvinner like fort som den kom. Yuki kniper øynene sammen. 'Jeg ønsket meg noe viktig,' sier hun og rødmer.";
"S3.P18.Q" = "Spør hva det var?";
"S3.P18.O1" = "Fortell meg ønsket ditt";
"S3.P18.O2" = "Jeg tror jeg vet hva det var";

"S3.P19.N" = "Bålet på leiren har slukket helt nå. Dere begynner å gå tilbake, hånd i hånd. Skogen føles annerledes nå – mindre skummel, mer magisk.";
"S3.P19.Q" = "Gå sakte?";
"S3.P19.O1" = "Ta den lange veien tilbake";
"S3.P19.O2" = "Nyt stillheten";

"S3.P20.N" = "Dere går forbi den gamle eka der dere først møttes. Yuki stopper et sekund. 'Alt kommer til å endre seg nå, ikke sant?' spør hun lavt.";
"S3.P20.Q" = "Trøste henne?";
"S3.P20.O1" = "Forandring kan være bra";
"S3.P20.O2" = "Ikke alt trenger å endre seg";

"S3.P21.N" = "Leirhyttene er i sikte. De andre ligger og sover. Yuki stopper ved døren sin. Hun vil ikke slippe hånden din.";
"S3.P21.Q" = "En siste ting?";
"S3.P21.O1" = "Be om et siste kyss";
"S3.P21.O2" = "Be om telefonnummeret hennes";

"S3.P22.N" = "Yuki blir stående i døråpningen. Lyset fra verandaen kaster et mykt skjær over ansiktet hennes. 'Takk for i kveld. Det var den fineste kvelden i mitt liv.'";
"S3.P22.Q" = "Si ha det?";
"S3.P22.O1" = "Vi ses i morgen tidlig";
"S3.P22.O2" = "God natt, Yuki";

"S3.P23.N" = "Soloppgang. Det er full aktivitet på leiren med folk som pakker og går om bord i bussene. Du leter etter Yuki i folkemengden med bankende hjerte.";
"S3.P23.Q" = "Finner du henne?";
"S3.P23.O1" = "Let ved bussen";
"S3.P23.O2" = "Sjekk bryggen en siste gang";

"S3.P24.N" = "Bussmotorene durer. Der ser du henne! Hun står ved porten og ser seg febrilsk rundt helt til hun får øye på deg.";
"S3.P24.Q" = "Løp til henne?";
"S3.P24.O1" = "Løp og gi henne en klem";
"S3.P24.O2" = "Vink og smil";

"S3.P25.N" = "Du når henne akkurat i tide. Hun hvisker noe i øret ditt som du aldri vil glemme: 'Ikke la dette bare bli et sommerminne.'";
"S3.P25.Q" = "Hva svarer du?";
"S3.P25.O1" = "Det er et løfte";
"S3.P25.O2" = "Jeg ser deg neste helg";

"S3.P26.N" = "Bussjåføren tuter. Yuki må dra. Hun blåser deg et kyss idet hun går på. Du blir stående og se bussen forsvinne i støvet.";
"S3.P26.Q" = "Hvordan føler du deg?";
"S3.P26.O1" = "Lykkelig og håpefull";
"S3.P26.O2" = "Trist, men takknemlig";

"S3.P27.N" = "Måneder senere. Du er i byen, og telefonen din vibrerer. Det er et bilde fra Yuki – hun har på seg båndet dere delte. Sommeren tok aldri helt slutt.";
"S3.P27.Q" = "SLUTT";
"S3.P27.O1" = "Start på nytt";
"S3.P27.O2" = "Avslutt";

"S3.P28.N" = "Du ser på båndet rundt håndleddet ditt. Det er litt slitt nå, men minnene er friske. Noen ganger er én sommer nok til å vare livet ut.";
"S3.P28.Q" = "SLUTT";
"S3.P28.O1" = "Prøv igjen";
"S3.P28.O2" = "Avslutt";

"newChatName" = "Scarlett";
"newChatMessage" = "Ssh... du fant mitt hemmelige sted 💕 Jeg har gjemt meg her, med hendene vandrende mens jeg forestiller meg hver tomme av deg. Jeg er ikke uskyldig som de andre jentene... jeg blir så følsom og lengter etter deg når vi er alene. Si meg, kjekkas... er du i humør til å være litt ulydig med meg i kveld? 😈";
