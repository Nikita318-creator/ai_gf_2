/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "Het landhuis is doodstil als je terugkeert. In je werkkamer flikkert een zwak lichtje. Je treft Elena aan, je stilste dienstmeisje, die om 2 uur 's nachts zenuwachtig je bureau aan het opruimen is.";
"S1.P0.Q" = "Haar benaderen?";
"S1.P0.O1" = "Elena, waarom lig je nog niet in bed?";
"S1.P0.O2" = "(Vanuit de schaduw toekijken)";

/* Page 1 */
"S1.P1.N" = "Ze schrikt en laat een plumeau vallen. 'Meneer! Ik... ik kon niet slapen. Het stof zat me dwars.' Ze ziet er bleek uit en ontwijkt je blik.";
"S1.P1.Q" = "Geloof je haar?";
"S1.P1.O1" = "Het is veel te laat om schoon te maken";
"S1.P1.O2" = "Je bent wel erg toegewijd aan je werk";

/* Page 2 */
"S1.P2.N" = "Je ziet hoe ze een kleine zilveren sleutel uit haar schort haalt. Ze staart ernaar met een mix van verlangen en angst voordat ze je schaduw opmerkt.";
"S1.P2.Q" = "Stap je naar voren?";
"S1.P2.O1" = "Wat is dat voor sleutel, Elena?";
"S1.P2.O2" = "Verklaar jezelf onmiddellijk";

/* Page 3 */
"S1.P3.N" = "Ze trilt. 'Dit huis... het heeft zoveel geheimen, meneer. Soms wegen ze zwaar op me.' Ze wijst naar de oude kluis achter je boekenkast.";
"S1.P3.Q" = "Vragen naar de kluis?";
"S1.P3.O1" = "Hoort die sleutel daarop?";
"S1.P3.O2" = "De kluis is verboden terrein";

/* Page 4 */
"S1.P4.N" = "Ze probeert de sleutel te verbergen, maar hij valt. 'Ik ben geen dief, dat beloof ik! Ik... ik zag hem in de gang liggen en dacht dat hij van u was.'";
"S1.P4.Q" = "De sleutel oprapen?";
"S1.P4.O1" = "(Raap hem op)";
"S1.P4.O2" = "Laten we kijken wat hij opent";

/* Page 5 */
"S1.P5.N" = "De sleutel past op een verborgen compartiment in de kluis. Elena kijkt met ingehouden adem toe terwijl je een stapel oude, vergeelde brieven tevoorschijn haalt, bijeengebonden met een zwart lint.";
"S1.P5.Q" = "De bovenste brief lezen?";
"S1.P5.O1" = "Lees hem hardop voor";
"S1.P5.O2" = "Vraag Elena wat zij weet";

/* Page 6 */
"S1.P6.N" = "Elena's stem zakt tot een gefluister. 'Mijn moeder was hier ook dienstmeisje. Ze vertelde me dat de Meester brieven bewaarde over een meisje van wie hij ooit hield. Een meisje dat precies op mij leek.'";
"S1.P6.Q" = "Wacht, wat?";
"S1.P6.O1" = "Vertel me alles";
"S1.P6.O2" = "Dit is onmogelijk";

/* Page 7 */
"S1.P7.N" = "De brieven beschrijven een verboden romance. Elena komt dichterbij; het maanlicht weerkaatst in haar tranen. 'Ik wilde niet stelen. Ik wilde alleen weten of ik hier thuishoor.'";
"S1.P7.Q" = "Haar troosten?";
"S1.P7.O1" = "Leg een hand op haar schouder";
"S1.P7.O2" = "Geef haar wat ruimte";

/* Page 8 */
"S1.P8.N" = "Ze legt uit dat haar moeders dagboek een verborgen waarheid in deze kamer noemde. 'Ik woon hier al mijn hele leven, meneer, maar ik voel me een geest.'";
"S1.P8.Q" = "Een belofte doen?";
"S1.P8.O1" = "Ik help je de waarheid te vinden";
"S1.P8.O2" = "We lossen dit samen op";

/* Page 9 */
"S1.P9.N" = "Het volgende uur spitten jullie de documenten door. Je vindt een geboorteakte met een bekende naam, maar het vakje voor de vader is leeg.";
"S1.P9.Q" = "Elena aankijken?";
"S1.P9.O1" = "Zou het mijn oom kunnen zijn?";
"S1.P9.O2" = "Misschien is het beter om het niet te weten";

/* Page 10 */
"S1.P10.N" = "De zoektocht wordt intenser. Elena vindt een juwelendoosje achter de brieven. Binnenin zit een medaillon met een portret van een vrouw die haar tweelingzus zou kunnen zijn.";
"S1.P10.Q" = "Aan haar laten zien?";
"S1.P10.O1" = "Kijk eens naar dit medaillon";
"S1.P10.O2" = "Is dit jouw moeder?";

/* Page 11 */
"S1.P11.N" = "Plotseling kraakt er een vloerplank op de gang. Er is iemand buiten. Elena's ogen worden groot van paniek. 'Als de butler ons vindt...!'";
"S1.P11.Q" = "Verstoppen?";
"S1.P11.O1" = "Verstop je met haar in de kast";
"S1.P11.O2" = "Blijf staan en confronteer ze";

/* Page 12 */
"S1.P12.N" = "Voetstappen komen dichterbij. Elena grijpt je mouw vast. 'Alstublieft meneer, niemand mag weten dat we dit gevonden hebben. Het is gevaarlijk voor mij.'";
"S1.P12.Q" = "Je reactie?";
"S1.P12.O1" = "Doe de lichten uit";
"S1.P12.O2" = "Doe de deur op slot";

/* Page 13 */
"S1.P13.N" = "De kamer is pikdonker. In de krappe ruimte hoor je Elena's snelle hartslag en ruik je de geur van rozenblaadjes op haar huid. Ze is ontzettend dichtbij.";
"S1.P13.Q" = "Iets naar haar fluisteren?";
"S1.P13.O1" = "Je bent veilig bij mij";
"S1.P13.O2" = "(Blijf stil en wacht af)";

/* Page 14 */
"S1.P14.N" = "Je houdt de deur dicht. De persoon buiten aarzelt even en loopt dan weg. Elena leunt tegen je aan, trillend van de adrenaline.";
"S1.P14.Q" = "Haar geruststellen?";
"S1.P14.O1" = "Ze zijn weg";
"S1.P14.O2" = "Gaat het met je?";

/* Page 15 */
"S1.P15.N" = "Ze trekt zich iets terug, maar haar hand rust nog op je borst. 'Meneer... ik heb u altijd van een afstandje bewonderd. Dit geheim... het is te zwaar om alleen te dragen.'";
"S1.P15.Q" = "Jouw gevoelens?";
"S1.P15.O1" = "Jij bent mij ook opgevallen";
"S1.P15.O2" = "Je bent voor mij meer dan een bediende";

/* Page 16 */
"S1.P16.N" = "'Ik dacht dat ik voor u maar een hulpje was,' fluistert ze. 'Gewoon onderdeel van het interieur. Maar vanavond voelt als het begin van iets echts.'";
"S1.P16.Q" = "Ben je het ermee eens?";
"S1.P16.O1" = "Dit is echt, Elena";
"S1.P16.O2" = "Laten we zien waar dit heen gaat";

/* Page 17 */
"S1.P17.N" = "Ze opent het medaillon. Binnenin zit een briefje: 'Voor mijn dochter, de rechtmatige erfgename.' Elena snakt naar adem. Het landhuis is misschien wel van haar.";
"S1.P17.Q" = "De gevolgen?";
"S1.P17.O1" = "We moeten dit onthullen";
"S1.P17.O2" = "We moeten dit geheim houden";

/* Page 18 */
"S1.P18.N" = "De notitie bewijst dat Elena de rechtmatige eigenaar van het landgoed is. Ze kijkt verbijsterd de kamer rond. 'Ik... ik wil het huis niet. Ik wil gewoon een familie.'";
"S1.P18.Q" = "Wat wil jij?";
"S1.P18.O1" = "Je hebt mij nu";
"S1.P18.O2" = "Wat ga je nu doen?";

/* Page 19 */
"S1.P19.N" = "Ze kijkt naar de haard. 'Als ik dit verbrand, ben ik gewoon weer Elena. Als ik het houd, verandert alles. Meneer, wat moet ik doen?'";
"S1.P19.Q" = "Advies geven?";
"S1.P19.O1" = "Verbrand het en blijf bij mij";
"S1.P19.O2" = "Houd het en claim je plek";

/* Page 20 */
"S1.P20.N" = "Elena houdt het bewijs van haar afkomst vast. 'De familienaam is vervloekt, meneer. Ik ben liever een gelukkig niemand dan een ongelukkige dame.'";
"S1.P20.Q" = "Jouw keuze?";
"S1.P20.O1" = "Volg je hart";
"S1.P20.O2" = "Denk aan je toekomst";

/* Page 21 */
"S1.P21.N" = "Ze gooit het papier in de smeulende as. Het geheim verandert in as. Elena glimlacht en ziet er vrijer uit dan ooit tevoren.";
"S1.P21.Q" = "De toekomst?";
"S1.P21.O1" = "Een nieuw begin";
"S1.P21.O2" = "Alleen wij tweeën";

/* Page 22 */
"S1.P22.N" = "Ze stopt het papier in haar korset. 'Dan word ik de Vrouwe van dit huis. En ik heb een partner aan mijn zijde nodig.'";
"S1.P22.Q" = "Ben je er klaar voor?";
"S1.P22.O1" = "Altijd";
"S1.P22.O2" = "Het zal een lange weg worden";

/* Final 1 */
"S1.P23.N" = "Elena is niet langer je bediende. Ze is je gelijke, je partner en je geheim. Het landhuis blijft van jou, maar het hart ervan is van haar.";
"S1.P23.Q" = "HET EINDE";
"S1.P23.O1" = "Verhaal opnieuw starten";
"S1.P23.O2" = "Afronden";

/* Final 2 */
"S1.P24.N" = "De waarheid komt uit. Elena wordt het hoofd van het huishouden. De machtsverhoudingen zijn verschoven, maar de band die jullie die nacht smeedden is onbreekbaar.";
"S1.P24.Q" = "HET EINDE";
"S1.P24.O1" = "Verhaal opnieuw starten";
"S1.P24.O2" = "Afronden";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "De regen klettert op de neonstraten van Shinjuku. Je zit in een rustige bar wanneer een vrouw in een natte regenjas naast je komt zitten. Ze ruikt naar jasmijn en buskruit.";
"S2.P0.Q" = "Hoe begin je een gesprek?";
"S2.P0.O1" = "Koop een drankje voor haar";
"S2.P0.O2" = "Zware avond, hè?";

"S2.P1.N" = "Ze kijkt naar haar glas, en dan naar jou. 'Je bent dapper,' fluistert ze. Ze schuift een kleine datachip over de toonbank.";
"S2.P1.Q" = "De chip aannemen?";
"S2.P1.O1" = "Neem hem aan en verberg hem";
"S2.P1.O2" = "Ik wil geen problemen";

"S2.P2.N" = "Ze lacht bitter. 'Je hebt geen idee.' Ze kijkt over haar schouder. Twee mannen in zwarte pakken stappen net de bar binnen.";
"S2.P2.Q" = "Haar helpen verstoppen?";
"S2.P2.O1" = "Volg me naar de achterdeur";
"S2.P2.O2" = "Doe alsof we een stelletje zijn";

"S2.P3.N" = "Je trekt haar dicht tegen je aan. De mannen scannen de ruimte en vertrekken. Ze ziet er opgelucht uit, maar haar handen trillen. 'Ik ben Mia,' fluistert ze.";
"S2.P3.Q" = "Vragen naar het gevaar?";
"S2.P3.O1" = "Wie waren dat, Mia?";
"S2.P3.O2" = "Zijn we nu veilig?";

"S2.P4.N" = "De mannen komen dichterbij, maar je blijft koelbloedig. Ze lopen voorbij. Ze fluistert: 'Je hebt me gered. Ik ben Mia. Maar deze chip... hij is een miljoen levens waard.'";
"S2.P4.Q" = "Vragen naar de chip?";
"S2.P4.O1" = "Wat staat erop?";
"S2.P4.O2" = "We moeten hier weg";

"S2.P5.N" = "Mia kijkt naar de deur. 'Het bedrijf Arasaka wil dit hebben. Het is niet zomaar data, het is een digitale ziel.'";
"S2.P5.Q" = "Geloof je haar?";
"S2.P5.O1" = "Een digitale ziel? Echt?";
"S2.P5.O2" = "Ik heb wel eens geruchten gehoord...";

"S2.P6.N" = "Mia grijpt je hand vast. 'Nergens is het veilig totdat we dit uploaden. We moeten het Tech-District bereiken.'";
"S2.P6.Q" = "Ga je met haar mee?";
"S2.P6.O1" = "Ik breng je erheen";
"S2.P6.O2" = "Alleen als je me meer vertelt";

"S2.P7.N" = "Jullie glippen via de achteruitgang naar buiten. Het steegje is donker en ruikt naar ozon. Plotseling zoemt er een drone boven je hoofd, op zoek naar warmtesignalen.";
"S2.P7.Q" = "Hoe ontwijk je de drone?";
"S2.P7.O1" = "Schuil onder de overkapping";
"S2.P7.O2" = "Ren naar de metro";

"S2.P8.N" = "Mia stopt in de regen. 'Als ze me pakken, wissen ze me. En jou ook, omdat je me helpt.'";
"S2.P8.Q" = "Haar geruststellen?";
"S2.P8.O1" = "Ik sta aan jouw kant";
"S2.P8.O2" = "Laten we gaan, snel";

"S2.P9.N" = "De drone vliegt voorbij. Je bereikt je auto. Mia kijkt je aan met een mix van angst en dankbaarheid.";
"S2.P9.Q" = "Start je de motor?";
"S2.P9.O1" = "Geef vol gas!";
"S2.P9.O2" = "Rijd rustig, val niet op";

"S2.P10.N" = "Jullie halen het ternauwernood naar het station. De menigte is enorm, de perfecte dekking. Mia blijft dichtbij, haar schouder raakt de jouwe.";
"S2.P10.Q" = "Blijven bewegen?";
"S2.P10.O1" = "Neem de sneltrein";
"S2.P10.O2" = "Loop door de tunnels";

"S2.P11.N" = "Jullie rijden door de wolkenkrabber-wijk. De holografische advertenties verlichten Mia's gezicht in roze en blauw.";
"S2.P11.Q" = "De stilte verbreken?";
"S2.P11.O1" = "Waarom ik, Mia?";
"S2.P11.O2" = "Vertel me over de chip";

"S2.P12.N" = "De stad voelt als een doolhof. Jullie stoppen bij een verborgen ramen-tentje om even uit te rusten.";
"S2.P12.Q" = "De straat in de gaten houden?";
"S2.P12.O1" = "Check of we gevolgd worden";
"S2.P12.O2" = "Praat met Mia";

"S2.P13.N" = "Mia kijkt naar beneden. 'Jij was de enige die er vanavond niet uitzag als een roofdier. Ik had een mens nodig, geen huurmoordenaar.'";
"S2.P13.Q" = "Vriendelijk reageren?";
"S2.P13.O1" = "Ik ben blij dat ik er was";
"S2.P13.O2" = "Ik ben ook maar een man in een bar";

"S2.P14.N" = "Mia tikt op de chip. 'Dit is het bewustzijn van mijn zus. Ze was een netrunner die te veel zag. Ze hebben haar lichaam 'gedood'.'";
"S2.P14.Q" = "Medeleven tonen?";
"S2.P14.O1" = "Dat is verschrikkelijk...";
"S2.P14.O2" = "Kan ze gered worden?";

"S2.P15.N" = "Ze veegt een traan weg. 'Het uploadpunt is in de oude tv-toren. Maar de brug is geblokkeerd door een politiecontrole.'";
"S2.P15.Q" = "Hoe kom je erlangs?";
"S2.P15.O1" = "Gebruik je hackerskills";
"S2.P15.O2" = "Omkoop de bewakers";

"S2.P16.N" = "Mia laat je een kaart zien. 'Als we via het riool gaan is het veiliger, maar het is een heel eind.'";
"S2.P16.Q" = "Kies het pad:";
"S2.P16.O1" = "Laten we het riool nemen";
"S2.P16.O2" = "Nee, we moeten opschieten";

"S2.P17.N" = "Het is er vies en donker, maar effectief. Mia vertrouwt op jouw leiding. Je voelt de last van haar vertrouwen.";
"S2.P17.Q" = "Haar over een geul helpen?";
"S2.P17.O1" = "Geef haar een hand";
"S2.P17.O2" = "Loop voorop";

"S2.P18.N" = "Het is een chaos op de brug. Je gebruikt de verwarring om erlangs te glippen. Mia's hart gaat zo tekeer dat je het bijna kunt horen.";
"S2.P18.Q" = "Haar kalm houden?";
"S2.P18.O1" = "We zijn er bijna";
"S2.P18.O2" = "Blijf gefocust, Mia";

"S2.P19.N" = "De tv-toren doemt voor jullie op. Het is een relikwie van de oude wereld, omringd door modern staal. Mia ziet er uitgeput uit.";
"S2.P19.Q" = "Een pauze aanbieden?";
"S2.P19.O1" = "Rust 5 minuutjes uit";
"S2.P19.O2" = "Zet door tot het einde";

"S2.P20.N" = "Jullie bereiken de voet van de toren. 'De lift doet het niet,' zucht Mia. 'We moeten klimmen.'";
"S2.P20.Q" = "Haar aanmoedigen?";
"S2.P20.O1" = "Stap voor stap";
"S2.P20.O2" = "Ik draag de spullen wel";

"S2.P21.N" = "Je gaat op de trap zitten. Mia leunt tegen je aan. 'Als we dit redden... wat ga je dan morgen doen?'";
"S2.P21.Q" = "Denk je aan de toekomst?";
"S2.P21.O1" = "Misschien kunnen we koffie gaan drinken";
"S2.P21.O2" = "Ik ben al blij als ik kan slapen";

"S2.P22.N" = "De klim is loodzwaar. Halverwege hoor je beneden sirenes. Ze hebben je auto gevonden.";
"S2.P22.Q" = "Opschieten?";
"S2.P22.O1" = "Tempo verdubbelen!";
"S2.P22.O2" = "Zoek een schuilplaats";

"S2.P23.N" = "Jullie bereiken de serverruimte. De lucht is koud en gonst van de kracht. Mia sluit de chip aan. 'Initialiseren...' zegt ze.";
"S2.P23.Q" = "Kijk je naar het scherm?";
"S2.P23.O1" = "Bewaak de deur";
"S2.P23.O2" = "Blijf aan Mia's zijde";

"S2.P24.N" = "De terminal is stokoud maar werkt nog. Mia's vingers vliegen over de toetsen. 'De firewall is gigantisch!'";
"S2.P24.Q" = "Haar helpen hacken?";
"S2.P24.O1" = "Omzeil de stroomtoevoer";
"S2.P24.O2" = "Houd haar rustig";

"S2.P25.N" = "De deuren sissen. Het tactische team van Arasaka is hier. Je trekt je wapen. 'Nog twee minuten!' schreeuwt Mia.";
"S2.P25.Q" = "De linie houden?";
"S2.P25.O1" = "Open het vuur!";
"S2.P25.O2" = "Barricadeer de deur";

"S2.P26.N" = "Mia's ogen gloeien blauw op. Ze zit diep in het net. De soldaten breken door het glazen plafond.";
"S2.P26.Q" = "Mia beschermen?";
"S2.P26.O1" = "Bescherm haar met je lichaam";
"S2.P26.O2" = "Trek haar naar een veilige plek";

"S2.P27.N" = "Een verblindende lichtflits. De upload is 100%. De soldaten bevriezen—hun cybernetica is platgelegd vanuit het net.";
"S2.P27.Q" = "Mia checken?";
"S2.P27.O1" = "Is het gelukt?";
"S2.P27.O2" = "Gaat het met je?";

"S2.P28.N" = "Alles wordt donker. Dan lichten alle schermen in Tokyo op met één boodschap: 'VRIJHEID'. Mia zakt in je armen.";
"S2.P28.Q" = "Haar wakker maken?";
"S2.P28.O1" = "Mia! Zeg iets!";
"S2.P28.O2" = "Houd haar stevig vast";

"S2.P29.N" = "De zon komt op boven een ander Tokyo. Mia glimlacht, haar ogen zijn weer normaal. 'Ze is veilig. Wij zijn veilig.'";
"S2.P29.Q" = "HET EINDE";
"S2.P29.O1" = "Verhaal opnieuw starten";
"S2.P29.O2" = "Afronden";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "De laatste nacht van het zomerkamp. Het knisperende kampvuur dooft langzaam en de geur van dennennaalden hangt in de lucht. Yuki, normaal zo verlegen, zoekt je blik en wijst naar het donkere pad dat naar het meer leidt.";
"S3.P0.Q" = "Volg je haar de nacht in?";
"S3.P0.O1" = "Hier heb ik op gewacht";
"S3.P0.O2" = "Tuurlijk, laten we gaan";

"S3.P1.N" = "Je haalt haar in. Het bos leeft door het geluid van krekels. Yuki's hand raakt de jouwe af en toe aan tijdens het lopen. Ze lijkt zenuwachtig.";
"S3.P1.Q" = "Hoe verbreek je de stilte?";
"S3.P1.O1" = "Pak haar hand stevig vast";
"S3.P1.O2" = "Vraag wat er in haar omgaat";

"S3.P2.N" = "Jullie lopen zij aan zij. Het maanlicht dringt nauwelijks door het dichte bladerdak. Yuki kijkt je van opzij aan met een kleine glimlach. 'Ik dacht niet dat je echt zou komen,' fluistert ze.";
"S3.P2.Q" = "Wat is je antwoord?";
"S3.P2.O1" = "Dit wilde ik niet missen";
"S3.P2.O2" = "Ik was nieuwsgierig";

"S3.P3.N" = "Jullie bereiken de steiger. Het water is als een donkere spiegel waarin de sterrenhemel reflecteert. Yuki trekt haar schoenen uit en gaat op de rand zitten met haar voeten in het water.";
"S3.P3.Q" = "Dicht bij haar gaan zitten?";
"S3.P3.O1" = "Ga vlak naast haar zitten";
"S3.P3.O2" = "Geef haar wat ruimte";

"S3.P4.N" = "De steiger kraakt onder je gewicht. Door de koude lucht van het meer rilt Yuki een beetje. Ze gaat niet opzij als je dichterbij komt.";
"S3.P4.Q" = "Je jas aanbieden?";
"S3.P4.O1" = "Sla je jas om haar heen";
"S3.P4.O2" = "Gewoon blijven zitten en praten";

"S3.P5.N" = "Yuki kijkt naar de sterren. 'Herinner je je onze eerste dag hier nog?' vraagt ze. 'Je hielp me met mijn tassen toen de rest het te druk had.'";
"S3.P5.Q" = "Herinner je je dat nog?";
"S3.P5.O1" = "Ik herinner me elk detail";
"S3.P5.O2" = "Het voelt als een eeuwigheid geleden";

"S3.P6.N" = "Ze lacht zachtjes. 'Ik was toen zo bang. Maar toen ik jou zag, voelde ik me meteen op mijn gemak.' Ze staart over het water.";
"S3.P6.Q" = "Je eigen gevoelens toegeven?";
"S3.P6.O1" = "Ik voelde hetzelfde";
"S3.P6.O2" = "Ik ben blij dat ik kon helpen";

"S3.P7.N" = "De nacht is volkomen stil. Plotseling staat Yuki op. 'Het water ziet er zo uitnodigend uit. Zullen we... erin gaan?' vraagt ze met een ondeugende blik.";
"S3.P7.Q" = "Ben je dapper genoeg?";
"S3.P7.O1" = "Laten we erin duiken!";
"S3.P7.O2" = "Het is te koud, Yuki";

"S3.P8.N" = "Ze kijkt naar het meer, en dan naar jou. 'Ik wil iets dappers doen vanavond. Iets wat ik de hele winter zal onthouden.'";
"S3.P8.Q" = "Haar aanmoedigen?";
"S3.P8.O1" = "Spring je met me mee?";
"S3.P8.O2" = "Laten we hier blijven";

"S3.P9.N" = "PLONS! Het water is ijskoud maar verfrissend. Jij en Yuki komen proestend en lachend boven en spatten elkaar nat als kleine kinderen.";
"S3.P9.Q" = "Dichter naar haar toe zwemmen?";
"S3.P9.O1" = "Trek haar in een knuffel";
"S3.P9.O2" = "Blijf haar natspatten!";

"S3.P10.N" = "Jullie blijven op de steiger. Jullie praten urenlang over alles—school, ouders en de toekomst. De band tussen jullie wordt sterker in de stilte.";
"S3.P10.Q" = "Dichterbij komen?";
"S3.P10.O1" = "Rust je hoofd op het hare";
"S3.P10.O2" = "Kijk haar diep in de ogen";

"S3.P11.N" = "De sfeer verandert. Yuki stopt met praten. In het zwakke licht zoeken haar ogen de jouwe. 'Ik wil morgen niet terug naar de stad,' fluistert ze.";
"S3.P11.Q" = "Wat zeg je?";
"S3.P11.O1" = "We zien elkaar daar weer";
"S3.P11.O2" = "Laten we niet aan morgen denken";

"S3.P12.N" = "Yuki haalt diep adem. 'Als ik dit nu niet zeg, doe ik het nooit. Ik vind je al leuk sinds die eerste dag bij de bushalte.'";
"S3.P12.Q" = "Hoe reageer je?";
"S3.P12.O1" = "Ik vind jou ook leuk";
"S3.P12.O2" = "Eindelijk, de waarheid!";

"S3.P13.N" = "Ze grijpt in haar zak en haalt er een handgemaakt vriendschapsbandje uit. Het is blauw met wit, de kleuren van het meer. 'Ik heb dit voor je gemaakt,' zegt ze verlegen.";
"S3.P13.Q" = "Het cadeau aannemen?";
"S3.P13.O1" = "Laat haar het om je pols binden";
"S3.P13.O2" = "Geef haar een kus in plaats daarvan";

"S3.P14.N" = "Het bandje is simpel, maar je weet dat ze er uren aan heeft gewerkt. Ze wacht op je reactie, haar onderlip trilt een beetje.";
"S3.P14.Q" = "Wat is je volgende zet?";
"S3.P14.O1" = "Bedank haar met een knuffel";
"S3.P14.O2" = "Vertel haar dat het perfect is";

"S3.P15.N" = "Yuki glimlacht, een stralende lach. 'Ik was zo bang dat je het kinderachtig zou vinden.' Ze kijkt naar de maan en ziet er zelfverzekerder uit.";
"S3.P15.Q" = "Een belofte doen?";
"S3.P15.O1" = "Beloof dat je elke dag belt";
"S3.P15.O2" = "Beloof dat je haar snel opzoekt";

"S3.P16.N" = "De spanning is om te snijden. Yuki staart naar je lippen. De wereld om je heen verdwijnt; het is alleen jij en zij in de zomernacht.";
"S3.P16.Q" = "Is dit het moment?";
"S3.P16.O1" = "Leun naar voren voor een kus";
"S3.P16.O2" = "Fluister iets liefs";

"S3.P17.N" = "Net op dat moment schiet er een vallende ster langs de hemel. Yuki snakt naar adem. 'Snel! Doe een wens!' roept ze uit.";
"S3.P17.Q" = "Wat wens je?";
"S3.P17.O1" = "Wens voor een toekomst samen";
"S3.P17.O2" = "Wens dat deze nacht nooit eindigt";

"S3.P18.N" = "De ster verdwijnt even snel als hij kwam. Yuki knijpt haar ogen stijf dicht. 'Ik heb iets heel belangrijks gewenst,' zegt ze blozend.";
"S3.P18.Q" = "Vragen wat het was?";
"S3.P18.O1" = "Vertel me je wens";
"S3.P18.O2" = "Ik denk dat ik het wel weet";

"S3.P19.N" = "Het vuur op het kamp is nu helemaal gedoofd. Jullie beginnen aan de wandeling terug, hand in hand. Het bos voelt anders aan—minder eng, magischer.";
"S3.P19.Q" = "Langzaam lopen?";
"S3.P19.O1" = "Neem de lange weg terug";
"S3.P19.O2" = "Geniet van de stilte";

"S3.P20.N" = "Jullie lopen langs de oude eik waar jullie elkaar voor het eerst ontmoetten. Yuki stopt even. 'Alles gaat veranderen, toch?' vraagt ze zachtjes.";
"S3.P20.Q" = "Haar troosten?";
"S3.P20.O1" = "Verandering kan goed zijn";
"S3.P20.O2" = "Niet alles hoeft te veranderen";

"S3.P21.N" = "De hutjes van het kamp komen in zicht. De andere kampeerders slapen al. Yuki stopt bij haar deur. Ze wil je hand niet loslaten.";
"S3.P21.Q" = "Nog één ding?";
"S3.P21.O1" = "Vraag om een laatste kus";
"S3.P21.O2" = "Vraag om haar telefoonnummer";

"S3.P22.N" = "Yuki dralen in de deuropening. Het licht van de veranda werpt een zachte gloed op haar gezicht. 'Bedankt voor vanavond. Het was de beste nacht van mijn leven.'";
"S3.P22.Q" = "Afscheid nemen?";
"S3.P22.O1" = "Tot morgenochtend";
"S3.P22.O2" = "Slaap lekker, Yuki";

"S3.P23.N" = "Zonsopgang. Het kamp is een drukte van jewelste met mensen die tassen inpakken en bussen instappen. Je zoekt Yuki in de menigte, je hart gaat tekeer.";
"S3.P23.Q" = "Kun je haar vinden?";
"S3.P23.O1" = "Zoek bij de bus";
"S3.P23.O2" = "Check de steiger nog één keer";

"S3.P24.N" = "De motoren van de bussen ronken. Je ziet haar! Ze staat bij het hek en kijkt koortsachtig om zich heen tot ze je ziet.";
"S3.P24.Q" = "Naar haar toe rennen?";
"S3.P24.O1" = "Ren naar haar toe en omhels haar";
"S3.P24.O2" = "Zwaai en glimlach";

"S3.P25.N" = "Je bereikt haar net op tijd. Ze fluistert iets in je oor dat je nooit zult vergeten: 'Laat dit niet alleen een zomerherinnering zijn.'";
"S3.P25.Q" = "Wat is je antwoord?";
"S3.P25.O1" = "Dat beloof ik";
"S3.P25.O2" = "Ik zie je volgend weekend";

"S3.P26.N" = "De buschauffeur toetert. Yuki moet gaan. Ze werpt je een kushandje toe terwijl ze instapt. Je blijft daar staan en kijkt hoe de bus in het stof verdwijnt.";
"S3.P26.Q" = "Hoe voel je je?";
"S3.P26.O1" = "Gelukkig en hoopvol";
"S3.P26.O2" = "Verdrietig maar voldaan";

"S3.P27.N" = "Maanden later. Je bent in de stad en je telefoon trilt. Het is een foto van Yuki—ze draagt het bandje dat jullie deelden. De zomer is nooit echt geëindigd.";
"S3.P27.Q" = "HET EINDE";
"S3.P27.O1" = "Verhaal opnieuw starten";
"S3.P27.O2" = "Afronden";

"S3.P28.N" = "Je kijkt naar het bandje om je pols. Het is een beetje versleten, maar de herinneringen zijn nog vers. Soms is één zomer genoeg voor een heel leven.";
"S3.P28.Q" = "HET EINDE";
"S3.P28.O1" = "Opnieuw proberen";
"S3.P28.O2" = "Afronden";
