/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "Rumah agam sunyi sepi kepulangan awak. Cahaya malap kelihatan di bilik kerja. Awak mendapati Elena, pembantu rumah yang paling pendiam, sedang mengemas meja awak dengan gementar pada jam 2 pagi.";
"S1.P0.Q" = "Dekati dia?";
"S1.P0.O1" = "Elena, kenapa belum tidur lagi?";
"S1.P0.O2" = "(Perhati dari sebalik bayang-bayang)";

/* Page 1 */
"S1.P1.N" = "Dia terkejut dan menjatuhkan penyapu bulu ayam. 'Tuan! Saya... saya tak boleh tidur. Habuk ini mengganggu saya.' Wajahnya pucat dan dia mengelak pandangan mata awak.";
"S1.P1.Q" = "Percaya cakap dia?";
"S1.P1.O1" = "Dah lewat sangat untuk mengemas";
"S1.P1.O2" = "Awak memang pekerja yang gigih";

/* Page 2 */
"S1.P2.N" = "Awak melihat dia mengeluarkan kunci perak kecil dari apronnya. Dia merenungnya dengan perasaan rindu dan takut sebelum menyedari bayang-bayang awak.";
"S1.P2.Q" = "Melangkah ke hadapan?";
"S1.P2.O1" = "Kunci apa itu, Elena?";
"S1.P2.O2" = "Jelaskan perkara ini sekarang juga";

/* Page 3 */
"S1.P3.N" = "Dia menggigil. 'Rumah ini... banyak rahsianya, Tuan. Kadang-kadang ia membebani saya.' Dia menunjuk ke arah peti besi lama di sebalik rak buku.";
"S1.P3.Q" = "Tanya pasal peti besi?";
"S1.P3.O1" = "Adakah kunci itu untuk peti besi tersebut?";
"S1.P3.O2" = "Peti besi itu dilarang disentuh";

/* Page 4 */
"S1.P4.N" = "Dia cuba menyembunyikan kunci itu, tetapi ia terjatuh. 'Saya bukan pencuri, saya janji! Saya cuma... saya nampak ia di lorong dan ingat ia milik Tuan.'";
"S1.P4.Q" = "Ambil kunci itu?";
"S1.P4.O1" = "(Ambil kunci)";
"S1.P4.O2" = "Mari kita tengok apa yang ia buka";

/* Page 5 */
"S1.P5.N" = "Kunci itu sepadan dengan bahagian tersembunyi di dalam peti besi. Elena memerhati dengan penuh debaran saat awak mendedahkan timbunan surat lama yang kekuningan, diikat dengan reben hitam.";
"S1.P5.Q" = "Baca surat teratas?";
"S1.P5.O1" = "Baca dengan kuat";
"S1.P5.O2" = "Tanya Elena apa yang dia tahu";

/* Page 6 */
"S1.P6.N" = "Suara Elena berubah menjadi bisikan. 'Ibu saya juga pernah menjadi pembantu di sini. Dia beritahu saya yang Tuan Besar menyimpan rekod tentang seorang gadis yang pernah dicintainya. Gadis yang mirip wajah saya.'";
"S1.P6.Q" = "Tunggu, apa?";
"S1.P6.O1" = "Ceritakan segalanya";
"S1.P6.O2" = "Ini mustahil";

/* Page 7 */
"S1.P7.N" = "Surat-surat itu menceritakan tentang cinta terlarang. Elena melangkah lebih dekat, cahaya bulan menyinari air matanya. 'Saya tak niat nak mencuri. Saya cuma nak tahu jika saya benar-benar milik di sini.'";
"S1.P7.Q" = "Pujuk dia?";
"S1.P7.O1" = "Letakkan tangan di bahunya";
"S1.P7.O2" = "Berikan dia ruang";

/* Page 8 */
"S1.P8.N" = "Dia menjelaskan diari ibunya menyebut tentang kebenaran yang tersembunyi di dalam bilik ini. 'Saya dah tinggal di rumah ini seumur hidup saya, Tuan, tapi saya rasa seperti hantu.'";
"S1.P8.Q" = "Buat janji?";
"S1.P8.O1" = "Saya akan bantu awak cari kebenaran";
"S1.P8.O2" = "Kita akan selesaikan ini bersama-sama";

/* Page 9 */
"S1.P9.N" = "Awak meluangkan masa sejam mencari rekod. Awak terjumpa sijil kelahiran dengan nama yang dikenali, tetapi bahagian bapa dikosongkan.";
"S1.P9.Q" = "Pandang Elena?";
"S1.P9.O1" = "Mungkinkah itu pakcik saya?";
"S1.P9.O2" = "Mungkin lebih baik kita tak tahu";

/* Page 10 */
"S1.P10.N" = "Pencarian semakin mendalam. Elena menemui kotak barang kemas yang tersembunyi di sebalik surat-surat. Di dalamnya ada loket dengan potret wanita yang seiras dengannya.";
"S1.P10.Q" = "Tunjukkan padanya?";
"S1.P10.O1" = "Lihat loket ini";
"S1.P10.O2" = "Adakah ini ibu awak?";

/* Page 11 */
"S1.P11.N" = "Tiba-tiba, bunyi lantai berkerit di luar. Ada orang di lorong. Mata Elena terbeliak ketakutan. 'Kalau Butler jumpa kita...!'";
"S1.P11.Q" = "Sembunyi?";
"S1.P11.O1" = "Sembunyi di dalam almari bersamanya";
"S1.P11.O2" = "Kekal di sini dan hadapi mereka";

/* Page 12 */
"S1.P12.N" = "Bunyi tapak kaki semakin dekat. Elena memegang lengan baju awak. 'Tolong Tuan, tak ada siapa boleh tahu kita jumpa ini. Ia bahaya bagi saya.'";
"S1.P12.Q" = "Reaksi?";
"S1.P12.O1" = "Padamkan lampu";
"S1.P12.O2" = "Kunci pintu";

/* Page 13 */
"S1.P13.N" = "Bilik menjadi gelap gelita. Dalam ruang yang sempit itu, awak boleh mendengar degupan jantung Elena yang laju dan bau kelopak mawar pada kulitnya. Dia sangat dekat dengan awak.";
"S1.P13.Q" = "Berbisik padanya?";
"S1.P13.O1" = "Awak selamat dengan saya";
"S1.P13.O2" = "(Diam dan tunggu)";

/* Page 14 */
"S1.P14.N" = "Awak menahan pintu. Orang di luar itu menunggu seketika, kemudian berlalu pergi. Elena bersandar pada awak, menggigil kerana debaran adrenalin.";
"S1.P14.Q" = "Tenangkan dia?";
"S1.P14.O1" = "Mereka dah pergi";
"S1.P14.O2" = "Awak okay?";

/* Page 15 */
"S1.P15.N" = "Dia menjauhkan diri sedikit, tetapi tangannya masih di dada awak. 'Tuan... saya selalu mengagumi Tuan dari jauh. Rahsia ini... terlalu berat untuk dipikul sendirian.'";
"S1.P15.Q" = "Perasaan awak?";
"S1.P15.O1" = "Saya pun perasan awak juga";
"S1.P15.O2" = "Awak lebih daripada sekadar pembantu";

/* Page 16 */
"S1.P16.N" = "'Saya ingatkan saya cuma pelayan bagi Tuan,' bisiknya. 'Cuma sebahagian daripada perabot. Tapi malam ini rasa seperti permulaan sesuatu yang nyata.'";
"S1.P16.Q" = "Setuju?";
"S1.P16.O1" = "Ia memang nyata, Elena";
"S1.P16.O2" = "Mari kita lihat ke mana ini membawa kita";

/* Page 17 */
"S1.P17.N" = "Dia membuka loket itu. Di dalamnya ada nota kecil: 'Untuk anak perempuanku, pewaris sebenar.' Elena tergamam. Rumah agam ini mungkin sebenarnya milik dia.";
"S1.P17.Q" = "Implikasinya?";
"S1.P17.O1" = "Kita mesti dedahkan ini";
"S1.P17.O2" = "Kita patut rahsiakan ini";

/* Page 18 */
"S1.P18.N" = "Nota itu membuktikan Elena adalah pemilik sah estet ini. Dia memandang sekeliling bilik dengan terkejut. 'Saya... saya tak mahukan rumah ini. Saya cuma mahukan sebuah keluarga.'";
"S1.P18.Q" = "Apa yang awak mahukan?";
"S1.P18.O1" = "Awak dah ada saya sekarang";
"S1.P18.O2" = "Apa yang awak akan buat?";

/* Page 19 */
"S1.P19.N" = "Dia memandang ke arah tempat perapian. 'Kalau saya bakar ini, saya jadi Elena biasa semula. Kalau saya simpan, semuanya berubah. Tuan, apa patut saya buat?'";
"S1.P19.Q" = "Beri nasihat?";
"S1.P19.O1" = "Bakar dan tinggal bersama saya";
"S1.P19.O2" = "Simpan dan ambil hak awak";

/* Page 20 */
"S1.P20.N" = "Elena memegang bukti keturunannya. 'Nama keluarga ini berpuaka, Tuan. Saya lebih rela jadi orang biasa yang bahagia daripada jadi wanita bangsawan yang derita.'";
"S1.P20.Q" = "Pilihan awak?";
"S1.P20.O1" = "Ikut kata hati awak";
"S1.P20.O2" = "Fikirkan masa depan awak";

/* Page 21 */
"S1.P21.N" = "Dia mencampakkan kertas itu ke dalam bara api yang kian padam. Rahsia itu menjadi abu. Elena tersenyum, kelihatan lebih bebas daripada sebelumnya.";
"S1.P21.Q" = "Masa depan?";
"S1.P21.O1" = "Permulaan yang baru";
"S1.P21.O2" = "Hanya kita berdua";

/* Page 22 */
"S1.P22.N" = "Dia menyimpan kertas itu di dalam bajunya. 'Kalau begitu, saya akan menjadi Tuan Puteri rumah ini. Dan saya perlukan pasangan di sisi saya.'";
"S1.P22.Q" = "Awak sedia?";
"S1.P22.O1" = "Sentiasa sedia";
"S1.P22.O2" = "Ia akan menjadi perjalanan yang panjang";

/* Final 1 */
"S1.P23.N" = "Elena bukan lagi pembantu rumah awak. Dia adalah setaraf dengan awak, pasangan awak, dan rahsia awak. Rumah agam itu tetap milik awak, tetapi jantungnya milik dia.";
"S1.P23.Q" = "TAMAT";
"S1.P23.O1" = "Mula Semula Cerita";
"S1.P23.O2" = "Selesai";

/* Final 2 */
"S1.P24.N" = "Kebenaran terbongkar. Elena menjadi ketua isi rumah. Dinamik kuasa telah berubah, tetapi ikatan yang awak bina malam itu tidak akan hancur.";
"S1.P24.Q" = "TAMAT";
"S1.P24.O1" = "Mula Semula Cerita";
"S1.P24.O2" = "Selesai";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "Hujan membasahi jalan neon Shinjuku. Awak sedang duduk di sebuah bar yang tenang apabila seorang wanita berbaju kot hujan basah duduk di sebelah awak. Dia berbau seperti bunga melur dan belerang.";
"S2.P0.Q" = "Bagaimana awak mulakan perbualan?";
"S2.P0.O1" = "Belikan dia minuman";
"S2.P0.O2" = "Malam yang sukar, ya?";

"S2.P1.N" = "Dia memandang gelasnya, kemudian memandang awak. 'Awak berani,' bisiknya. Dia menolak cip data kecil di atas kaunter.";
"S2.P1.Q" = "Ambil cip itu?";
"S2.P1.O1" = "Ambil dan sembunyikan";
"S2.P1.O2" = "Saya tak nak masalah";

"S2.P2.N" = "Dia ketawa sinis. 'Awak tak ada idea.' Dia memandang ke belakang. Dua lelaki berpakaian sut hitam baru masuk ke bar.";
"S2.P2.Q" = "Bantu dia sembunyi?";
"S2.P2.O1" = "Ikut saya ke pintu belakang";
"S2.P2.O2" = "Berpura-pura kita pasangan kekasih";

"S2.P3.N" = "Awak menariknya rapat. Lelaki-lelaki itu memerhati ruang bar dan beredar. Dia kelihatan lega tetapi tangannya menggigil. 'Saya Mia,' bisiknya.";
"S2.P3.Q" = "Tanya tentang bahaya itu?";
"S2.P3.O1" = "Siapa mereka tadi, Mia?";
"S2.P3.O2" = "Kita selamat sekarang?";

"S2.P4.N" = "Lelaki-lelaki itu mendekati, tapi awak bersikap tenang. Mereka melintas. Dia berbisik: 'Awak selamatkan saya. Saya Mia. Tapi cip ini... ia bernilai sejuta nyawa.'";
"S2.P4.Q" = "Tanya pasal cip?";
"S2.P4.O1" = "Apa ada di dalamnya?";
"S2.P4.O2" = "Kita patut pergi dari sini";

"S2.P5.N" = "Mia memandang ke pintu. 'Korporasi 'Arasaka' mahukan ini. Ia bukan sekadar data, ia adalah jiwa digital.'";
"S2.P5.Q" = "Percaya dia?";
"S2.P5.O1" = "Jiwa digital? Biar betul?";
"S2.P5.O2" = "Saya pernah dengar khabar angin...";

"S2.P6.N" = "Mia memegang tangan awak. 'Tak ada tempat yang selamat selagi kita tak muat naik ini. Kita kena sampai ke Daerah Teknologi.'";
"S2.P6.Q" = "Pergi bersamanya?";
"S2.P6.O1" = "Saya akan bawa awak ke sana";
"S2.P6.O2" = "Hanya jika awak beritahu lebih lanjut";

"S2.P7.N" = "Awak menyelinap keluar. Lorong itu gelap dan berbau ozon. Tiba-tiba, sebuah dron berbunyi di atas, mencari kesan haba.";
"S2.P7.Q" = "Macam mana nak elak dron?";
"S2.P7.O1" = "Sembunyi di bawah kanopi";
"S2.P7.O2" = "Lari ke arah kereta api bawah tanah";

"S2.P8.N" = "Mia berhenti dalam hujan. 'Kalau mereka tangkap saya, mereka akan hapuskan saya. Dan awak juga, sebab tolong saya.'";
"S2.P8.Q" = "Tenangkan dia?";
"S2.P8.O1" = "Saya bersama awak dalam hal ini";
"S2.P8.O2" = "Jom gerak, cepat";

"S2.P9.N" = "Dron itu berlalu. Awak sampai ke kereta. Mia memandang awak dengan perasaan takut dan berterima kasih.";
"S2.P9.Q" = "Hidupkan enjin?";
"S2.P9.O1" = "Pecut!";
"S2.P9.O2" = "Pandu perlahan, jangan tarik perhatian";

"S2.P10.N" = "Awak hampir tak sempat sampai ke stesen. Orang ramai sangat ramai, memberikan perlindungan sempurna. Mia kekal dekat, bahunya bersentuhan dengan awak.";
"S2.P10.Q" = "Teruskan bergerak?";
"S2.P10.O1" = "Naik kereta api ekspres";
"S2.P10.O2" = "Jalan melalui terowong";

"S2.P11.N" = "Awak sedang bergerak melalui daerah pencakar langit. Iklan holografik menyinari wajah Mia dalam warna merah jambu dan biru.";
"S2.P11.Q" = "Mulakan perbualan?";
"S2.P11.O1" = "Kenapa pilih saya, Mia?";
"S2.P11.O2" = "Ceritakan tentang cip itu";

"S2.P12.N" = "Bandar ini terasa seperti labirin. Awak berhenti di kedai ramen tersembunyi untuk berehat sekejap.";
"S2.P12.Q" = "Perhati jalan?";
"S2.P12.O1" = "Periksa jika ada yang mengekor";
"S2.P12.O2" = "Bercakap dengan Mia";

"S2.P13.N" = "Mia menunduk. 'Awak satu-satunya orang yang tak nampak seperti pemangsa malam ini. Saya perlukan manusia, bukan askar upahan.'";
"S2.P13.Q" = "Balas dengan baik?";
"S2.P13.O1" = "Saya gembira saya ada di sana";
"S2.P13.O2" = "Saya cuma lelaki biasa di bar";

"S2.P14.N" = "Mia mengetik cip itu. 'Ini kesedaran kakak saya. Dia seorang netrunner yang tahu terlalu banyak. Mereka 'bunuh' badannya.'";
"S2.P14.Q" = "Tunjukkan simpati?";
"S2.P14.O1" = "Itu sangat mengerikan...";
"S2.P14.O2" = "Bolehkah dia diselamatkan?";

"S2.P15.N" = "Dia mengesat air mata. 'Tempat muat naik ada di menara TV lama. Tapi jambatan disekat oleh sekatan jalan raya polis.'";
"S2.P15.Q" = "Macam mana nak lintas?";
"S2.P15.O1" = "Gunakan kemahiran penggodam awak";
"S2.P15.O2" = "Rasuah pengawal";

"S2.P16.N" = "Mia menunjukkan peta. 'Kalau kita lalu pembentung, ia lebih selamat, tapi jalannya jauh.'";
"S2.P16.Q" = "Pilih jalan?";
"S2.P16.O1" = "Mari ikut jalan pembentung";
"S2.P16.O2" = "Tak, kita kena cepat";

"S2.P17.N" = "Ia kotor dan gelap, tapi berkesan. Mia bergantung pada panduan awak. Awak dapat rasa betapa dia mempercayai awak.";
"S2.P17.Q" = "Bantu dia melintasi ruang?";
"S2.P17.O1" = "Berikan dia tangan";
"S2.P17.O2" = "Pimpin jalan";

"S2.P18.N" = "Keadaan di jambatan huru-hara. Awak gunakan kekeliruan itu untuk menyelinap. Jantung Mia berdegup sangat laju sehingga awak hampir boleh mendengarnya.";
"S2.P18.Q" = "Tenangkan dia?";
"S2.P18.O1" = "Kita dah hampir sampai";
"S2.P18.O2" = "Kekal fokus, Mia";

"S2.P19.N" = "Menara TV kelihatan di hadapan. Ia adalah relik dunia lama, dikelilingi oleh keluli moden. Mia kelihatan sangat letih.";
"S2.P19.Q" = "Tawarkan rehat?";
"S2.P19.O1" = "Rehat selama 5 minit";
"S2.P19.O2" = "Teruskan sampai ke penghujung";

"S2.P20.N" = "Awak sampai ke kaki menara. 'Lif dah mati,' Mia mengeluh. 'Kita kena panjat.'";
"S2.P20.Q" = "Beri galakan?";
"S2.P20.O1" = "Satu langkah demi satu langkah";
"S2.P20.O2" = "Biar saya bawa peralatan";

"S2.P21.N" = "Awak duduk di tangga. Mia bersandar pada awak. 'Kalau kita berjaya... apa awak buat esok?'";
"S2.P21.Q" = "Fikir masa depan?";
"S2.P21.O1" = "Mungkin kita boleh minum kopi";
"S2.P21.O2" = "Saya cuma nak dapat tidur dengan aman";

"S2.P22.N" = "Pendakian itu sangat perit. Separuh jalan ke atas, awak dengar bunyi siren di bawah. Mereka dah jumpa kereta awak.";
"S2.P22.Q" = "Cepatkan langkah?";
"S2.P22.O1" = "Gandakan kelajuan!";
"S2.P22.O2" = "Cari tempat bersembunyi";

"S2.P23.N" = "Awak sampai ke bilik pelayan. Udara sejuk dan berdesing dengan kuasa elektrik. Mia menyambungkan cip. 'Memulakan...' katanya.";
"S2.P23.Q" = "Perhati skrin?";
"S2.P23.O1" = "Jaga pintu";
"S2.P23.O2" = "Kekal di sisi Mia";

"S2.P24.N" = "Terminal itu kuno tapi masih berfungsi. Jari-jemari Mia menari di atas papan kekunci. 'Dinding apinya sangat besar!'";
"S2.P24.Q" = "Bantu dia menggodam?";
"S2.P24.O1" = "Pintas bekalan kuasa";
"S2.P24.O2" = "Pastikan dia kekal tenang";

"S2.P25.N" = "Pintu berdesis. Pasukan taktikal Arasaka sudah sampai. Awak mengeluarkan senjata. 'Dua minit lagi!' jerit Mia.";
"S2.P25.Q" = "Pertahankan kawasan?";
"S2.P25.O1" = "Lepaskan tembakan!";
"S2.P25.O2" = "Sekat pintu";

"S2.P26.N" = "Mata Mia bercahaya biru. Dia sedang jauh di dalam rangkaian net. Askar-askar mula memecah masuk melalui bumbung kaca.";
"S2.P26.Q" = "Lindungi Mia?";
"S2.P26.O1" = "Lindungi dia dengan badan awak";
"S2.P26.O2" = "Tarik dia ke tempat selamat";

"S2.P27.N" = "Kilauan cahaya yang membutakan. Muat naik selesai 100%. Askar-askar itu kaku—peranti siber mereka telah disekat dari rangkaian.";
"S2.P27.Q" = "Periksa Mia?";
"S2.P27.O1" = "Dah selesai?";
"S2.P27.O2" = "Awak okay?";

"S2.P28.N" = "Semuanya menjadi gelap. Kemudian, setiap skrin di Tokyo menyala dengan satu mesej: 'KEBEBASAN'. Mia jatuh ke dalam pelukan awak.";
"S2.P28.Q" = "Kejutkan dia?";
"S2.P28.O1" = "Mia! Cakap dengan saya!";
"S2.P28.O2" = "Pegang dia erat-erat";

"S2.P29.N" = "Matahari mula terbit di Tokyo yang berbeza. Mia tersenyum, matanya kembali normal. 'Dia selamat. Kita selamat.'";
"S2.P29.Q" = "TAMAT";
"S2.P29.O1" = "Mula Semula Cerita";
"S2.P29.O2" = "Selesai";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "Malam terakhir kem musim panas. Unggun api semakin padam, dan bau jarum pain ada di mana-mana. Yuki, yang biasanya pemalu, memandang awak dan memberi isyarat ke arah jalan gelap menuju ke tasik.";
"S3.P0.Q" = "Adakah awak akan mengikutinya ke dalam kegelapan?";
"S3.P0.O1" = "Saya dah lama tunggu saat ini";
"S3.P0.O2" = "Tentu, jom pergi";

"S3.P1.N" = "Awak mengejarnya. Hutan itu hidup dengan bunyi cengkerik. Tangan Yuki sekali-sekala bersentuhan dengan tangan awak semasa berjalan. Dia kelihatan gementar.";
"S3.P1.Q" = "Macam mana nak mulakan bicara?";
"S3.P1.O1" = "Pegang tangannya dengan erat";
"S3.P1.O2" = "Tanya apa yang dia fikirkan";

"S3.P2.N" = "Awak berjalan bersebelahan. Cahaya bulan hampir tidak menembusi dahan pokok yang tebal. Yuki memandang awak dari sisi, tersenyum nipis. 'Saya tak sangka awak betul-betul datang,' bisiknya.";
"S3.P2.Q" = "Apa jawapan awak?";
"S3.P2.O1" = "Saya takkan lepaskan peluang ini";
"S3.P2.O2" = "Saya cuma ingin tahu";

"S3.P3.N" = "Awak sampai ke jeti. Air tasik seperti cermin gelap, memantulkan lautan bintang yang luas. Yuki menanggalkan kasutnya dan duduk di tepi jeti, menghayunkan kakinya.";
"S3.P3.Q" = "Duduk dekat dengannya?";
"S3.P3.O1" = "Duduk tepat di sebelahnya";
"S3.P3.O2" = "Berikan dia sedikit ruang";

"S3.P4.N" = "Jeti itu berkerit di bawah berat badan awak. Udara sejuk dari tasik membuatkan Yuki sedikit menggigil. Dia tidak berganjak semasa awak mendekati.";
"S3.P4.Q" = "Tawarkan jaket awak?";
"S3.P4.O1" = "Sarungkan jaket awak padanya";
"S3.P4.O2" = "Cuma duduk dan berbual";

"S3.P5.N" = "Yuki memandang bintang. 'Awak ingat tak hari pertama kita di sini?' tanyanya. 'Awak tolong saya bawa beg masa orang lain semua sibuk.'";
"S3.P5.Q" = "Adakah awak ingat?";
"S3.P5.O1" = "Saya ingat setiap perincian";
"S3.P5.O2" = "Rasa macam dah lama sangat";

"S3.P6.N" = "Dia ketawa kecil. 'Saya sangat takut masa tu. Tapi nampak awak buat saya rasa seperti saya milik di sini.' Dia memandang ke arah air.";
"S3.P6.Q" = "Akui perasaan awak sendiri?";
"S3.P6.O1" = "Saya pun rasa perkara yang sama";
"S3.P6.O2" = "Saya gembira dapat membantu";

"S3.P7.N" = "Malam itu sangat tenang. Tiba-tiba, Yuki berdiri. 'Air tu nampak sangat menarik. Patutkah kita... terjun?' tanyanya dengan pandangan nakal.";
"S3.P7.Q" = "Adakah awak cukup berani?";
"S3.P7.O1" = "Jom kita terjun!";
"S3.P7.O2" = "Sejuk sangatlah, Yuki";

"S3.P8.N" = "Dia memandang ke arah tasik, kemudian memandang awak. 'Saya nak buat sesuatu yang berani malam ni. Sesuatu yang saya akan ingat sepanjang musim sejuk.'";
"S3.P8.Q" = "Beri galakan padanya?";
"S3.P8.O1" = "Terjun bersama saya?";
"S3.P8.O2" = "Mari kekal di sini";

"S3.P9.N" = "SPLASH! Air itu sangat sejuk tapi menyegarkan. Awak dan Yuki muncul di permukaan, tercengang dan ketawa, saling menyimbah air seperti kanak-kanak.";
"S3.P9.Q" = "Berenang lebih dekat dengannya?";
"S3.P9.O1" = "Tarik dia ke dalam pelukan";
"S3.P9.O2" = "Teruskan menyimbah air!";

"S3.P10.N" = "Awak kekal di jeti. Awak berbual berjam-jam tentang segalanya—sekolah, ibu bapa, dan masa depan. Ikatan antara awak berdua semakin kuat dalam kesunyian.";
"S3.P10.Q" = "Merapat lagi?";
"S3.P10.O1" = "Sandarkan kepala awak pada kepalanya";
"S3.P10.O2" = "Pandang tepat ke dalam matanya";

"S3.P11.N" = "Suasana berubah. Yuki berhenti bercakap. Dalam cahaya malap, matanya mencari mata awak. 'Saya tak nak balik ke bandar esok,' bisiknya.";
"S3.P11.Q" = "Apa yang awak katakan?";
"S3.P11.O1" = "Kita akan jumpa lagi di sana";
"S3.P11.O2" = "Jangan fikir tentang esok dulu";

"S3.P12.N" = "Yuki menarik nafas dalam. 'Kalau saya tak cakap sekarang, saya takkan pernah cakap. Saya dah sukakan awak sejak hari pertama di perhentian bas lagi.'";
"S3.P12.Q" = "Bagaimana reaksi awak?";
"S3.P12.O1" = "Saya pun sukakan awak juga";
"S3.P12.O2" = "Akhirnya, terbongkar pun rahsia!";

"S3.P13.N" = "Dia menyeluk saku dan mengeluarkan gelang persahabatan buatan sendiri. Warnanya biru dan putih, seperti warna tasik. 'Saya buat ni untuk awak,' katanya dengan malu.";
"S3.P13.Q" = "Terima hadiah itu?";
"S3.P13.O1" = "Biar dia ikatkan pada tangan awak";
"S3.P13.O2" = "Berikan dia ciuman sebagai balasan";

"S3.P14.N" = "Gelang itu ringkas, tapi awak tahu dia mengambil masa berjam-jam untuk menyiapkannya. Dia menunggu reaksi awak, bibir bawahnya sedikit menggigil.";
"S3.P14.Q" = "Apa tindakan awak?";
"S3.P14.O1" = "Ucap terima kasih dengan pelukan";
"S3.P14.O2" = "Beritahunya yang ia sangat sempurna";

"S3.P15.N" = "Yuki tersenyum, senyuman yang benar-benar berseri. 'Saya risau awak akan ingat ia kebudak-budakan.' Dia memandang bulan, kelihatan lebih yakin sekarang.";
"S3.P15.Q" = "Buat janji?";
"S3.P15.O1" = "Janji untuk telefon setiap hari";
"S3.P15.O2" = "Janji untuk melawatnya segera";

"S3.P16.N" = "Suasana terasa sangat intim. Yuki sedang merenung bibir awak. Dunia sekeliling seolah hilang; hanya ada awak berdua dan malam musim panas.";
"S3.P16.Q" = "Adakah ini masanya?";
"S3.P16.O1" = "Dekati untuk ciuman";
"S3.P16.O2" = "Bisikkan sesuatu yang manis";

"S3.P17.N" = "Tiba-tiba, tahi bintang melintas di langit, meninggalkan jejak perak. Yuki tergamam. 'Cepat! Buat hajat!' jeritnya.";
"S3.P17.Q" = "Apa hajat awak?";
"S3.P17.O1" = "Hajat untuk masa depan bersama";
"S3.P17.O2" = "Hajat agar malam ini berpanjangan";

"S3.P18.N" = "Bintang itu hilang sepantas ia datang. Yuki memejamkan matanya rapat. 'Saya harapkan sesuatu yang penting,' katanya sambil tersipu malu.";
"S3.P18.Q" = "Tanya apa hajatnya?";
"S3.P18.O1" = "Beritahu saya hajat awak";
"S3.P18.O2" = "Saya rasa saya tahu apa hajat tu";

"S3.P19.N" = "Unggun api di kem telah padam sepenuhnya sekarang. Awak mula berjalan pulang, berpegangan tangan. Hutan itu terasa berbeza sekarang—kurang menakutkan, lebih ajaib.";
"S3.P19.Q" = "Jalan perlahan-lahan?";
"S3.P19.O1" = "Ikut jalan yang lebih jauh";
"S3.P19.O2" = "Nikmati kesunyian ini";

"S3.P20.N" = "Awak melewati pokok oak lama tempat pertama kali awak bertemu. Yuki berhenti seketika. 'Semuanya akan berubah, kan?' tanyanya lembut.";
"S3.P20.Q" = "Pujuk dia?";
"S3.P20.O1" = "Perubahan boleh jadi sesuatu yang baik";
"S3.P20.O2" = "Tak semua benda kena berubah";

"S3.P21.N" = "Kabin kem sudah kelihatan. Peserta lain sudah tidur. Yuki berhenti di pintu biliknya. Dia tidak mahu melepaskan tangan awak.";
"S3.P21.Q" = "Satu perkara terakhir?";
"S3.P21.O1" = "Minta ciuman terakhir";
"S3.P21.O2" = "Minta nombor telefonnya";

"S3.P22.N" = "Yuki kaku di ambang pintu. Lampu beranda memberikan cahaya lembut pada wajahnya. 'Terima kasih untuk malam ini. Ia malam yang paling indah dalam hidup saya.'";
"S3.P22.Q" = "Ucapkan selamat tinggal?";
"S3.P22.O1" = "Jumpa esok pagi";
"S3.P22.O2" = "Selamat malam, Yuki";

"S3.P23.N" = "Matahari terbit. Kem sibuk dengan orang ramai mengemas beg dan menaiki bas. Awak mencari Yuki dalam kesesakan, jantung berdegup kencang.";
"S3.P23.Q" = "Bolehkah awak menemuinya?";
"S3.P23.O1" = "Cari di tepi bas";
"S3.P23.O2" = "Periksa jeti sekali lagi";

"S3.P24.N" = "Enjin bas sedang berbunyi. Awak nampak dia! Dia berdiri di tepi pintu pagar, memandang sekeliling dengan cemas sehingga dia nampak awak.";
"S3.P24.Q" = "Lari ke arahnya?";
"S3.P24.O1" = "Lari dan peluk dia";
"S3.P24.O2" = "Lambai dan tersenyum";

"S3.P25.N" = "Awak sampai kepadanya tepat pada masanya. Dia membisikkan sesuatu di telinga awak yang takkan awak lupakan. 'Jangan biarkan ini jadi sekadar kenangan musim panas.'";
"S3.P25.Q" = "Berikan jawapan awak?";
"S3.P25.O1" = "Itu satu janji";
"S3.P25.O2" = "Saya akan jumpa awak hujung minggu depan";

"S3.P26.N" = "Pemandu bas membunyikan hon. Yuki terpaksa pergi. Dia memberikan ciuman jauh (blow kiss) semasa menaiki bas. Awak berdiri di situ, memerhati bas hilang dalam debu.";
"S3.P26.Q" = "Apa perasaan awak?";
"S3.P26.O1" = "Gembira dan penuh harapan";
"S3.P26.O2" = "Sedih tapi berpuas hati";

"S3.P27.N" = "Berbulan-bulan kemudian. Awak berada di bandar, dan telefon awak bergetar. Ia gambar daripada Yuki—dia memakai gelang yang awak kongsi bersama. Musim panas tak pernah benar-benar berakhir.";
"S3.P27.Q" = "TAMAT";
"S3.P27.O1" = "Mula Semula Cerita";
"S3.P27.O2" = "Selesai";

"S3.P28.N" = "Awak melihat gelang di pergelangan tangan awak. Ia sedikit haus, tapi kenangannya masih segar. Kadang-kadang, satu musim panas sudah cukup untuk dikenang seumur hidup.";
"S3.P28.Q" = "TAMAT";
"S3.P28.O1" = "Cuba Lagi";
"S3.P28.O2" = "Selesai";

