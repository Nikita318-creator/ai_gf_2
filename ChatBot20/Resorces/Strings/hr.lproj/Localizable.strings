/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "Vila je tiha dok se vraćaš. Slabo svjetlo titra u tvojoj radnoj sobi. Tamo pronalaziš Elenu, svoju najtišu sobaricu, kako nervozno posprema tvoj radni stol u 2 ujutro.";
"S1.P0.Q" = "Prići joj?";
"S1.P0.O1" = "Elena, zašto nisi u krevetu?";
"S1.P0.O2" = "(Promatraj iz sjene)";

/* Page 1 */
"S1.P1.N" = "Ona uzdahne i ispusti metlicu za prašinu. 'Gospodine! Ja... nisam mogla spavati. Prašina mi je smetala.' Blijeda je i izbjegava tvoj pogled.";
"S1.P1.Q" = "Vjeruješ li joj?";
"S1.P1.O1" = "Prekasno je za čišćenje";
"S1.P1.O2" = "Vrlo si predana radnica";

/* Page 2 */
"S1.P2.N" = "Gledaš kako iz pregače izvlači mali srebrni ključ. Promatra ga s mješavinom čežnje i straha prije nego što opazi tvoju sjenu.";
"S1.P2.Q" = "Iskoračiti?";
"S1.P2.O1" = "Kakav je to ključ, Elena?";
"S1.P2.O2" = "Odmah mi objasni što radiš";

/* Page 3 */
"S1.P3.N" = "Ona drhti. 'Ova kuća... krije toliko tajni, gospodine. Ponekad me guše.' Pokazuje prema starom sefu iza tvoje police s knjigama.";
"S1.P3.Q" = "Pitati za sef?";
"S1.P3.O1" = "Pripada li ključ tamo?";
"S1.P3.O2" = "Sef je zabranjena zona";

/* Page 4 */
"S1.P4.N" = "Pokušava sakriti ključ, ali on ispadne. 'Nisam lopov, obećavam! Samo... vidjela sam ga u hodniku i mislila da je vaš.'";
"S1.P4.Q" = "Podignuti ključ?";
"S1.P4.O1" = "(Podigni ga)";
"S1.P4.O2" = "Hajde da vidimo što otvara";

/* Page 5 */
"S1.P5.N" = "Ključ savršeno odgovara tajnom pretincu u sefu. Elena gleda suspregnuta daha dok otkrivaš hrpu starih, požutjelih pisama vezanih crnom vrpcom.";
"S1.P5.Q" = "Pročitati prvo pismo?";
"S1.P5.O1" = "Pročitaj ga naglas";
"S1.P5.O2" = "Pitaj Elenu što ona zna";

/* Page 6 */
"S1.P6.N" = "Elenin glas prijeđe u šapat. 'I moja majka je bila sobarica ovdje. Rekla mi je da je Gospodar čuvao uspomenu na djevojku koju je nekoć volio. Djevojku koja je izgledala poput mene.'";
"S1.P6.Q" = "Čekaj, što?";
"S1.P6.O1" = "Ispričaj mi sve";
"S1.P6.O2" = "To je nemoguće";

/* Page 7 */
"S1.P7.N" = "Pisma opisuju zabranjenu romansu. Elena zakorači bliže, dok mjesečina obasjava njezine suze. 'Nisam željela ukrasti. Samo sam htjela znati pripadam li ovdje.'";
"S1.P7.Q" = "Utješiti je?";
"S1.P7.O1" = "Stavi joj ruku na rame";
"S1.P7.O2" = "Daj joj malo prostora";

/* Page 8 */
"S1.P8.N" = "Objašnjava da je dnevnik njezine majke spominjao skrivenu istinu u ovoj sobi. 'Cijeli život živim u ovoj kući, gospodine, ali osjećam se kao duh.'";
"S1.P8.Q" = "Dati obećanje?";
"S1.P8.O1" = "Pomoći ću ti otkriti istinu";
"S1.P8.O2" = "Riješit ćemo ovo zajedno";

/* Page 9 */
"S1.P9.N" = "Sljedećih sat vremena provodite kopajući po zapisima. Pronalaziš rodni list s poznatim imenom, ali odjeljak za oca je prazan.";
"S1.P9.Q" = "Pogledati Elenu?";
"S1.P9.O1" = "Je li to mogao biti moj stric?";
"S1.P9.O2" = "Možda je bolje ne znati";

/* Page 10 */
"S1.P10.N" = "Potraga postaje intenzivna. Elena pronalazi kutijicu s nakitom skrivenu iza pisama. Unutra je medaljon s portretom žene koja izgleda kao njezina blizanka.";
"S1.P10.Q" = "Pokazati joj?";
"S1.P10.O1" = "Pogledaj ovaj medaljon";
"S1.P10.O2" = "Je li ovo tvoja majka?";

/* Page 11 */
"S1.P11.N" = "Odjednom, podne daske u hodniku zaškripe. Netko je vani. Elenine oči se rašire od panike. 'Ako nas Batler nađe...!'";
"S1.P11.Q" = "Sakriti se?";
"S1.P11.O1" = "Sakrij se u ormar s njom";
"S1.P11.O2" = "Ostani i suoči se s njim";

/* Page 12 */
"S1.P12.N" = "Koraci su sve bliže. Elena te zgrabi za rukav. 'Molim vas, gospodine, nitko ne smije znati da smo ovo našli. Opasno je za mene.'";
"S1.P12.Q" = "Reakcija?";
"S1.P12.O1" = "Ugasi svjetla";
"S1.P12.O2" = "Zaključaj vrata";

/* Page 13 */
"S1.P13.N" = "U sobi je potpuni mrak. U tijesnom prostoru čuješ Elenino ubrzano srce i miris latica ruže na njezinoj koži. Nevjerojatno ti je blizu.";
"S1.P13.Q" = "Šapnuti joj?";
"S1.P13.O1" = "Sigurna si sa mnom";
"S1.P13.O2" = "(Šuti i čekaj)";

/* Page 14 */
"S1.P14.N" = "Držiš vrata zatvorenima. Osoba vani zastane na trenutak, a zatim odlazi. Elena se nasloni na tebe, drhteći od adrenalina.";
"S1.P14.Q" = "Umiriti je?";
"S1.P14.O1" = "Otišli su";
"S1.P14.O2" = "Jesi li dobro?";

/* Page 15 */
"S1.P15.N" = "Lagano se odmakne, ali njezina ruka ostaje na tvojim prsima. 'Gospodine... oduvijek sam vam se divila izdaleka. Ova tajna... preteška je da je nosim sama.'";
"S1.P15.Q" = "Tvoji osjećaji?";
"S1.P15.O1" = "I ja sam tebe primijetio";
"S1.P15.O2" = "Ti si više od sobarice";

/* Page 16 */
"S1.P16.N" = "'Mislila sam da sam vam samo sluškinja,' šapne ona. 'Samo dio namještaja. Ali večeras... čini se kao početak nečeg stvarnog.'";
"S1.P16.Q" = "Slažeš se?";
"S1.P16.O1" = "Stvarno je, Elena";
"S1.P16.O2" = "Vidjet ćemo kamo će nas ovo odvesti";

/* Page 17 */
"S1.P17.N" = "Ona otvara medaljon. Unutra je poruka: 'Za moju kćer, pravu nasljednicu.' Elena zanijemi. Vila bi zapravo mogla pripadati njoj.";
"S1.P17.Q" = "Što to znači?";
"S1.P17.O1" = "Moramo ovo otkriti javnosti";
"S1.P17.O2" = "Trebamo to zadržati kao tajnu";

/* Page 18 */
"S1.P18.N" = "Poruka dokazuje da je Elena zakonita vlasnica imanja. Šokirano gleda oko sebe. 'Ja... ne želim kuću. Samo želim obitelj.'";
"S1.P18.Q" = "Što ti želiš?";
"S1.P18.O1" = "Sada imaš mene";
"S1.P18.O2" = "Što ćeš učiniti?";

/* Page 19 */
"S1.P19.N" = "Gleda u kamin. 'Ako ovo spalim, opet sam samo Elena. Ako zadržim, sve se mijenja. Gospodine, što da radim?'";
"S1.P19.Q" = "Savjetovati je?";
"S1.P19.O1" = "Spali to i ostani sa mnom";
"S1.P19.O2" = "Zadrži to i preuzmi svoje mjesto";

/* Page 20 */
"S1.P20.N" = "Elena drži dokaz o svom podrijetlu. 'Obiteljsko ime je prokleto, gospodine. Radije bih bila sretna nitko nego nesretna dama.'";
"S1.P20.Q" = "Tvoj izbor?";
"S1.P20.O1" = "Slijedi svoje srce";
"S1.P20.O2" = "Razmisli o svojoj budućnosti";

/* Page 21 */
"S1.P21.N" = "Ona baci papir u žeravicu. Tajna se pretvara u pepeo. Elena se smiješi, izgledajući slobodnije nego ikada prije.";
"S1.P21.Q" = "Budućnost?";
"S1.P21.O1" = "Novi početak";
"S1.P21.O2" = "Samo nas dvoje";

/* Page 22 */
"S1.P22.N" = "Ona spremi papir u prsluk. 'Onda ću postati Gospoda ove kuće. I trebat će mi partner uz mene.'";
"S1.P22.Q" = "Jesi li spreman?";
"S1.P22.O1" = "Uvijek";
"S1.P22.O2" = "Bit će to dug put";

/* Final 1 */
"S1.P23.N" = "Elena više nije tvoja sobarica. Ona je tvoja ravnopravna partnerica i tvoja tajna. Vila ostaje tvoja, ali njezino srce pripada njoj.";
"S1.P23.Q" = "KRAJ";
"S1.P23.O1" = "Ponovno pokreni priču";
"S1.P23.O2" = "Završi";

/* Final 2 */
"S1.P24.N" = "Istina izlazi na vidjelo. Elena postaje glava kućanstva. Odnosi moći su se promijenili, ali veza koju ste stvorili te noći je neraskidiva.";
"S1.P24.Q" = "KRAJ";
"S1.P24.O1" = "Ponovno pokreni priču";
"S1.P24.O2" = "Završi";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "Kiša udara po neonskim ulicama Shinjukua. Sjediš u mirnom baru kad žena u mokrom baloneru sjedne do tebe. Miriše na jasmin i barut.";
"S2.P0.Q" = "Kako započeti razgovor?";
"S2.P0.O1" = "Plati joj piće";
"S2.P0.O2" = "Teška noć, ha?";

"S2.P1.N" = "Pogleda u čašu, pa u tebe. 'Hrabar si,' šapne. Gurne mali podatkovni čip preko šanka.";
"S2.P1.Q" = "Uzeti čip?";
"S2.P1.O1" = "Uzmi ga i sakrij";
"S2.P1.O2" = "Ne želim probleme";

"S2.P2.N" = "Gorko se nasmije. 'Nemaš pojma.' Pogleda preko ramena. Dva muškarca u crnim odijelima upravo su ušla u bar.";
"S2.P2.Q" = "Pomoći joj da se sakrije?";
"S2.P2.O1" = "Prati me do stražnjih vrata";
"S2.P2.O2" = "Pravi se da smo par";

"S2.P3.N" = "Privučeš je blizu. Muškarci pretraže prostoriju i odu. Izgleda laknulo, ali ruke joj drhte. 'Ja sam Mia,' šapne.";
"S2.P3.Q" = "Pitati za opasnost?";
"S2.P3.O1" = "Tko je to bio, Mia?";
"S2.P3.O2" = "Jesmo li sada sigurni?";

"S2.P4.N" = "Muškarci prilaze, ali ti ostaješ hladnokrvan. Prolaze pokraj vas. Ona šapne: 'Spasio si me. Ja sam Mia. Ali ovaj čip... vrijedi milijun života.'";
"S2.P4.Q" = "Pitati za čip?";
"S2.P4.O1" = "Što je na njemu?";
"S2.P4.O2" = "Moramo bježati odavde";

"S2.P5.N" = "Mia gleda prema vratima. 'Korporacija Arasaka želi ovo. To nisu samo podaci, to je digitalna duša.'";
"S2.P5.Q" = "Vjeruješ li joj?";
"S2.P5.O1" = "Digitalna duša? Ozbiljno?";
"S2.P5.O2" = "Čuo sam glasine...";

"S2.P6.N" = "Mia te zgrabi za ruku. 'Nigdje nismo sigurni dok ovo ne učitamo. Moramo doći do Tech-distrikta.'";
"S2.P6.Q" = "Ići s njom?";
"S2.P6.O1" = "Odvest ću te tamo";
"S2.P6.O2" = "Samo ako mi kažeš više";

"S2.P7.N" = "Iskradate se na stražnji izlaz. Uličica je mračna i miriše na ozon. Odjednom, dron zazuji iznad vas, tražeći toplinske potpise.";
"S2.P7.Q" = "Kako izbjeći dron?";
"S2.P7.O1" = "Sakrij se pod nadstrešnicu";
"S2.P7.O2" = "Trči prema podzemnoj";

"S2.P8.N" = "Mia stane na kiši. 'Ako me uhvate, izbrisat će me. I tebe također, jer si mi pomogao.'";
"S2.P8.Q" = "Umiriti je?";
"S2.P8.O1" = "U ovome sam s tobom";
"S2.P8.O2" = "Samo se krećimo, brzo";

"S2.P9.N" = "Dron prolazi. Dolazite do tvog auta. Mia te gleda s mješavinom straha i zahvalnosti.";
"S2.P9.Q" = "Upaliti motor?";
"S2.P9.O1" = "Daj gas do daske!";
"S2.P9.O2" = "Vozi polako, stopi se s okolinom";

"S2.P10.N" = "Jedva stižete do stanice. Gužva je ogromna, što je savršen zaklon. Mia ostaje blizu, ramenom dodirujući tvoje.";
"S2.P10.Q" = "Nastaviti kretanje?";
"S2.P10.O1" = "Idemo na brzi vlak";
"S2.P10.O2" = "Hodajmo kroz tunele";

"S2.P11.N" = "Prolazite kroz nebodersku četvrt. Holografske reklame obasjavaju Mijino lice ružičastom i plavom bojom.";
"S2.P11.Q" = "Prekinuti tišinu?";
"S2.P11.O1" = "Zašto ja, Mia?";
"S2.P11.O2" = "Reci mi nešto o čipu";

"S2.P12.N" = "Grad se čini kao labirint. Stajete u skrivenom ramen shopu da se nakratko odmorite.";
"S2.P12.Q" = "Promatrati ulicu?";
"S2.P12.O1" = "Provjeri prati li nas tko";
"S2.P12.O2" = "Razgovaraj s Mijom";

"S2.P13.N" = "Mia obori pogled. 'Bio si jedini koji večeras nije izgledao kao grabežljivac. Trebao mi je čovjek, a ne plaćenik.'";
"S2.P13.Q" = "Odgovoriti ljubazno?";
"S2.P13.O1" = "Drago mi je da sam bio tamo";
"S2.P13.O2" = "Ja sam samo tip iz bara";

"S2.P14.N" = "Mia dodirne čip. 'Ovo je svijest moje sestre. Bila je netrunnerica koja je vidjela previše. 'Ugasili' su joj tijelo.'";
"S2.P14.Q" = "Izraziti suosjećanje?";
"S2.P14.O1" = "To je strašno...";
"S2.P14.O2" = "Može li se spasiti?";

"S2.P15.N" = "Obriše suzu. 'Mjesto za učitavanje je u starom TV tornju. Ali most je blokiran policijskom zasjedom.'";
"S2.P15.Q" = "Kako prijeći?";
"S2.P15.O1" = "Iskoristi svoje hakerske vještine";
"S2.P15.O2" = "Podmiti stražare";

"S2.P16.N" = "Mia ti pokazuje kartu. 'Ako idemo kroz kanalizaciju, sigurnije je, ali put je dug.'";
"S2.P16.Q" = "Odabrati put?";
"S2.P16.O1" = "Idemo kroz kanalizaciju";
"S2.P16.O2" = "Ne, trebamo brzinu";

"S2.P17.N" = "Prljavo je i mračno, ali djeluje. Mia se oslanja na tvoje vodstvo. Osjećaš težinu njezina povjerenja.";
"S2.P17.Q" = "Pomoći joj da prijeđe procjep?";
"S2.P17.O1" = "Pruži joj ruku";
"S2.P17.O2" = "Vodi put";

"S2.P18.N" = "Na mostu je kaos. Koristiš pomutnju da se provučeš. Mijino srce kuca toliko brzo da ga gotovo čuješ.";
"S2.P18.Q" = "Umiriti je?";
"S2.P18.O1" = "Skoro smo stigli";
"S2.P18.O2" = "Ostani fokusirana, Mia";

"S2.P19.N" = "TV toranj se uzdiže ispred vas. To je relikt starog svijeta, okružen modernim čelikom. Mia izgleda iscrpljeno.";
"S2.P19.Q" = "Ponuditi odmor?";
"S2.P19.O1" = "Odmorimo pet minuta";
"S2.P19.O2" = "Izgurajmo do kraja";

"S2.P20.N" = "Dolazite do podnožja tornja. 'Lift ne radi,' uzdahne Mia. 'Moramo se penjati.'";
"S2.P20.Q" = "Ohrabriti je?";
"S2.P20.O1" = "Korak po korak";
"S2.P20.O2" = "Ja ću nositi opremu";

"S2.P21.N" = "Sjedite na stubama. Mia se nasloni na tebe. 'Ako uspijemo... što ćeš raditi sutra?'";
"S2.P21.Q" = "Razmišljati o budućnosti?";
"S2.P21.O1" = "Možda možemo na kavu";
"S2.P21.O2" = "Bit ću sretan samo da zaspim";

"S2.P22.N" = "Uspon je brutalan. Na pola puta čujete sirene ispod sebe. Pronašli su tvoj auto.";
"S2.P22.Q" = "Požuriti?";
"S2.P22.O1" = "Udvostruči tempo!";
"S2.P22.O2" = "Pronađi mjesto za skrivanje";

"S2.P23.N" = "Stižete u serversku sobu. Zrak je hladan i bruji od struje. Mia spaja čip. 'Inicijalizacija...' kaže ona.";
"S2.P23.Q" = "Gledati u ekran?";
"S2.P23.O1" = "Čuvaj vrata";
"S2.P23.O2" = "Ostani uz Miju";

"S2.P24.N" = "Terminal je drevan, ali radi. Mijini prsti lete po tipkovnici. 'Vatrozid je ogroman!'";
"S2.P24.Q" = "Pomoći joj s hakiranjem?";
"S2.P24.O1" = "Premosti napajanje";
"S2.P24.O2" = "Drži je stabilnom";

"S2.P25.N" = "Vrata zapište. Arasakin taktički tim je ovdje. Izvlačiš oružje. 'Samo još dvije minute!' vrišti Mia.";
"S2.P25.Q" = "Držati položaj?";
"S2.P25.O1" = "Otvori vatru!";
"S2.P25.O2" = "Barikadiraj vrata";

"S2.P26.N" = "Mijine oči svijetle plavo. Duboko je u mreži. Vojnici probijaju stakleni strop.";
"S2.P26.Q" = "Zaštititi Miju?";
"S2.P26.O1" = "Zaštiti je svojim tijelom";
"S2.P26.O2" = "Povuci je u zaklon";

"S2.P27.N" = "Zasljepljujući bljesak svjetlosti. Učitavanje je na 100%. Vojnici se smrzavaju—njihova kibernetika je ometana iz mreže.";
"S2.P27.Q" = "Provjeriti Miju?";
"S2.P27.O1" = "Je li gotovo?";
"S2.P27.O2" = "Jesi li dobro?";

"S2.P28.N" = "Sve se gasi. Zatim se svaki ekran u Tokiju pali s jednom porukom: 'SLOBODA'. Mia se sruši u tvoje naručje.";
"S2.P28.Q" = "Probuditi je?";
"S2.P28.O1" = "Mia! Reci nešto!";
"S2.P28.O2" = "Čvrsto je zagrli";

"S2.P29.N" = "Sunce izlazi nad drugačijim Tokijom. Mia se smiješi, oči su joj opet normalne. 'Sigurna je. Sigurni smo.'";
"S2.P29.Q" = "KRAJ";
"S2.P29.O1" = "Ponovno pokreni priču";
"S2.P29.O2" = "Završi";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "Zadnja noć ljetnog kampa. Logorska vatra se polako gasi, a miris borovih iglica je posvuda. Yuki, inače sramežljiva, uhvati tvoj pogled i pokaže prema mračnoj stazi koja vodi do jezera.";
"S3.P0.Q" = "Hoćeš li je slijediti u noć?";
"S3.P0.O1" = "Ovo sam čekao";
"S3.P0.O2" = "Naravno, idemo";

"S3.P1.N" = "Stižeš je. Šuma odzvanja zvukom zrikavaca. Yukina ruka povremeno okrzne tvoju dok hodate. Izgleda nervozno.";
"S3.P1.Q" = "Kako prekinuti tišinu?";
"S3.P1.O1" = "Čvrsto je uhvati za ruku";
"S3.P1.O2" = "Pitaj je što joj je na umu";

"S3.P2.N" = "Hodate jedno uz drugo. Mjesečina jedva probija guste krošnje. Yuki te gleda krajičkom oka, lagano se smješkajući. 'Nisam mislila da ćeš stvarno doći,' šapne.";
"S3.P2.Q" = "Tvoj odgovor?";
"S3.P2.O1" = "To ne bih propustio";
"S3.P2.O2" = "Bio sam znatiželjan";

"S3.P3.N" = "Dolazite do mola. Voda je poput tamnog ogledala koje odražava beskrajno more zvijezda. Yuki izuje cipele i sjedne na rub, mašući nogama.";
"S3.P3.Q" = "Sjesti blizu nje?";
"S3.P3.O1" = "Sjedni tik do nje";
"S3.P3.O2" = "Daj joj malo prostora";

"S3.P4.N" = "Mol škripi pod tvojom težinom. Hladan zrak s jezera natjera Yuki da lagano zadrhti. Ne miče se dok joj prilaziš.";
"S3.P4.Q" = "Ponuditi jaknu?";
"S3.P4.O1" = "Ogrni je svojom jaknom";
"S3.P4.O2" = "Samo sjedi i pričaj";

"S3.P5.N" = "Yuki gleda u zvijezde. 'Sjećaš li se našeg prvog dana ovdje?' pita ona. 'Pomogao si mi s torbama kad su svi ostali bili zauzeti.'";
"S3.P5.Q" = "Sjećaš li se?";
"S3.P5.O1" = "Sjećam se svakog detalja";
"S3.P5.O2" = "Čini se kao da je bilo davno";

"S3.P6.N" = "Tiho se nasmije. 'Tada sam se tako bojala. Ali kad sam te vidjela, osjetila sam da ovdje pripadam.' Gleda u vodu.";
"S3.P6.Q" = "Priznati osjećaje?";
"S3.P6.O1" = "I ja sam se osjećao isto";
"S3.P6.O2" = "Drago mi je da sam mogao pomoći";

"S3.P7.N" = "Noć je potpuno mirna. Odjednom, Yuki ustane. 'Voda izgleda tako primamljivo. Hoćemo li... ući?' pita s vragolastim sjajem u očima.";
"S3.P7.Q" = "Jesi li dovoljno hrabar?";
"S3.P7.O1" = "Skočimo unutra!";
"S3.P7.O2" = "Prehladno je, Yuki";

"S3.P8.N" = "Gleda u jezero, pa u tebe. 'Želim učiniti nešto hrabro večeras. Nešto čega ću se sjećati cijelu zimu.'";
"S3.P8.Q" = "Ohrabriti je?";
"S3.P8.O1" = "Skoči sa mnom?";
"S3.P8.O2" = "Ostanimo ovdje";

"S3.P9.N" = "PLJAS! Voda je ledena, ali osnažuje. Ti i Yuki izranjate, hvatate zrak i smijete se, prskajući jedno drugo poput djece.";
"S3.P9.Q" = "Plivati bliže njoj?";
"S3.P9.O1" = "Privuci je u zagrljaj";
"S3.P9.O2" = "Nastavi je prskati!";

"S3.P10.N" = "Ostajete na molu. Pričate satima o svemu—školi, roditeljima, budućnosti. Veza između vas postaje jača u tišini.";
"S3.P10.Q" = "Približiti se?";
"S3.P10.O1" = "Nasloni glavu na njezinu";
"S3.P10.O2" = "Pogledaj je u oči";

"S3.P11.N" = "Atmosfera se mijenja. Yuki prestane pričati. U prigušenom svjetlu, njezine oči traže tvoje. 'Ne želim se sutra vratiti u grad,' šapne.";
"S3.P11.Q" = "Što kažeš?";
"S3.P11.O1" = "Vidjet ćemo se tamo";
"S3.P11.O2" = "Ne razmišljajmo o sutra";

"S3.P12.N" = "Yuki duboko udahne. 'Ako ovo ne kažem sada, nikada neću. Sviđaš mi se još od onog prvog dana na autobusnoj stanici.'";
"S3.P12.Q" = "Kako reagiraš?";
"S3.P12.O1" = "I ti se meni sviđaš";
"S3.P12.O2" = "Napokon, istina!";

"S3.P13.N" = "Posegne u džep i izvuče ručno izrađenu narukvicu prijateljstva. Plavo-bijela je, u bojama jezera. 'Napravila sam ovo za tebe,' kaže sramežljivo.";
"S3.P13.Q" = "Prihvatiti dar?";
"S3.P13.O1" = "Pusti je da ti je zaveže";
"S3.P13.O2" = "Poljubi je umjesto toga";

"S3.P14.N" = "Narukvica je jednostavna, ali znaš da su joj trebali sati da je napravi. Čeka tvoju reakciju, dok joj donja usna lagano drhti.";
"S3.P14.Q" = "Tvoj potez?";
"S3.P14.O1" = "Zahvali joj zagrljajem";
"S3.P14.O2" = "Reci joj da je savršena";

"S3.P15.N" = "Yuki se nasmije, pravim, blistavim osmijehom. 'Tako sam se brinula da ćeš misliti da je djetinjasto.' Gleda u mjesec, sada s više samopouzdanja.";
"S3.P15.Q" = "Dati obećanje?";
"S3.P15.O1" = "Obećaj da ćeš je zvati svaki dan";
"S3.P15.O2" = "Obećaj da ćeš je brzo posjetiti";

"S3.P16.N" = "Zrak titra od napetosti. Yuki ti gleda u usne. Svijet oko vas nestaje; ostajete samo vas dvoje i ljetna noć.";
"S3.P16.Q" = "Je li to taj trenutak?";
"S3.P16.O1" = "Nagnet se za poljubac";
"S3.P16.O2" = "Šapni joj nešto slatko";

"S3.P17.N" = "Baš tada, zvijezda padalica proleti nebom, ostavljajući srebrni trag. Yuki uzdahne. 'Brzo! Zamisli želju!' povikne.";
"S3.P17.Q" = "Što želiš?";
"S3.P17.O1" = "Poželi zajedničku budućnost";
"S3.P17.O2" = "Poželi da ova noć potraje";

"S3.P18.N" = "Zvijezda nestane brže nego što je došla. Yuki čvrsto sklopi oči. 'Poželjela sam nešto važno,' kaže crveneći se.";
"S3.P18.Q" = "Pitati što je to bilo?";
"S3.P18.O1" = "Reci mi svoju želju";
"S3.P18.O2" = "Mislim da znam što je to bilo";

"S3.P19.N" = "Vatra u kampu se sada potpuno ugasila. Krećete natrag, ruku pod ruku. Šuma se čini drugačijom—manje strašnom, više čarobnom.";
"S3.P19.Q" = "Hodati polako?";
"S3.P19.O1" = "Idimo onim duljim putem";
"S3.P19.O2" = "Uživaj u tišini";

"S3.P20.N" = "Prolazite pored onog starog hrasta gdje ste se prvi put sreli. Yuki zastane na trenutak. 'Sve će se promijeniti, zar ne?' tiho upita.";
"S3.P20.Q" = "Utješiti je?";
"S3.P20.O1" = "Promjena može biti dobra";
"S3.P20.O2" = "Ne mora se sve promijeniti";

"S3.P21.N" = "Kabine kampa su na vidiku. Ostali spavaju. Yuki stane pred svojim vratima. Ne želi ti ispustiti ruku.";
"S3.P21.Q" = "Još jedna stvar?";
"S3.P21.O1" = "Zatraži poljubac za kraj";
"S3.P21.O2" = "Pitaj je za broj telefona";

"S3.P22.N" = "Yuki oklijeva na vratima. Svjetlo s trijema baca meki sjaj na njezino lice. 'Hvala ti za večeras. Bila je ovo najbolja noć u mom životu.'";
"S3.P22.Q" = "Oprostiti se?";
"S3.P22.O1" = "Vidimo se ujutro";
"S3.P22.O2" = "Laku noć, Yuki";

"S3.P23.N" = "Izlazak sunca. U kampu je vreva, ljudi pakiraju torbe i ulaze u autobuse. Tražiš Yuki u gužvi, srce ti ubrzano kuca.";
"S3.P23.Q" = "Možeš li je pronaći?";
"S3.P23.O1" = "Pogledaj kod autobusa";
"S3.P23.O2" = "Provjeri mol još jednom";

"S3.P24.N" = "Motori autobusa bruje. Vidiš je! Stoji kod kapije i mahnito gleda oko sebe dok te ne ugleda.";
"S3.P24.Q" = "Potrčati k njoj?";
"S3.P24.O1" = "Dotrči i zagrli je";
"S3.P24.O2" = "Mahni joj i nasmiješi se";

"S3.P25.N" = "Stižeš do nje baš na vrijeme. Šapne ti nešto na uho što nikada nećeš zaboraviti. 'Ne dopusti da ovo ostane samo ljetna uspomena.'";
"S3.P25.Q" = "Tvoj odgovor?";
"S3.P25.O1" = "To je obećanje";
"S3.P25.O2" = "Vidimo se sljedeći vikend";

"S3.P26.N" = "Vozač trubi. Yuki mora ići. Šalje ti poljubac dok ulazi. Stojiš tamo, gledajući kako autobus nestaje u prašini.";
"S3.P26.Q" = "Kako se osjećaš?";
"S3.P26.O1" = "Sretno i puno nade";
"S3.P26.O2" = "Tužno, ali ispunjeno";

"S3.P27.N" = "Mjesecima kasnije. U gradu si, telefon ti vibrira. To je fotografija od Yuki—nosi narukvicu koju ste podijelili. Ljeto zapravo nikada nije završilo.";
"S3.P27.Q" = "KRAJ";
"S3.P27.O1" = "Ponovno pokreni priču";
"S3.P27.O2" = "Završi";

"S3.P28.N" = "Gledaš narukvicu na svom zapešću. Malo je istrošena, ali sjećanja su svježa. Ponekad je jedno ljeto dovoljno za cijeli život.";
"S3.P28.Q" = "KRAJ";
"S3.P28.O1" = "Pokušaj ponovno";
"S3.P28.O2" = "Završi";

