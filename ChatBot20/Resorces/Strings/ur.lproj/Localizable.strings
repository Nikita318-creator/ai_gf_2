/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "حویلی میں گہرا سکوت ہے جب تم واپس لوٹتے ہو۔ تمہارے اسٹڈی روم میں ایک ہلکی سی روشنی ٹمٹما رہی ہے۔ تم دیکھتے ہو کہ تمہاری سب سے خاموش خادمہ، ایلینا، رات کے دو بجے گھبرائی ہوئی تمہاری میز صاف کر رہی ہے۔";
"S1.P0.Q" = "اس کے پاس جائیں؟";
"S1.P0.O1" = "ایلینا، تم اب تک سوئی کیوں نہیں؟";
"S1.P0.O2" = "(اندھیرے سے خاموشی سے دیکھیں)";

/* Page 1 */
"S1.P1.N" = "وہ اچھل پڑتی ہے اور اس کے ہاتھ سے جھاڑن گر جاتا ہے۔ 'صاحب! میں... مجھے نیند نہیں آ رہی تھی۔ دھول مٹی دیکھ کر رہا نہیں گیا۔' اس کا چہرہ زرد ہے اور وہ نظریں چرانے کی کوشش کر رہی ہے۔";
"S1.P1.Q" = "اس کی بات کا یقین کریں؟";
"S1.P1.O1" = "صفائی کے لیے یہ وقت بہت دیر ہو چکی ہے";
"S1.P1.O2" = "تم واقعی اپنے کام کے لیے بہت مخلص ہو";

/* Page 2 */
"S1.P2.N" = "تم دیکھتے ہو کہ وہ اپنے ایپرن سے ایک چھوٹی چاندی کی چابی نکالتی ہے۔ وہ اسے حسرت اور خوف کے ملے جلے تاثرات سے دیکھ رہی ہے، پھر اچانک اسے تمہارا سایہ نظر آتا ہے۔";
"S1.P2.Q" = "آگے بڑھیں؟";
"S1.P2.O1" = "ایلینا، یہ چابی کیسی ہے؟";
"S1.P2.O2" = "فوراً وضاحت کرو کہ یہ کیا ہے";

/* Page 3 */
"S1.P3.N" = "وہ کانپنے لگتی ہے۔ 'اس گھر کے بہت سے راز ہیں صاحب۔ کبھی کبھی ان کا بوجھ مجھ سے سہا نہیں جاتا۔' وہ تمہاری کتابوں کی الماری کے پیچھے پرانے سیف (Safe) کی طرف اشارہ کرتی ہے۔";
"S1.P3.Q" = "سیف کے بارے میں پوچھیں؟";
"S1.P3.O1" = "کیا یہ چابی اسی سیف کی ہے؟";
"S1.P3.O2" = "اس سیف کو ہاتھ لگانا منع ہے";

/* Page 4 */
"S1.P4.N" = "وہ چابی چھپانے کی کوشش کرتی ہے، لیکن وہ گر جاتی ہے۔ 'میں چور نہیں ہوں، میں وعدہ کرتی ہوں! بس... مجھے یہ راہداری میں ملی اور مجھے لگا یہ آپ کی ہوگی۔'";
"S1.P4.Q" = "چابی اٹھائیں؟";
"S1.P4.O1" = "(چابی اٹھائیں)";
"S1.P4.O2" = "چلو دیکھتے ہیں کہ یہ کیا کھولتی ہے";

/* Page 5 */
"S1.P5.N" = "چابی سیف کے ایک خفیہ خانے میں فٹ آ جاتی ہے۔ ایلینا سانس روکے دیکھ رہی ہے جب تم سیاہ ربن سے بندھے پرانے زرد خطوط کا ایک پلندہ نکالتے ہو۔";
"S1.P5.Q" = "سب سے اوپر والا خط پڑھیں؟";
"S1.P5.O1" = "اسے بلند آواز میں پڑھیں";
"S1.P5.O2" = "ایلینا سے پوچھیں کہ وہ کیا جانتی ہے";

/* Page 6 */
"S1.P6.N" = "ایلینا کی آواز سرگوشی میں بدل جاتی ہے۔ 'میری ماں بھی یہاں خادمہ تھیں۔ انہوں نے مجھے بتایا تھا کہ بڑے صاحب نے ایک ایسی لڑکی کی یادیں محفوظ کر رکھی ہیں جس سے وہ پیار کرتے تھے۔ ایک ایسی لڑکی جو بالکل میرے جیسی دکھتی تھی۔'";
"S1.P6.Q" = "کیا؟ ایک منٹ...";
"S1.P6.O1" = "مجھے سب کچھ تفصیل سے بتاؤ";
"S1.P6.O2" = "یہ تو ناممکن ہے";

/* Page 7 */
"S1.P7.N" = "خطوط ایک ممنوعہ محبت کی داستان بیان کرتے ہیں۔ ایلینا قریب آتی ہے، چاند کی روشنی اس کے آنسوؤں میں جھلک رہی ہے۔ 'میں چوری نہیں کرنا چاہتی تھی۔ میں بس یہ جاننا چاہتی تھی کہ کیا میرا اس گھر سے کوئی تعلق ہے یا نہیں۔'";
"S1.P7.Q" = "اسے دلاسہ دیں؟";
"S1.P7.O1" = "اس کے کندھے پر اپنا ہاتھ رکھیں";
"S1.P7.O2" = "اسے تھوڑا وقت اور جگہ دیں";

/* Page 8 */
"S1.P8.N" = "وہ بتاتی ہے کہ اس کی ماں کی ڈائری میں اس کمرے کے کسی خفیہ سچ کا ذکر تھا۔ 'میں پوری زندگی اسی گھر میں رہی ہوں صاحب، لیکن میں نے ہمیشہ خود کو ایک سایہ محسوس کیا ہے۔'";
"S1.P8.Q" = "کوئی وعدہ کریں؟";
"S1.P8.O1" = "میں سچ تلاش کرنے میں تمہاری مدد کروں گا";
"S1.P8.O2" = "ہم مل کر اس پہیلی کو حل کریں گے";

/* Page 9 */
"S1.P9.N" = "تم اگلا ایک گھنٹہ پرانے ریکارڈز چھاننے میں گزارتے ہو۔ تمہیں ایک پیدائشی سرٹیفکیٹ ملتا ہے جس پر ایک جانا پہچانا نام ہے، لیکن والد والا خانہ خالی ہے۔";
"S1.P9.Q" = "ایلینا کی طرف دیکھیں؟";
"S1.P9.O1" = "کیا یہ میرے چچا ہو سکتے ہیں؟";
"S1.P9.O2" = "شاید نہ جاننا ہی بہتر ہے";

/* Page 10 */
"S1.P10.N" = "تلاش تیز ہو جاتی ہے۔ ایلینا کو خطوط کے پیچھے چھپا ایک زیور کا ڈبہ ملتا ہے۔ اس کے اندر ایک لاکٹ ہے جس میں ایک عورت کی تصویر ہے جو بالکل ایلینا کی ہم شکل ہے۔";
"S1.P10.Q" = "اسے دکھائیں؟";
"S1.P10.O1" = "یہ لاکٹ دیکھو";
"S1.P10.O2" = "کیا یہ تمہاری ماں کی تصویر ہے؟";

/* Page 11 */
"S1.P11.N" = "اچانک، باہر راہداری میں فرش کے تختے کی چرچراہٹ سنائی دیتی ہے۔ کوئی وہاں موجود ہے۔ ایلینا کی آنکھیں خوف سے پھیل جاتی ہیں۔ 'اگر بٹلر نے ہمیں دیکھ لیا تو...!'";
"S1.P11.Q" = "چھپ جائیں؟";
"S1.P11.O1" = "اس کے ساتھ الماری میں چھپ جائیں";
"S1.P11.O2" = "وہیں رکیں اور مقابلہ کریں";

/* Page 12 */
"S1.P12.N" = "قدموں کی آواز قریب آ رہی ہے۔ ایلینا تمہاری آستین پکڑ لیتی ہے۔ 'خدارا صاحب، کسی کو پتہ نہیں چلنا چاہیے کہ ہمیں یہ سب ملا ہے۔ یہ میرے لیے خطرناک ہو سکتا ہے۔'";
"S1.P12.Q" = "ردعمل؟";
"S1.P12.O1" = "بتیاں گل کر دیں";
"S1.P12.O2" = "دروازہ بند کر کے لاک کر دیں";

/* Page 13 */
"S1.P13.N" = "کمرے میں گھپ اندھیرا ہے۔ اس تنگ جگہ میں تمہیں ایلینا کے دل کی دھڑکن اور اس کے بدن سے آتی گلاب کی خوشبو محسوس ہو رہی ہے۔ وہ تمہارے بہت قریب ہے۔";
"S1.P13.Q" = "اس سے سرگوشی کریں؟";
"S1.P13.O1" = "تم میرے ساتھ محفوظ ہو";
"S1.P13.O2" = "(خاموش رہ کر انتظار کریں)";

/* Page 14 */
"S1.P14.N" = "تم دروازہ مضبوطی سے تھامے رکھتے ہو۔ باہر موجود شخص لمحہ بھر رکتا ہے اور پھر چلا جاتا ہے۔ ایلینا تمہارے سہارے کھڑی ہے، اس کا جسم گھبراہٹ سے تھرتھرا رہا ہے۔";
"S1.P14.Q" = "اسے تسلی دیں؟";
"S1.P14.O1" = "وہ اب جا چکے ہیں";
"S1.P14.O2" = "کیا تم ٹھیک ہو؟";

/* Page 15 */
"S1.P15.N" = "وہ تھوڑا پیچھے ہٹتی ہے، لیکن اس کا ہاتھ اب بھی تمہارے سینے پر ہے۔ 'صاحب... میں نے ہمیشہ آپ کو دور سے ہی چاہا ہے۔ یہ راز... اکیلے اٹھانا میرے لیے بہت مشکل تھا۔'";
"S1.P15.Q" = "تمہارے جذبات؟";
"S1.P15.O1" = "میری نظریں بھی تم پر ہی تھیں";
"S1.P15.O2" = "تم محض ایک خادمہ سے بڑھ کر ہو";

/* Page 16 */
"S1.P16.N" = "'مجھے لگا تھا میں آپ کے لیے صرف ایک ملازمہ ہوں،' وہ سرگوشی کرتی ہے۔ 'بس اس گھر کے فرنیچر کا ایک حصہ۔ لیکن آج کی رات کچھ حقیقی سا لگ رہا ہے۔'";
"S1.P16.Q" = "اتفاق کریں؟";
"S1.P16.O1" = "یہ سب حقیقی ہے، ایلینا";
"S1.P16.O2" = "دیکھتے ہیں یہ سب ہمیں کہاں لے جاتا ہے";

/* Page 17 */
"S1.P17.N" = "وہ لاکٹ کھولتی ہے۔ اندر ایک چھوٹا سا رقعہ ہے: 'میری بیٹی کے لیے، جو اس گھر کی اصل وارث ہے۔' ایلینا کے منہ سے چیخ نکل جاتی ہے۔ یہ حویلی اصل میں اس کی ملکیت ہو سکتی ہے۔";
"S1.P17.Q" = "اب کیا ہوگا؟";
"S1.P17.O1" = "ہمیں یہ سچ سب کو بتانا ہوگا";
"S1.P17.O2" = "ہمیں اسے راز ہی رکھنا چاہیے";

/* Page 18 */
"S1.P18.N" = "وہ تحریر ثابت کرتی ہے کہ ایلینا اس جائیداد کی اصل مالک ہے۔ وہ حیرت زدہ ہو کر کمرے کو دیکھتی ہے۔ 'میں... مجھے یہ گھر نہیں چاہیے۔ مجھے بس ایک خاندان چاہیے تھا۔'";
"S1.P18.Q" = "تم کیا چاہتے ہو؟";
"S1.P18.O1" = "اب میں تمہارے ساتھ ہوں";
"S1.P18.O2" = "اب تم کیا کرو گی؟";

/* Page 19 */
"S1.P19.N" = "وہ آتش دان کی طرف دیکھتی ہے۔ 'اگر میں اسے جلا دوں، تو میں دوبارہ صرف ایلینا بن جاؤں گی۔ اگر اسے رکھ لوں، تو سب کچھ بدل جائے گا۔ صاحب، میں کیا کروں؟'";
"S1.P19.Q" = "مشورہ دیں؟";
"S1.P19.O1" = "اسے جلا دو اور میرے پاس ہی رہو";
"S1.P19.O2" = "اسے محفوظ رکھو اور اپنا حق لو";

/* Page 20 */
"S1.P20.N" = "ایلینا کے ہاتھ میں اس کے خاندان کا ثبوت ہے۔ 'خاندانی ناموں کو نظر لگ جاتی ہے صاحب۔ میں ایک امیر اداس عورت بننے کے بجائے ایک خوش باش عام لڑکی بننا پسند کروں گی۔'";
"S1.P20.Q" = "تمہارا فیصلہ؟";
"S1.P20.O1" = "اپنے دل کی بات مانو";
"S1.P20.O2" = "اپنے مستقبل کے بارے میں سوچو";

/* Page 21 */
"S1.P21.N" = "وہ کاغذ گرتی ہوئی آگ میں ڈال دیتی ہے۔ وہ راز راکھ بن جاتا ہے۔ ایلینا مسکراتی ہے، وہ پہلے سے کہیں زیادہ آزاد لگ رہی ہے۔";
"S1.P21.Q" = "مستقبل؟";
"S1.P21.O1" = "ایک نئی شروعات";
"S1.P21.O2" = "صرف تم اور میں";

/* Page 22 */
"S1.P22.N" = "وہ کاغذ اپنے لباس میں چھپا لیتی ہے۔ 'پھر میں اس گھر کی مالکن بن کر دکھاؤں گی۔ اور مجھے اپنے ساتھ ایک جیون ساتھی کی ضرورت ہوگی۔'";
"S1.P22.Q" = "کیا تم تیار ہو؟";
"S1.P22.O1" = "ہمیشہ";
"S1.P22.O2" = "یہ راستہ طویل اور مشکل ہوگا";

/* Final 1 */
"S1.P23.N" = "ایلینا اب تمہاری خادمہ نہیں رہی۔ وہ تمہاری ساتھی، تمہارا برابر کا حصہ اور تمہارا راز ہے۔ حویلی تمہاری رہی، لیکن اس گھر کی روح اب ایلینا ہے۔";
"S1.P23.Q" = "اختتام";
"S1.P23.O1" = "کہانی دوبارہ شروع کریں";
"S1.P23.O2" = "ختم کریں";

/* Final 2 */
"S1.P24.N" = "سچ سامنے آ گیا۔ ایلینا گھر کی سربراہ بن گئی۔ رشتے کی نوعیت بدل گئی، لیکن اس رات جو بندھن تم دونوں کے درمیان بنا، وہ اٹوٹ ہے۔";
"S1.P24.Q" = "اختتام";
"S1.P24.O1" = "کہانی دوبارہ شروع کریں";
"S1.P24.O2" = "ختم کریں";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "شنجوکو کی نیون روشن گلیوں پر بارش برس رہی ہے۔ تم ایک خاموش بار میں بیٹھے ہو جب ایک عورت بھیگے ہوئے کوٹ میں تمہارے ساتھ آ کر بیٹھتی ہے۔ اس سے چنبیلی اور بارود کی ملی جلی خوشبو آ رہی ہے۔";
"S2.P0.Q" = "گفتگو کا آغاز کیسے کریں گے؟";
"S2.P0.O1" = "اسے ایک ڈرنک پیش کریں";
"S2.P0.O2" = "لگتا ہے رات کافی بھاری گزری؟";

"S2.P1.N" = "وہ پہلے گلاس کو دیکھتی ہے، پھر تمہیں۔ 'تم کافی بہادر ہو،' وہ سرگوشی کرتی ہے اور کاؤنٹر پر ایک چھوٹی ڈیٹا چپ تمہاری طرف سرکاتی ہے۔";
"S2.P1.Q" = "چپ اٹھائیں؟";
"S2.P1.O1" = "اسے اٹھا کر چھپا لیں";
"S2.P1.O2" = "مجھے کسی مصیبت میں نہیں پڑنا";

"S2.P2.N" = "وہ ایک تلخ قہقہہ لگاتی ہے۔ 'تمہیں اندازہ بھی نہیں ہے۔' وہ مڑ کر اپنے کندھے کے پیچھے دیکھتی ہے۔ سیاہ سوٹ میں ملبوس دو آدمی بار میں داخل ہوئے ہیں۔";
"S2.P2.Q" = "اسے چھپنے میں مدد دیں؟";
"S2.P2.O1" = "پچھلے دروازے سے میرے پیچھے آؤ";
"S2.P2.O2" = "ایسا ظاہر کرو جیسے ہم ایک جوڑا ہیں";

"S2.P3.N" = "تم اسے اپنے قریب کر لیتے ہو۔ وہ آدمی کمرے کا جائزہ لیتے ہیں اور چلے جاتے ہیں۔ اس کے چہرے پر سکون آتا ہے لیکن ہاتھ اب بھی کانپ رہے ہیں۔ 'میں میا ہوں،' وہ سرگوشی کرتی ہے۔";
"S2.P3.Q" = "خطرے کے بارے میں پوچھیں؟";
"S2.P3.O1" = "وہ کون لوگ تھے، میا؟";
"S2.P3.O2" = "کیا اب ہم محفوظ ہیں؟";

"S2.P4.N" = "وہ آدمی قریب آتے ہیں، لیکن تم خود کو پرسکون ظاہر کرتے ہو۔ وہ پاس سے گزر جاتے ہیں۔ وہ سرگوشی کرتی ہے: 'تم نے میری جان بچا لی۔ میرا نام میا ہے۔ لیکن یہ چپ... یہ لاکھوں جانوں سے زیادہ قیمتی ہے۔'";
"S2.P4.Q" = "چپ کے بارے میں پوچھیں؟";
"S2.P4.O1" = "اس میں کیا ہے؟";
"S2.P4.O2" = "ہمیں یہاں سے نکلنا چاہیے";

"S2.P5.N" = "میا دروازے کی طرف دیکھتی ہے۔ 'اراساکا کارپوریشن اسے ہر قیمت پر چاہتی ہے۔ یہ صرف ڈیٹا نہیں ہے، یہ ایک ڈیجیٹل روح ہے۔'";
"S2.P5.Q" = "یقین کریں؟";
"S2.P5.O1" = "ڈیجیٹل روح؟ کیا واقعی؟";
"S2.P5.O2" = "میں نے کچھ افواہیں سنی تھیں...";

"S2.P6.N" = "میا تمہارا ہاتھ تھام لیتی ہے۔ 'جب تک ہم اسے اپلوڈ نہیں کر دیتے، کہیں بھی امان نہیں۔ ہمیں ٹیک ڈسٹرکٹ پہنچنا ہوگا۔'";
"S2.P6.Q" = "اس کے ساتھ چلیں؟";
"S2.P6.O1" = "میں تمہیں وہاں لے جاؤں گا";
"S2.P6.O2" = "صرف تب، اگر تم مجھے مزید تفصیل بتاؤ";

"S2.P7.N" = "تم پچھلے راستے سے نکل جاتے ہو۔ گلی اندھیری ہے اور وہاں عجیب سی بو ہے۔ اچانک ایک ڈرون سر کے اوپر سے گزرتا ہے جو انسانی حرارت کو تلاش کر رہا ہے۔";
"S2.P7.Q" = "ڈرون سے کیسے بچیں گے؟";
"S2.P7.O1" = "سائے میں چھپ جائیں";
"S2.P7.O2" = "سب وے کی طرف بھاگیں";

"S2.P8.N" = "میا بارش میں رک جاتی ہے۔ 'اگر انہوں نے مجھے پکڑ لیا، تو وہ میرا وجود مٹا دیں گے۔ اور تمہارا بھی، کیونکہ تم نے میری مدد کی۔'";
"S2.P8.Q" = "اسے حوصلہ دیں؟";
"S2.P8.O1" = "میں اس مشکل میں تمہارے ساتھ ہوں";
"S2.P8.O2" = "بس تیزی سے قدم بڑھاؤ";

"S2.P9.N" = "ڈرون گزر جاتا ہے۔ تم اپنی کار تک پہنچ جاتے ہو۔ میا تمہیں خوف اور شکر گزاری کے ملے جلے جذبات سے دیکھتی ہے۔";
"S2.P9.Q" = "انجن اسٹارٹ کریں؟";
"S2.P9.O1" = "تیزی سے گاڑی بھگائیں!";
"S2.P9.O2" = "آہستہ چلائیں تاکہ شک نہ ہو";

"S2.P10.N" = "تم بمشکل اسٹیشن پہنچتے ہو۔ وہاں بہت ہجوم ہے جو چھپنے کے لیے بہترین ہے۔ میا تمہارے بالکل ساتھ لگی ہوئی ہے، اس کا کندھا تمہارے کندھے سے چھو رہا ہے۔";
"S2.P10.Q" = "چلتے رہیں؟";
"S2.P10.O1" = "ایکسپریس ٹرین لیں";
"S2.P10.O2" = "سرنگوں کے راستے پیدل چلیں";

"S2.P11.N" = "تم بلند و بالا عمارتوں کے علاقے سے گزر رہے ہو۔ ہولوگرافک اشتہارات میا کے چہرے کو گلابی اور نیلی روشنیوں سے منور کر رہے ہیں۔";
"S2.P11.Q" = "خاموشی توڑیں؟";
"S2.P11.O1" = "میا، تم نے میری ہی مدد کیوں لی؟";
"S2.P11.O2" = "مجھے اس چپ کے بارے میں بتاؤ";

"S2.P12.N" = "شہر ایک بھول بھلیاں جیسا لگتا ہے۔ تم دم لینے کے لیے ایک چھپی ہوئی رامن شاپ پر رکتے ہو۔";
"S2.P12.Q" = "گلی پر نظر رکھیں؟";
"S2.P12.O1" = "دیکھو کوئی پیچھا تو نہیں کر رہا";
"S2.P12.O2" = "میا سے بات کریں";

"S2.P13.N" = "میا نظریں جھکا لیتی ہے۔ 'آج کی رات تم اکیلے تھے جو کسی شکاری جیسے نہیں لگ رہے تھے۔ مجھے ایک ہمدرد انسان کی ضرورت تھی، کسی کرائے کے سپاہی کی نہیں۔'";
"S2.P13.Q" = "نرمی سے جواب دیں؟";
"S2.P13.O1" = "مجھے خوشی ہے کہ میں وہاں موجود تھا";
"S2.P13.O2" = "میں تو بس بار میں بیٹھا ایک عام سا لڑکا ہوں";

"S2.P14.N" = "میا چپ کو چھوتی ہے۔ 'یہ میری بہن کا شعور ہے۔ وہ ایک ایسی ہیکر تھی جس نے وہ سب دیکھ لیا جو اسے نہیں دیکھنا چاہیے تھا۔ انہوں نے اس کا جسم 'ختم' کر دیا۔'";
"S2.P14.Q" = "ہمدردی کا اظہار کریں؟";
"S2.P14.O1" = "یہ تو بہت ہی خوفناک ہے...";
"S2.P14.O2" = "کیا اسے بچایا جا سکتا ہے؟";

"S2.P15.N" = "وہ ایک آنسو پونچھتی ہے۔ 'اپلوڈ پوائنٹ پرانے ٹی وی ٹاور میں ہے۔ لیکن پل پر پولیس کا پہرہ ہے۔'";
"S2.P15.Q" = "پار کیسے کریں گے؟";
"S2.P15.O1" = "اپنی ہیکنگ کی مہارت استعمال کرو";
"S2.P15.O2" = "گارڈز کو رشوت دے کر نکلو";

"S2.P16.N" = "میا تمہیں نقشہ دکھاتی ہے۔ 'اگر ہم گٹروں (Sewers) کے راستے جائیں تو محفوظ ہے، لیکن راستہ بہت لمبا ہے۔'";
"S2.P16.Q" = "راستہ چنیں؟";
"S2.P16.O1" = "چلو، زیرِ زمین راستے سے چلتے ہیں";
"S2.P16.O2" = "نہیں، ہمیں جلدی پہنچنا ہوگا";

"S2.P17.N" = "یہ راستہ گندا اور اندھیرا ہے، لیکن کام کر گیا۔ میا تم پر مکمل بھروسہ کر رہی ہے۔ تم اس کے اعتماد کا بوجھ محسوس کر سکتے ہو۔";
"S2.P17.Q" = "گڑھا پار کرنے میں اس کی مدد کریں؟";
"S2.P17.O1" = "اسے اپنا ہاتھ دیں";
"S2.P17.O2" = "آگے بڑھ کر راستہ دکھائیں";

"S2.P18.N" = "پل پر کافی افراتفری ہے۔ تم اس کا فائدہ اٹھا کر وہاں سے نکل جاتے ہو۔ میا کا دل اتنی زور سے دھڑک رہا ہے کہ تم اسے صاف سن سکتے ہو۔";
"S2.P18.Q" = "اسے پرسکون کریں؟";
"S2.P18.O1" = "ہم بس پہنچنے ہی والے ہیں";
"S2.P18.O2" = "میا، اپنا دھیان کام پر رکھو";

"S2.P19.N" = "ٹی وی ٹاور سامنے نظر آ رہا ہے۔ یہ جدید فولادی عمارتوں کے درمیان ایک پرانی یادگار جیسا ہے۔ میا ڈھال چکی ہے۔";
"S2.P19.Q" = "تھوڑی دیر رکنے کا کہیں؟";
"S2.P19.O1" = "پانچ منٹ آرام کر لو";
"S2.P19.O2" = "نہیں، آخری دم تک ہمت نہیں ہارنی";

"S2.P20.N" = "تم ٹاور کے دامن میں پہنچتے ہو۔ 'لفٹ خراب ہے،' میا آہ بھرتی ہے۔ 'ہمیں سیڑھیوں سے چڑھنا ہوگا۔'";
"S2.P20.Q" = "اس کی ہمت بڑھائیں؟";
"S2.P20.O1" = "بس ایک ایک قدم کر کے اوپر چلو";
"S2.P20.O2" = "سامان میں اٹھا لیتا ہوں";

"S2.P21.N" = "تم سیڑھیوں پر بیٹھ جاتے ہو۔ میا تمہارے کندھے سے ٹیک لگا لیتی ہے۔ 'اگر ہم بچ گئے... تو کل تم کیا کرو گے؟'";
"S2.P21.Q" = "مستقبل کا سوچیں؟";
"S2.P21.O1" = "شاید ہم کہیں مل کر کافی پیئیں";
"S2.P21.O2" = "مجھے بس سکون سے سونے کی خوشی ہوگی";

"S2.P22.N" = "چڑھائی بہت کٹھن ہے۔ آدھے راستے میں تمہیں نیچے سائرن سنائی دیتے ہیں۔ انہوں نے تمہاری کار ڈھونڈ لی ہے۔";
"S2.P22.Q" = "جلدی کریں؟";
"S2.P22.O1" = "رفتار دگنی کر دو!";
"S2.P22.O2" = "چھپنے کی جگہ تلاش کرو";

"S2.P23.N" = "تم سرور روم پہنچ جاتے ہو۔ ہوا ٹھنڈی ہے اور مشینوں کی گونج سنائی دے رہی ہے۔ میا چپ کنیکٹ کرتی ہے۔ 'شروعات ہو رہی ہے...' وہ کہتی ہے۔";
"S2.P23.Q" = "اسکرین دیکھیں؟";
"S2.P23.O1" = "دروازے پر پہرہ دیں";
"S2.P23.O2" = "میا کے بالکل ساتھ کھڑے رہیں";

"S2.P24.N" = "ٹرمینل پرانا ہے لیکن کام کر رہا ہے۔ میا کی انگلیاں تیزی سے کی بورڈ پر چل رہی ہیں۔ 'فائر وال بہت مضبوط ہے!'";
"S2.P24.Q" = "ہیکنگ میں مدد کریں؟";
"S2.P24.O1" = "بجلی کا سسٹم اوور رائیڈ کرو";
"S2.P24.O2" = "اس کا حوصلہ بندھائیں";

"S2.P25.N" = "دروازوں سے آواز آتی ہے۔ اراساکا کی ٹیم پہنچ چکی ہے۔ تم اپنا ہتھیار نکالتے ہو۔ 'بس دو منٹ اور!' میا چلاتی ہے۔";
"S2.P25.Q" = "پوزیشن سنبھالیں؟";
"S2.P25.O1" = "فائرنگ شروع کرو!";
"S2.P25.O2" = "دروازے کے آگے رکاوٹیں کھڑی کرو";

"S2.P26.N" = "میا کی آنکھیں نیلی ہو جاتی ہیں۔ وہ ڈیجیٹل دنیا کی گہرائیوں میں ہے۔ سپاہی شیشے کی چھت توڑ کر اندر آ رہے ہیں۔";
"S2.P26.Q" = "میا کی حفاظت کریں؟";
"S2.P26.O1" = "اسے اپنے جسم سے ڈھانپ لیں";
"S2.P26.O2" = "اسے کھینچ کر محفوظ جگہ لے جائیں";

"S2.P27.N" = "ایک زوردار روشنی کا دھماکہ ہوتا ہے۔ اپلوڈ 100٪ مکمل ہو چکا ہے۔ سپاہی وہیں جم جاتے ہیں—ان کا نیٹ ورک ہیک ہو چکا ہے۔";
"S2.P27.Q" = "میا کو دیکھیں؟";
"S2.P27.O1" = "کیا کام ہو گیا؟";
"S2.P27.O2" = "کیا تم ٹھیک ہو؟";

"S2.P28.N" = "سب کچھ اندھیرے میں ڈوب جاتا ہے۔ پھر ٹوکیو کی ہر اسکرین پر ایک ہی لفظ چمکتا ہے: 'آزادی'۔ میا نڈھال ہو کر تمہاری بانہوں میں گر جاتی ہے۔";
"S2.P28.Q" = "اسے ہوش میں لائیں؟";
"S2.P28.O1" = "میا! کچھ بولو!";
"S2.P28.O2" = "اسے مضبوطی سے تھامے رکھیں";

"S2.P29.N" = "ایک بدلے ہوئے ٹوکیو پر سورج طلوع ہو رہا ہے۔ میا مسکراتی ہے، اس کی آنکھیں اب نارمل ہیں۔ 'وہ محفوظ ہے۔ اب ہم بھی محفوظ ہیں۔'";
"S2.P29.Q" = "اختتام";
"S2.P29.O1" = "کہانی دوبارہ شروع کریں";
"S2.P29.O2" = "ختم کریں";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "سمر کیمپ کی آخری رات۔ آگ کے الاؤ کی تپش مدہم ہو رہی ہے اور ہر طرف صنوبر کی خوشبو پھیلی ہے۔ یوکی، جو عام طور پر بہت شرمیلی ہے، تمہاری نظروں سے نظریں ملاتی ہے اور جھیل کی طرف جاتے اندھیرے راستے کی طرف اشارہ کرتی ہے۔";
"S3.P0.Q" = "کیا تم اس کے پیچھے اندھیری رات میں جاؤ گے؟";
"S3.P0.O1" = "میں اسی پل کا انتظار کر رہا تھا";
"S3.P0.O2" = "ہاں، چلو چلتے ہیں";

"S3.P1.N" = "تم اس تک پہنچ جاتے ہو۔ جنگل جھینگروں کی آواز سے گونج رہا ہے۔ چلتے ہوئے کبھی کبھار یوکی کا ہاتھ تمہارے ہاتھ سے ٹکرا جاتا ہے۔ وہ تھوڑی گھبرائی ہوئی لگ رہی ہے۔";
"S3.P1.Q" = "خاموشی کیسے توڑیں گے؟";
"S3.P1.O1" = "مضبوطی سے اس کا ہاتھ تھام لیں";
"S3.P1.O2" = "پوچھیں کہ اس کے ذہن میں کیا چل رہا ہے";

"S3.P2.N" = "تم دونوں ساتھ ساتھ چل رہے ہو۔ چاند کی روشنی گھنے درختوں کو بمشکل چیر پا رہی ہے۔ یوکی تمہیں ترچھی نظروں سے دیکھتی ہے اور ہلکا سا مسکراتی ہے۔ 'مجھے نہیں لگا تھا کہ تم واقعی آؤ گے،' وہ سرگوشی کرتی ہے۔";
"S3.P2.Q" = "تمہارا جواب؟";
"S3.P2.O1" = "میں اسے کیسے چھوڑ سکتا تھا";
"S3.P2.O2" = "بس مجھے تھوڑا تجسس تھا";

"S3.P3.N" = "تم لکڑی کے گھاٹ (Pier) تک پہنچ جاتے ہو۔ پانی ایک سیاہ آئینے کی طرح ہے جس میں ستاروں کا عکس نظر آ رہا ہے۔ یوکی اپنے جوتے اتارتی ہے اور کنارے پر بیٹھ کر اپنے پاؤں پانی میں لٹکا دیتی ہے۔";
"S3.P3.Q" = "اس کے قریب بیٹھیں؟";
"S3.P3.O1" = "بالکل اس کے ساتھ جڑ کر بیٹھیں";
"S3.P3.O2" = "اسے تھوڑی جگہ دیں";

"S3.P4.N" = "تمہارے بوجھ سے لکڑی کا تختہ چرچراتا ہے۔ جھیل کی ٹھنڈی ہوا سے یوکی تھوڑا سا کانپتی ہے۔ تمہارے قریب آنے پر وہ پیچھے نہیں ہٹتی۔";
"S3.P4.Q" = "اپنی جیکٹ پیش کریں؟";
"S3.P4.O1" = "اسے اپنی جیکٹ پہنا دیں";
"S3.P4.O2" = "بس وہیں بیٹھ کر باتیں کریں";

"S3.P5.N" = "یوکی ستاروں کی طرف دیکھتی ہے۔ 'کیا تمہیں یہاں ہمارا پہلا دن یاد ہے؟' وہ پوچھتی ہے۔ 'تم نے میرے بیگ اٹھانے میں مدد کی تھی جب باقی سب مصروف تھے۔'";
"S3.P5.Q" = "کیا تمہیں یاد ہے؟";
"S3.P5.O1" = "مجھے ایک ایک پل یاد ہے";
"S3.P5.O2" = "لگتا ہے جیسے صدیوں پرانی بات ہو";

"S3.P6.N" = "وہ ہلکا سا ہنستی ہے۔ 'میں اس وقت بہت ڈری ہوئی تھی۔ لیکن تمہیں دیکھ کر مجھے لگا جیسے میں یہاں تنہا نہیں ہوں۔' وہ پانی کی طرف دیکھتی ہے۔";
"S3.P6.Q" = "اپنے جذبات کا اظہار کریں؟";
"S3.P6.O1" = "مجھے بھی بالکل ایسا ہی لگا تھا";
"S3.P6.O2" = "مجھے خوشی ہے کہ میں تمہارے کام آ سکا";

"S3.P7.N" = "رات بالکل پرسکون ہے۔ اچانک یوکی کھڑی ہو جاتی ہے۔ 'پانی کتنا پرکشش لگ رہا ہے۔ کیا ہمیں... اندر جانا چاہیے؟' وہ شرارت سے پوچھتی ہے۔";
"S3.P7.Q" = "کیا تم اتنے بہادر ہو؟";
"S3.P7.O1" = "چلو، چھلانگ لگاتے ہیں!";
"S3.P7.O2" = "یوکی، پانی بہت ٹھنڈا ہے";

"S3.P8.N" = "وہ جھیل کو دیکھتی ہے، پھر تمہیں۔ 'آج رات میں کچھ بہادری والا کام کرنا چاہتی ہوں۔ کچھ ایسا جو مجھے پوری سردیوں میں یاد رہے۔'";
"S3.P8.Q" = "اس کا حوصلہ بڑھائیں؟";
"S3.P8.O1" = "میرے ساتھ چھلانگ لگاؤ گی؟";
"S3.P8.O2" = "چلو یہیں رکتے ہیں";

"S3.P9.N" = "چھپاک! پانی برف جیسا ہے لیکن بہت مزہ آ رہا ہے۔ تم اور یوکی ہنستے ہوئے باہر نکلتے ہو اور بچوں کی طرح ایک دوسرے پر پانی پھینکتے ہو۔";
"S3.P9.Q" = "اس کے مزید قریب تیر کر جائیں؟";
"S3.P9.O1" = "اسے پیار سے گلے لگا لیں";
"S3.P9.O2" = "پانی پھینکنا جاری رکھیں!";

"S3.P10.N" = "تم گھاٹ پر ہی رہتے ہو۔ تم گھنٹوں ہر موضوع پر بات کرتے ہو—اسکول، والدین اور مستقبل۔ خاموشی میں تم دونوں کا رشتہ مزید گہرا ہو رہا ہے۔";
"S3.P10.Q" = "مزید قریب ہوں؟";
"S3.P10.O1" = "اپنا سر اس کے سر سے ٹکا دیں";
"S3.P10.O2" = "اس کی آنکھوں میں جھانکیں";

"S3.P11.N" = "ماحول بدل جاتا ہے۔ یوکی بولنا بند کر دیتی ہے۔ مدہم روشنی میں اس کی آنکھیں تمہاری آنکھوں میں کچھ تلاش کر رہی ہیں۔ 'میں کل واپس شہر نہیں جانا چاہتی،' وہ سرگوشی کرتی ہے۔";
"S3.P11.Q" = "تم کیا کہو گے؟";
"S3.P11.O1" = "ہم وہاں بھی ایک دوسرے سے ملیں گے";
"S3.P11.O2" = "چلو کل کے بارے میں نہیں سوچتے";

"S3.P12.N" = "یوکی ایک لمبا سانس لیتی ہے۔ 'اگر میں نے یہ آج نہ کہا، تو کبھی نہیں کہہ پاؤں گی۔ بس اسٹاپ پر اس پہلے دن سے ہی تم مجھے اچھے لگتے ہو۔'";
"S3.P12.Q" = "تمہارا ردعمل؟";
"S3.P12.O1" = "تم مجھے بھی بہت پسند ہو";
"S3.P12.O2" = "بالآخر، سچ سامنے آ ہی گیا!";

"S3.P13.N" = "وہ اپنی جیب میں ہاتھ ڈال کر ہاتھ سے بنا ہوا ایک فرینڈشپ بریسلٹ نکالتی ہے۔ یہ جھیل کے رنگوں جیسا نیلا اور سفید ہے۔ 'میں نے یہ تمہارے لیے بنایا تھا،' وہ شرماتے ہوئے کہتی ہے۔";
"S3.P13.Q" = "تحفہ قبول کریں؟";
"S3.P13.O1" = "اسے اپنے ہاتھ پر باندھنے دیں";
"S3.P13.O2" = "اس کے بجائے اسے ایک بوسہ دیں";

"S3.P14.N" = "بریسلٹ سادہ سا ہے، لیکن تم جانتے ہو اسے بنانے میں اس نے گھنٹوں لگائے ہوں گے۔ وہ تمہارے ردعمل کا انتظار کر رہی ہے، اس کا نچلا ہونٹ ہلکا سا کانپ رہا ہے۔";
"S3.P14.Q" = "اب کیا کریں گے؟";
