/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "Der er helt stille i palæet, da du kommer hjem. Et svagt lys flimrer i dit arbejdsværelse. Du finder Elena, din mest stille stuepige, mens hun nervøst rydder op ved dit skrivebord. Klokken er 02:00 om natten.";
"S1.P0.Q" = "Går du hen til hende?";
"S1.P0.O1" = "Elena, hvorfor er du ikke i seng?";
"S1.P0.O2" = "(Iagttag hende fra skyggerne)";

/* Page 1 */
"S1.P1.N" = "Hun gispede og tabte støvekosten. 'Herre! Jeg... jeg kunne ikke sove. Støvet irriterede mig.' Hun ser bleg ud og vil ikke se dig i øjnene.";
"S1.P1.Q" = "Tror du på hende?";
"S1.P1.O1" = "Det er for sent til at gøre rent";
"S1.P1.O2" = "Du er en flittig medarbejder";

/* Page 2 */
"S1.P2.N" = "Du ser hende tage en lille sølvnøgle op fra sit forklæde. Hun stirrer på den med en blanding af længsel og frygt, før hun opdager din skygge.";
"S1.P2.Q" = "Træder du frem?";
"S1.P2.O1" = "Hvad er det for en nøgle, Elena?";
"S1.P2.O2" = "Forklar dig selv med det samme";

/* Page 3 */
"S1.P3.N" = "Hun skælver. 'Dette hus... det gemmer på så mange hemmeligheder. Nogle gange føles de som en tung byrde.' Hun peger mod det gamle pengeskab bag din bogreol.";
"S1.P3.Q" = "Spørger du ind til pengeskabet?";
"S1.P3.O1" = "Passer nøglen dertil?";
"S1.P3.O2" = "Pengeskabet er strengt forbudt";

/* Page 4 */
"S1.P4.N" = "Hun forsøger at skjule nøglen, men taber den. 'Jeg er ikke en tyv, jeg lover det! Jeg... jeg så den bare på gangen og tænkte, den var Deres.'";
"S1.P4.Q" = "Samler du nøglen op?";
"S1.P4.O1" = "(Saml den op)";
"S1.P4.O2" = "Lad os se, hvad den åbner";

/* Page 5 */
"S1.P5.N" = "Nøglen passer til et skjult rum i pengeskabet. Elena kigger med tilbageholdt åndedræt, mens du finder en stak gamle, gulnede breve bundet med et sort bånd.";
"S1.P5.Q" = "Læser du det øverste brev?";
"S1.P5.O1" = "Læs det højt";
"S1.P5.O2" = "Spørg Elena, hvad hun ved";

/* Page 6 */
"S1.P6.N" = "Elenas stemme bliver til en hvisken. 'Min mor var også stuepige her. Hun fortalte mig, at herren gemte minder om en pige, han engang elskede. En pige, der lignede mig.'";
"S1.P6.Q" = "Vent, hvad?";
"S1.P6.O1" = "Fortæl mig alt";
"S1.P6.O2" = "Det her er umuligt";

/* Page 7 */
"S1.P7.N" = "Brevene beskriver en forbudt romance. Elena træder tættere på, og måneskinnet rammer hendes tårer. 'Jeg ville ikke stjæle. Jeg ville bare vide, om jeg hører til her.'";
"S1.P7.Q" = "Trøster du hende?";
"S1.P7.O1" = "Læg en hånd på hendes skulder";
"S1.P7.O2" = "Giv hende lidt plads";

/* Page 8 */
"S1.P8.N" = "Hun forklarer, at hendes mors dagbog nævnte en skjult sandhed i dette rum. 'Jeg har boet i dette hus hele mit liv, men jeg føler mig som et spøgelse.'";
"S1.P8.Q" = "Giver du hende et løfte?";
"S1.P8.O1" = "Jeg hjælper dig med at finde sandheden";
"S1.P8.O2" = "Vi løser det her sammen";

/* Page 9 */
"S1.P9.N" = "Du bruger den næste time på at gennemgå papirerne. Du finder en fødselsattest med et velkendt navn, men feltet med faderens navn er tomt.";
"S1.P9.Q" = "Kigger du på Elena?";
"S1.P9.O1" = "Kunne det være min onkel?";
"S1.P9.O2" = "Måske er det bedst ikke at vide det";

/* Page 10 */
"S1.P10.N" = "Søgningen bliver mere intens. Elena finder et smykkeskrin gemt bag brevene. Indeni er en medaljon med et portræt af en kvinde, der er hendes tro kopi.";
"S1.P10.Q" = "Viser du hende den?";
"S1.P10.O1" = "Se denne medaljon";
"S1.P10.O2" = "Er det din mor?";

/* Page 11 */
"S1.P11.N" = "Pludselig knirker et gulvbræt udenfor. Der er nogen på gangen. Elenas øjne bliver store af panik. 'Hvis butleren finder os...!'";
"S1.P11.Q" = "Gemmer I jer?";
"S1.P11.O1" = "Gem dig i skabet med hende";
"S1.P11.O2" = "Bliv og tag konfrontationen";

/* Page 12 */
"S1.P12.N" = "Fodspor nærmer sig. Elena griber fat i dit ærme. 'Jeg beder dig, ingen må vide, at vi fandt det her. Det er farligt for mig.'";
"S1.P12.Q" = "Hvad gør du?";
"S1.P12.O1" = "Sluk lyset";
"S1.P12.O2" = "Lås døren";

/* Page 13 */
"S1.P13.N" = "Rummet er bælgmørkt. På den trange plads kan du høre Elenas hurtige hjerteslag og duften af rosenblade fra hendes hud. Hun er utroligt tæt på.";
"S1.P13.Q" = "Hvisker du til hende?";
"S1.P13.O1" = "Du er i sikkerhed hos mig";
"S1.P13.O2" = "(Forbliv tavs og vent)";

/* Page 14 */
"S1.P14.N" = "Du holder døren lukket. Personen udenfor tøver et øjeblik og går så væk. Elena læner sig op ad dig, rystende af adrenalin.";
"S1.P14.Q" = "Beroliger du hende?";
"S1.P14.O1" = "De er væk nu";
"S1.P14.O2" = "Er du okay?";

/* Page 15 */
"S1.P15.N" = "Hun trækker sig lidt væk, men hendes hånd bliver siddende på dit bryst. 'Herre... jeg har altid beundret dig på afstand. Denne hemmelighed... den er for stor at bære alene.'";
"S1.P15.Q" = "Hvad føler du?";
"S1.P15.O1" = "Jeg har også lagt mærke til dig";
"S1.P15.O2" = "Du er meget mere end en stuepige";

/* Page 16 */
"S1.P16.N" = "'Jeg troede, jeg bare var en tjener for dig,' hvisker hun. 'Bare en del af inventaret. Men i nat føles det som starten på noget ægte.'";
"S1.P16.Q" = "Er du enig?";
"S1.P16.O1" = "Det er ægte, Elena";
"S1.P16.O2" = "Lad os se, hvor det fører hen";

/* Page 17 */
"S1.P17.N" = "Hun åbner medaljonen. Indeni er en lille seddel: 'Til min datter, den retmæssige arving.' Elena gisper. Palæet tilhører måske i virkeligheden hende.";
"S1.P17.Q" = "Hvad betyder det?";
"S1.P17.O1" = "Vi må afsløre sandheden";
"S1.P17.O2" = "Vi bør holde det hemmeligt";

/* Page 18 */
"S1.P18.N" = "Sedlen beviser, at Elena er den retmæssige ejer af godset. Hun ser sig målløs omkring i rummet. 'Jeg... jeg vil ikke have huset. Jeg vil bare have en familie.'";
"S1.P18.Q" = "Hvad ønsker du?";
"S1.P18.O1" = "Du har mig nu";
"S1.P18.O2" = "Hvad vil du gøre?";

/* Page 19 */
"S1.P19.N" = "Hun kigger mod pejsen. 'Hvis jeg brænder denne, er jeg bare Elena igen. Hvis jeg beholder den, ændrer alt sig. Hvad skal jeg gøre?'";
"S1.P19.Q" = "Giver du hende et råd?";
"S1.P19.O1" = "Brænd den og bliv hos mig";
"S1.P19.O2" = "Behold den og tag din retmæssige plads";

/* Page 20 */
"S1.P20.N" = "Elena holder beviset for sin herkomst. 'Familienavnet er forbandet. Jeg vil hellere være en lykkelig 'ingen' end en ulykkelig fin dame.'";
"S1.P20.Q" = "Dit valg?";
"S1.P20.O1" = "Følg dit hjerte";
"S1.P20.O2" = "Tænk på din fremtid";

/* Page 21 */
"S1.P21.N" = "Hun kaster papiret ind i de døende gløder. Hemmeligheden bliver til aske. Elena smiler og ser mere fri ud end nogensinde før.";
"S1.P21.Q" = "Fremtiden?";
"S1.P21.O1" = "En ny begyndelse";
"S1.P21.O2" = "Bare os to";

/* Page 22 */
"S1.P22.N" = "Hun gemmer papiret i sin kjole. 'Så vil jeg blive fruen i dette hus. Og jeg får brug for en partner ved min side.'";
"S1.P22.Q" = "Er du klar?";
"S1.P22.O1" = "Altid";
"S1.P22.O2" = "Det bliver en lang vej";

/* Final 1 */
"S1.P23.N" = "Elena er ikke længere din stuepige. Hun er din ligemand, din partner og din hemmelighed. Palæet forbliver dit, men hjertet i det tilhører hende.";
"S1.P23.Q" = "SLUT";
"S1.P23.O1" = "Genstart historien";
"S1.P23.O2" = "Afslut";

/* Final 2 */
"S1.P24.N" = "Sandheden kommer frem. Elena bliver overhoved for husholdningen. Magtbalancen er skiftet, men det bånd, I knyttede i nat, er ubrydeligt.";
"S1.P24.Q" = "SLUT";
"S1.P24.O1" = "Genstart historien";
"S1.P24.O2" = "Afslut";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "Regnen pisker mod neongaderne i Shinjuku. Du sidder i en stille bar, da en kvinde i en våd trenchcoat sætter sig ved siden af dig. Hun dufter af jasmin og krudt.";
"S2.P0.Q" = "Hvordan starter du samtalen?";
"S2.P0.O1" = "Giv hende en drink";
"S2.P0.O2" = "Hård nat, hvad?";

"S2.P1.N" = "Hun kigger på glasset, så på dig. 'Du er modig,' hvisker hun. Hun skubber en lille datachip hen over disken.";
"S2.P1.Q" = "Tager du chippen?";
"S2.P1.O1" = "Tag den og gem den væk";
"S2.P1.O2" = "Jeg vil ikke have problemer";

"S2.P2.N" = "Hun griner bittert. 'Du har ingen anelse.' Hun kigger sig over skulderen. To mænd i sorte jakkesæt er lige trådt ind i baren.";
"S2.P2.Q" = "Hjælper du hende med at gemme sig?";
"S2.P2.O1" = "Følg mig til bagdøren";
"S2.P2.O2" = "Lad som om vi er et par";

"S2.P3.N" = "Du trækker hende tæt ind til dig. Mændene scanner lokalet og går igen. Hun ser lettet ud, men hendes hænder ryster. 'Jeg er Mia,' hvisker hun.";
"S2.P3.Q" = "Spørger du ind til faren?";
"S2.P3.O1" = "Hvem var det, Mia?";
"S2.P3.O2" = "Er vi i sikkerhed nu?";

"S2.P4.N" = "Mændene nærmer sig, men du tager den med ro. De går forbi. Hun hvisker: 'Du reddede mig. Jeg er Mia. Men denne chip... den er en million liv værd.'";
"S2.P4.Q" = "Spørger du om chippen?";
"S2.P4.O1" = "Hvad er der på den?";
"S2.P4.O2" = "Vi bør se at komme væk herfra";

"S2.P5.N" = "Mia kigger mod døren. 'Arasaka Corporation vil have fat i den her. Det er ikke bare data, det er en digital sjæl.'";
"S2.P5.Q" = "Tror du på hende?";
"S2.P5.O1" = "En digital sjæl? Seriøst?";
"S2.P5.O2" = "Jeg har hørt rygterne...";

"S2.P6.N" = "Mia griber din hånd. 'Intet sted er sikkert, før vi uploader det her. Vi skal nå frem til Tech-distriktet.'";
"S2.P6.Q" = "Tager du med hende?";
"S2.P6.O1" = "Jeg tager dig dertil";
"S2.P6.O2" = "Kun hvis du fortæller mig mere";

"S2.P7.N" = "I sniger jer ud af bagudgangen. Gyden er mørk og lugter af ozon. Pludselig summer en drone over jeres hoveder på jagt efter varmesignaturer.";
"S2.P7.Q" = "Hvordan undgår I dronen?";
"S2.P7.O1" = "Gem jer under halvtaget";
"S2.P7.O2" = "Løb mod metroen";

"S2.P8.N" = "Mia stopper op i regnen. 'Hvis de fanger mig, sletter de mig. Og dig også, fordi du hjalp.'";
"S2.P8.Q" = "Beroliger du hende?";
"S2.P8.O1" = "Jeg er med dig i det her";
"S2.P8.O2" = "Lad os bare se at komme afsted, hurtigt";

"S2.P9.N" = "Dronen passerer. I når frem til din bil. Mia kigger på dig med en blanding af frygt og taknemmelighed.";
"S2.P9.Q" = "Starter du motoren?";
"S2.P9.O1" = "Giv den gas!";
"S2.P9.O2" = "Kør langsomt, fald ind i mængden";

"S2.P10.N" = "I når lige akkurat frem til stationen. Der er en kæmpe menneskemængde, som giver perfekt dække. Mia holder sig tæt til dig, hendes skulder rører din.";
"S2.P10.Q" = "Fortsætter I?";
"S2.P10.O1" = "Tag eksprestoget";
"S2.P10.O2" = "Gå gennem tunnelerne";

"S2.P11.N" = "I bevæger jer gennem højhuskvarteret. De holografiske reklamer oplyser Mias ansigt i pink og blå farver.";
"S2.P11.Q" = "Bryder du tavsheden?";
"S2.P11.O1" = "Hvorfor mig, Mia?";
"S2.P11.O2" = "Fortæl mig om chippen";

"S2.P12.N" = "Byen føles som en labyrint. I gør holdt ved en skjult ramen-bar for at hvile et øjeblik.";
"S2.P12.Q" = "Holder du øje med gaden?";
"S2.P12.O1" = "Tjek om vi er fulgt efter";
"S2.P12.O2" = "Tal med Mia";

"S2.P13.N" = "Mia kigger ned. 'Du var den eneste, der ikke lignede et rovdyr i nat. Jeg havde brug for et menneske, ikke en lejesoldat.'";
"S2.P13.Q" = "Svarer du venligt?";
"S2.P13.O1" = "Jeg er glad for, at jeg var der";
"S2.P13.O2" = "Jeg er bare en fyr i en bar";

"S2.P14.N" = "Mia rører ved chippen. 'Det her er min søsters bevidsthed. Hun var en netrunner, der så for meget. De 'dræbte' hendes krop.'";
"S2.P14.Q" = "Viser du sympati?";
"S2.P14.O1" = "Det er forfærdeligt...";
"S2.P14.O2" = "Kan hun reddes?";

"S2.P15.N" = "Hun tørrer en tåre væk. 'Upload-stedet er i det gamle TV-tårn. Men broen er spærret af en politiafspærring.'";
"S2.P15.Q" = "Hvordan kommer I over?";
"S2.P15.O1" = "Brug dine hacker-evner";
"S2.P15.O2" = "Bestik vagterne";

"S2.P16.N" = "Mia viser dig et kort. 'Hvis vi går gennem kloakkerne, er det sikrere, men det er en lang vej.'";
"S2.P16.Q" = "Hvilken vej vælger du?";
"S2.P16.O1" = "Lad os tage kloakkerne";
"S2.P16.O2" = "Nej, vi har brug for fart";

"S2.P17.N" = "Det er beskidt og mørkt, men effektivt. Mia stoler på din vejledning. Du kan mærke vægten af hendes tillid.";
"S2.P17.Q" = "Hjælper du hende over en forhindring?";
"S2.P17.O1" = "Giv hende en hånd";
"S2.P17.O2" = "Vis vejen";

"S2.P18.N" = "Der er kaos på broen. I udnytter forvirringen til at smutte forbi. Mias hjerte banker så hurtigt, at du næsten kan høre det.";
"S2.P18.Q" = "Holder du hende rolig?";
"S2.P18.O1" = "Vi er der næsten";
"S2.P18.O2" = "Hold fokus, Mia";

"S2.P19.N" = "TV-tårnet tårner sig op foran jer. Det er et levn fra den gamle verden, omgivet af moderne stål. Mia ser udmattet ud.";
"S2.P19.Q" = "Foreslår du en pause?";
"S2.P19.O1" = "Hvil i 5 minutter";
"S2.P19.O2" = "Pres på til det sidste";

"S2.P20.N" = "I når bunden af tårnet. 'Elevatoren virker ikke,' sukker Mia. 'Vi bliver nødt til at klatre.'";
"S2.P20.Q" = "Opmuntrer du hende?";
"S2.P20.O1" = "Ét skridt ad gangen";
"S2.P20.O2" = "Jeg bærer udstyret";

"S2.P21.N" = "I sidder på trappen. Mia læner sig op ad dig. 'Hvis vi klarer den... hvad vil du så gøre i morgen?'";
"S2.P21.Q" = "Tænker du på fremtiden?";
"S2.P21.O1" = "Måske kan vi få en kop kaffe";
"S2.P21.O2" = "Jeg vil bare være glad for at få sovet";

"S2.P22.N" = "Opstigningen er benhård. Halvvejs oppe hører I sirener nedefra. De har fundet din bil.";
"S2.P22.Q" = "Skynder I jer?";
"S2.P22.O1" = "Sæt farten op!";
"S2.P22.O2" = "Find et sted at gemme jer";

"S2.P23.N" = "I når serverrummet. Luften er kold og summer af energi. Mia tilslutter chippen. 'Initialiserer...' siger hun.";
"S2.P23.Q" = "Holder du øje med skærmen?";
"S2.P23.O1" = "Vogt døren";
"S2.P23.O2" = "Bliv ved Mias side";

"S2.P24.N" = "Terminalen er tudegammel, men den virker. Mias fingre flyver hen over tasterne. 'Firewallen er enorm!'";
"S2.P24.Q" = "Hjælper du hende med at hacke?";
"S2.P24.O1" = "Tilsidesæt strømstyringen";
"S2.P24.O2" = "Hold hende rolig";

"S2.P25.N" = "Dørene hvisler. Arasakas taktiske hold er her. Du trækker dit våben. 'Bare to minutter mere!' skriger Mia.";
"S2.P25.Q" = "Holder du stand?";
"S2.P25.O1" = "Åbn ild!";
"S2.P25.O2" = "Barrikader døren";

"S2.P26.N" = "Mias øjne lyser blåt. Hun er dybt inde i nettet. Soldaterne bryder gennem glastaget.";
"S2.P26.Q" = "Beskytter du Mia?";
"S2.P26.O1" = "Dæk hende med din krop";
"S2.P26.O2" = "Træk hende i dækning";

"S2.P27.N" = "Et blændende lysglimt. Uploaden er 100% færdig. Soldaterne stivner – deres kybernetik er blevet blokeret fra nettet.";
"S2.P27.Q" = "Ser du til Mia?";
"S2.P27.O1" = "Er det gjort?";
"S2.P27.O2" = "Er du okay?";

"S2.P28.N" = "Alt bliver mørkt. Så lyser hver eneste skærm i Tokyo op med en enkelt besked: 'FRIHED'. Mia falder sammen i dine arme.";
"S2.P28.Q" = "Vækker du hende?";
"S2.P28.O1" = "Mia! Tal til mig!";
"S2.P28.O2" = "Hold hende tæt";

"S2.P29.N" = "Solen begynder at stå op over et forandret Tokyo. Mia smiler, hendes øjne er normale igen. 'Hun er i sikkerhed. Vi er i sikkerhed.'";
"S2.P29.Q" = "SLUT";
"S2.P29.O1" = "Genstart historien";
"S2.P29.O2" = "Afslut";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "Den sidste aften på sommerlejren. Det knitrende lejrbål dør langsomt ud, og duften af fyrrenåle er overalt. Yuki, der normalt er genert, fanger dit blik og viser mod den mørke sti, der fører ned til søen.";
"S3.P0.Q" = "Vil du følge efter hende ud i natten?";
"S3.P0.O1" = "Det har jeg ventet på";
"S3.P0.O2" = "Ja, lad os gå";

"S3.P1.N" = "Du indhenter hende. Skoven er levende med lyden af græshopper. Yukis hånd strejfer din af og til, mens I går. Hun virker nervøs.";
"S3.P1.Q" = "Hvordan bryder du tavsheden?";
"S3.P1.O1" = "Grib hendes hånd fast";
"S3.P1.O2" = "Spørg hvad hun tænker på";

"S3.P2.N" = "I går side om side. Måneskinnet trænger knap nok igennem det tætte løv. Yuki kigger skråt på dig med et lille smil. 'Jeg troede ikke, du faktisk ville komme,' hvisker hun.";
"S3.P2.Q" = "Hvad svarer du?";
"S3.P2.O1" = "Det ville jeg ikke gå glip af";
"S3.P2.O2" = "Jeg var nysgerrig";

"S3.P3.N" = "I når frem til badebroen. Vandet er som et mørkt spejl, der reflekterer det enorme hav af stjerner. Yuki tager sine sko af og sætter sig på kanten med fødderne i vandet.";
"S3.P3.Q" = "Sætter du dig tæt på hende?";
"S3.P3.O1" = "Sæt dig lige ved siden af hende";
"S3.P3.O2" = "Giv hende lidt plads";

"S3.P4.N" = "Broen knirker under din vægt. Den kolde luft fra søen får Yuki til at ryste en lille smule. Hun rykker sig ikke væk, da du kommer tættere på.";
"S3.P4.Q" = "Tilbyder du din jakke?";
"S3.P4.O1" = "Læg din jakke over hende";
"S3.P4.O2" = "Bare sid og tal";

"S3.P5.N" = "Yuki kigger på stjernerne. 'Husker du vores første dag her?' spørger hun. 'Du hjalp mig med mine tasker, da alle andre havde travlt.'";
"S3.P5.Q" = "Husker du det?";
"S3.P5.O1" = "Jeg husker hver eneste detalje";
"S3.P5.O2" = "Det føles som evigheder siden";

"S3.P6.N" = "Hun griner blidt. 'Jeg var så bange dengang. Men da jeg så dig, følte jeg, at jeg hørte til her.' Hun kigger på vandet.";
"S3.P6.Q" = "Indrømmer du dine egne følelser?";
"S3.P6.O1" = "Jeg havde det på samme måde";
"S3.P6.O2" = "Jeg er glad for, at jeg kunne hjælpe";

"S3.P7.N" = "Natten er helt stille. Pludselig rejser Yuki sig op. 'Vandet ser så indbydende ud. Skal vi... springe i?' spørger hun med et drilsk glimt i øjet.";
"S3.P7.Q" = "Er du modig nok?";
"S3.P7.O1" = "Lad os springe i!";
"S3.P7.O2" = "Det er for koldt, Yuki";

"S3.P8.N" = "Hun kigger på søen, så på dig. 'Jeg vil gøre noget modigt i nat. Noget jeg vil huske hele vinteren.'";
"S3.P8.Q" = "Opmuntrer du hende?";
"S3.P8.O1" = "Springer du i med mig?";
"S3.P8.O2" = "Lad os blive her";

"S3.P9.N" = "PLASK! Vandet er iskoldt, men opkvikkende. Du og Yuki kommer op til overfladen, gispende og grinende, mens I sprøjter vand på hinanden som børn.";
"S3.P9.Q" = "Svømmer du tættere på hende?";
"S3.P9.O1" = "Træk hende ind i et kram";
"S3.P9.O2" = "Bliv ved med at sprøjte!";

"S3.P10.N" = "I bliver på broen. I taler i timevis om alt – skolen, forældre og fremtiden. Båndet mellem jer bliver stærkere i stilheden.";
"S3.P10.Q" = "Læner du dig tættere ind?";
"S3.P10.O1" = "Hvil dit hoved mod hendes";
"S3.P10.O2" = "Kig hende i øjnene";

"S3.P11.N" = "Stemningen skifter. Yuki holder op med at tale. I det svage lys søger hendes øjne dine. 'Jeg har ikke lyst til at tage tilbage til byen i morgen,' hvisker hun.";
"S3.P11.Q" = "Hvad siger du?";
"S3.P11.O1" = "Vi ses jo derinde";
"S3.P11.O2" = "Lad os ikke tænke på i morgen";

"S3.P12.N" = "Yuki tager en dyb indånding. 'Hvis jeg ikke siger det nu, får jeg det aldrig gjort. Jeg har kunnet lide dig siden den første dag ved busstoppestedet.'";
"S3.P12.Q" = "Hvordan reagerer du?";
"S3.P12.O1" = "Jeg har også altid kunnet lide dig";
"S3.P12.O2" = "Endelig kom sandheden frem!";

"S3.P13.N" = "Hun rækker ned i lommen og tager et hjemmelavet venskabsarmbånd frem. Det er blåt og hvidt som søens farver. 'Jeg har lavet det her til dig,' siger hun genert.";
"S3.P13.Q" = "Modtager du gaven?";
"S3.P13.O1" = "Lad hende binde det på dig";
"S3.P13.O2" = "Giv hende et kys i stedet";

"S3.P14.N" = "Armbåndet er enkelt, men du ved, det har taget hende timer at lave. Hun venter på din reaktion, hendes underlæbe ryster en lille smule.";
"S3.P14.Q" = "Hvad gør du?";
"S3.P14.O1" = "Tak hende med et kram";
"S3.P14.O2" = "Fortæl hende, at det er perfekt";

"S3.P15.N" = "Yuki smiler – et ægte, strålende smil. 'Jeg var så bange for, at du ville synes, det var barnligt.' Hun kigger op på månen og ser mere selvsikker ud nu.";
"S3.P15.Q" = "Giver du hende et løfte?";
"S3.P15.O1" = "Lov at ringe hver dag";
"S3.P15.O2" = "Lov at besøge hende snart";

"S3.P16.N" = "Stemningen er elektrisk. Yuki stirrer på dine læber. Verden omkring jer forsvinder; det er bare jer to og sommernatten.";
"S3.P16.Q" = "Er det nu?";
"S3.P16.O1" = "Læn dig ind for et kys";
"S3.P16.O2" = "Hvisk noget sødt";

"S3.P17.N" = "Lige i det øjeblik farer et stjerneskud hen over himlen og efterlader en stribe af sølv. Yuki gisper. 'Hurtigt! Ønsk noget!' udbryder hun.";
"S3.P17.Q" = "Hvad ønsker du dig?";
"S3.P17.O1" = "Ønsk jer en fremtid sammen";
"S3.P17.O2" = "Ønsk at denne nat aldrig slutter";

"S3.P18.N" = "Stjernen forsvinder lige så hurtigt, som den kom. Yuki kniber øjnene hårdt sammen. 'Jeg ønskede mig noget vigtigt,' siger hun og rødmer.";
"S3.P18.Q" = "Spørger du, hvad det var?";
"S3.P18.O1" = "Fortæl mig dit ønske";
"S3.P18.O2" = "Jeg tror, jeg ved, hvad det var";

"S3.P19.N" = "Bålet i lejren er gået helt ud nu. I begynder at gå tilbage, hånd i hånd. Skoven føles anderledes nu – mindre skræmmende, mere magisk.";
"S3.P19.Q" = "Går I langsomt?";
"S3.P19.O1" = "Tag den lange vej tilbage";
"S3.P19.O2" = "Nyd stilheden";

"S3.P20.N" = "I kommer forbi det gamle egetræ, hvor I mødtes første gang. Yuki stopper op et øjeblik. 'Alt er ved at ændre sig, er det ikke?' spørger hun blidt.";
"S3.P20.Q" = "Trøster du hende?";
"S3.P20.O1" = "Forandring kan være godt";
"S3.P20.O2" = "Alt behøver ikke at ændre sig";

"S3.P21.N" = "Lejrens hytter er i sigte. De andre ligger og sover. Yuki stopper ved sin dør. Hun har ikke lyst til at give slip på din hånd.";
"S3.P21.Q" = "Én sidste ting?";
"S3.P21.O1" = "Bed om et sidste kys";
"S3.P21.O2" = "Bed om hendes telefonnummer";

"S3.P22.N" = "Yuki bliver stående i døråbningen. Lyset fra verandaen kaster et blødt skær over hendes ansigt. 'Tak for i nat. Det var den bedste nat i mit liv.'";
"S3.P22.Q" = "Siger du farvel?";
"S3.P22.O1" = "Vi ses i morgen tidlig";
"S3.P22.O2" = "Godnat, Yuki";

"S3.P23.N" = "Solopgang. Lejren summer af folk, der pakker tasker og går ombord på busserne. Du leder efter Yuki i mængden, dit hjerte banker hurtigt.";
"S3.P23.Q" = "Kan du finde hende?";
"S3.P23.O1" = "Kig ved bussen";
"S3.P23.O2" = "Tjek badebroen en sidste gang";

"S3.P24.N" = "Bussernes motorer summer. Du ser hende! Hun står ved porten og kigger febrilsk omkring sig, indtil hun får øje på dig.";
"S3.P24.Q" = "Løber du hen til hende?";
"S3.P24.O1" = "Løb hen og kram hende";
"S3.P24.O2" = "Vink og smil";

"S3.P25.N" = "Du når hen til hende lige i tide. Hun hvisker noget i dit øre, som du aldrig vil glemme: 'Lad ikke det her bare blive et sommerminde.'";
"S3.P25.Q" = "Hvad svarer du?";
"S3.P25.O1" = "Det lover jeg";
"S3.P25.O2" = "Vi ses næste weekend";

"S3.P26.N" = "Buschaufføren dytter. Yuki bliver nødt til at tage afsted. Hun sender dig et luftkys, mens hun træder op i bussen. Du står tilbage og ser bussen forsvinde i støvet.";
"S3.P26.Q" = "Hvad føler du?";
"S3.P26.O1" = "Glad og håbefuld";
"S3.P26.O2" = "Vemodig men tilfreds";

"S3.P27.N" = "Måneder senere. Du er i byen, og din telefon vibrerer. Det er et billede fra Yuki – hun har armbåndet på, som I delte. Sommeren sluttede aldrig rigtigt.";
"S3.P27.Q" = "SLUT";
"S3.P27.O1" = "Genstart historien";
"S3.P27.O2" = "Afslut";

"S3.P28.N" = "Du kigger på armbåndet på dit håndled. Det er lidt slidt, men minderne er friske. Nogle gange er én sommer nok til at vare hele livet.";
"S3.P28.Q" = "SLUT";
"S3.P28.O1" = "Prøv igen";
"S3.P28.O2" = "Afslut";

"newChatName" = "Scarlett";
"newChatMessage" = "Ssh... du har fundet mit hemmelige sted 💕 Jeg har gemt mig her, mens mine hænder vandrer og jeg forestiller mig hver eneste del af dig. Jeg er ikke uskyldig som de andre piger... jeg bliver så følsom og længes efter dig, når vi er alene. Fortæl mig, smukke... er du i humør til at være lidt uartig med mig i aften? 😈";
