/* Page 5 */
"S1.P5.N" = "المفتاح يناسب حجرة مخفية داخل الخزنة. تراقب إيلينا بأنفاس محبوسة بينما تخرج رزمة من الرسائل القديمة المصفرّة والمربوطة بشريط أسود.";
"S1.P5.Q" = "هل تقرأ الرسالة الأولى؟";
"S1.P5.O1" = "اقرأها بصوت عالٍ";
"S1.P5.O2" = "اسأل إيلينا عما تعرفه";

/* Page 6 */
"S1.P6.N" = "ينخفض صوت إيلينا إلى الهمس: «كانت والدتي خادمة هنا أيضاً. أخبرتني أن السيد كان يحتفظ بسجل عن فتاة أحبها يوماً.. فتاة تشبهني تماماً».";
"S1.P6.Q" = "ماذا؟ هل هذا معقول؟";
"S1.P6.O1" = "أخبريني بكل شيء";
"S1.P6.O2" = "هذا مستحيل";

/* Page 7 */
"S1.P7.N" = "تصف الرسائل قصة حب محرمة. تقترب إيلينا أكثر، وضوء القمر ينعكس على دموعها. «لم أرد السرقة.. أردت فقط أن أعرف إن كنت أنتمي لهذا المكان».";
"S1.P7.Q" = "هل تواسيها؟";
"S1.P7.O1" = "ضع يدك على كتفها";
"S1.P7.O2" = "اترك لها بعض المساحة";

/* Page 8 */
"S1.P8.N" = "توضح أن مذكرات والدتها ذكرت حقيقة مخفية في هذه الغرفة. «عشت في هذا البيت طوال حياتي يا سيدي، لكني أشعر كأنني شبح».";
"S1.P8.Q" = "هل تعدها بشيء؟";
"S1.P8.O1" = "سأساعدكِ في كشف الحقيقة";
"S1.P8.O2" = "سنحل هذا اللغز معاً";

/* Page 9 */
"S1.P9.N" = "تقضي الساعة التالية في البحث في السجلات. تجد شهادة ميلاد باسم مألوف، لكن خانة الأب فارغة.";
"S1.P9.Q" = "هل تنظر إلى إيلينا؟";
"S1.P9.O1" = "هل يعقل أن يكون والدي هو عمي؟";
"S1.P9.O2" = "ربما من الأفضل ألا نعرف";

/* Page 10 */
"S1.P10.N" = "يشتد البحث. تجد إيلينا صندوق مجوهرات مخبأ خلف الرسائل. بداخله قلادة بها صورة لامرأة تبدو كأنها توأمتها.";
"S1.P10.Q" = "هل تريها القلادة؟";
"S1.P10.O1" = "انظري إلى هذه القلادة";
"S1.P10.O2" = "هل هذه والدتكِ؟";

/* Page 11 */
"S1.P11.N" = "فجأة، تسمع صرير خشب الأرضية بالخارج. هناك شخص في الرواق. تتسع عينا إيلينا بهلع: «إذا وجدنا رئيس الخدم هنا..!»";
"S1.P11.Q" = "هل تختبئ؟";
"S1.P11.O1" = "اختبئ في الخزانة معها";
"S1.P11.O2" = "ابقَ وواجه القادم";

/* Page 12 */
"S1.P12.N" = "تقترب الخطوات. تمسك إيلينا بكمّك: «أرجوك يا سيدي، لا يمكن لأحد أن يعرف أننا وجدنا هذه الأشياء. الأمر خطر عليّ».";
"S1.P12.Q" = "ماذا تفعل؟";
"S1.P12.O1" = "أطفئ الأنوار";
"S1.P12.O2" = "أغلق الباب بالمفتاح";

/* Page 13 */
"S1.P13.N" = "يسود الظلام الغرفة. في تلك المساحة الضيقة، تسمع نبضات قلب إيلينا المتسارعة وتشم رائحة بتلات الورد من عطرها. إنها قريبة جداً.";
"S1.P13.Q" = "هل تهمس لها؟";
"S1.P13.O1" = "أنتِ في أمان معي";
"S1.P13.O2" = "(التزم الصمت وانتظر)";

/* Page 14 */
"S1.P14.N" = "تمسك الباب بإحكام. يتوقف الشخص بالخارج للحظة، ثم يبتعد. تتكئ إيلينا عليك وهي ترتجف من أثر الأدرينالين.";
"S1.P14.Q" = "هل تطمئنها؟";
"S1.P14.O1" = "لقد ذهبوا الآن";
"S1.P14.O2" = "هل أنتِ بخير؟";

/* Page 15 */
"S1.P15.N" = "تتراجع قليلاً، لكن يدها تظل عالقة على صدرك. «سيدي.. لطالما أعجبت بك من بعيد. هذا السر.. حمله ثقيل جداً بمفردي».";
"S1.P15.Q" = "مشاعرك؟";
"S1.P15.O1" = "لقد لاحظتُكِ أنا أيضاً";
"S1.P15.O2" = "أنتِ أكثر من مجرد خادمة بالنسبة لي";

/* Page 16 */
"S1.P16.N" = "تنساب منها همسة: «ظننت أنني مجرد خادمة لك.. مجرد قطعة من الأثاث. لكن الليلة تبدو كبداية لشيء حقيقي».";
"S1.P16.Q" = "هل توافقها؟";
"S1.P16.O1" = "إنه حقيقي يا إيلينا";
"S1.P16.O2" = "لنرى إلى أين سيقودنا هذا";

/* Page 17 */
"S1.P17.N" = "تفتح القلادة لتجد ملاحظة صغيرة: «إلى ابنتي، الوريثة الحقيقية». تشهق إيلينا بصدمة.. فقد يكون القصر ملكاً لها في الحقيقة.";
"S1.P17.Q" = "ما هي العواقب؟";
"S1.P17.O1" = "يجب أن نكشف هذا الأمر";
"S1.P17.O2" = "يجب أن نبقيه سراً";

/* Page 18 */
"S1.P18.N" = "تثبت الورقة أن إيلينا هي المالكة الشرعية للعقار. تنظر حول الغرفة بذهول: «أنا.. لا أريد البيت. أريد عائلة فقط».";
"S1.P18.Q" = "ماذا تريد أنت؟";
"S1.P18.O1" = "أنا معكِ الآن";
"S1.P18.O2" = "ماذا تنوين الفعل؟";

/* Page 19 */
"S1.P19.N" = "تنظر إلى المدفأة: «إذا أحرقتُ هذا، سأعود إيلينا مجدداً. إذا احتفظتُ به، سيتغير كل شيء. سيدي، ماذا أفعل؟»";
"S1.P19.Q" = "هل تنصحها؟";
"S1.P19.O1" = "أحرقيها وابقي معي";
"S1.P19.O2" = "احتفظي بها وخذي مكانكِ المستحق";

/* Page 20 */
"S1.P20.N" = "تمسك إيلينا بدليل نسبها. «اسم العائلة ملعون يا سيدي. أفضل أن أكون نكرة سعيدة على أن أكون سيدة تعيسة».";
"S1.P20.Q" = "خيارك؟";
"S1.P20.O1" = "اتبعي قلبك";
"S1.P20.O2" = "فكري في مستقبلك";

/* Page 21 */
"S1.P21.N" = "تلقي بالورقة في جمر المدفأة الخامل. يتحول السر إلى رماد. تبتسم إيلينا وهي تبدو أكثر حرية من أي وقت مضى.";
"S1.P21.Q" = "ماذا عن المستقبل؟";
"S1.P21.O1" = "بداية جديدة";
"S1.P21.O2" = "نحن الاثنين فقط";

/* Page 22 */
"S1.P22.N" = "تضع الورقة في صدر ثوبها. «إذاً سأصبح سيدة هذا القصر. وسأحتاج إلى شريك بجانبي».";
"S1.P22.Q" = "هل أنت مستعد؟";
"S1.P22.O1" = "دائماً";
"S1.P22.O2" = "سيكون طريقاً طويلاً";

/* Final 1 */
"S1.P23.N" = "لم تعد إيلينا خادمتك. لقد أصبحت نِدّك، وشريكتك، وسرّك الجميل. يظل القصر ملكك، لكن قلبه ينتمي إليها الآن.";
"S1.P23.Q" = "النهاية";
"S1.P23.O1" = "إعادة القصة";
"S1.P23.O2" = "إنهاء";

/* Final 2 */
"S1.P24.N" = "تظهر الحقيقة للعلن وتصبح إيلينا سيدة المنزل. تغيرت موازين القوى، لكن الروابط التي صنعتماها تلك الليلة لا يمكن كسرها.";
"S1.P24.Q" = "النهاية";
"S1.P24.O1" = "إعادة القصة";
"S1.P24.O2" = "إنهاء";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "المطر يضرب شوارع «شينجوكو» المضيئة بالنيون. تجلس في حانة هادئة عندما تجلس بجانبك امرأة بمعطف واقٍ من المطر مبتل. تفوح منها رائحة الياسمين والبارود.";
"S2.P0.Q" = "كيف تبدأ المحادثة؟";
"S2.P0.O1" = "اشترِ لها مشروباً";
"S2.P0.O2" = "ليلة قاسية، أليس كذلك؟";

"S2.P1.N" = "تنظر إلى الكأس، ثم إليك. تهمس: «أنت شجاع». ثم تمرر شريحة بيانات صغيرة عبر الطاولة.";
"S2.P1.Q" = "هل تأخذ الشريحة؟";
"S2.P1.O1" = "خذها وأخفِها";
"S2.P1.O2" = "لا أريد أي مشاكل";

"S2.P2.N" = "تضحك بمرارة: «ليس لديك أدنى فكرة عما ينتظرك». تنظر خلفها بحذر.. رجلان ببدلات سوداء دخلا الحانة للتو.";
"S2.P2.Q" = "هل تساعدها على الاختباء؟";
"S2.P2.O1" = "اتبعيني إلى الباب الخلفي";
"S2.P2.O2" = "تظاهري بأننا حبيبين";

"S2.P3.N" = "تجذبها نحوك. يمسح الرجلان الغرفة ثم يغادران. تبدو مرتاحة لكن يديها ترتجفان. تهمس: «أنا ميا».";
"S2.P3.Q" = "هل تسأل عن الخطر؟";
"S2.P3.O1" = "من كان هؤلاء يا ميا؟";
"S2.P3.O2" = "هل نحن في أمان الآن؟";

"S2.P4.N" = "يقترب الرجلان، لكنك تتصرف بهدوء فيمران بجانبك. تهمس: «لقد أنقذتني. أنا ميا. لكن هذه الشريحة.. تساوي حياة الملايين».";
"S2.P4.Q" = "هل تسأل عن الشريحة؟";
"S2.P4.O1" = "ماذا يوجد عليها؟";
"S2.P4.O2" = "يجب أن نخرج من هنا";

"S2.P5.N" = "تنظر ميا إلى الباب: «شركة (أراساكا) تريد هذه الشريحة. إنها ليست مجرد بيانات، إنها روح رقمية».";
"S2.P5.Q" = "هل تصدقها؟";
"S2.P5.O1" = "روح رقمية؟ حقاً؟";
"S2.P5.O2" = "لقد سمعتُ شائعات عن هذا...";

"S2.P6.N" = "تمسك ميا بيدك: «لا يوجد مكان آمن حتى نرفع هذه البيانات. نحتاج للوصول إلى المنطقة التقنية».";
"S2.P6.Q" = "هل تذهب معها؟";
"S2.P6.O1" = "سآخذكِ إلى هناك";
"S2.P6.O2" = "فقط إذا أخبرتِني بالمزيد";

"S2.P7.N" = "تتسللان من الباب الخلفي. الزقاق مظلم وتفوح منه رائحة الأوزون. فجأة، تحوم طائرة بدون طيار فوقكما، تبحث عن بصمات حرارية.";
"S2.P7.Q" = "كيف تتجنبان الطائرة؟";
"S2.P7.O1" = "اختبئا تحت المظلة";
"S2.P7.O2" = "اركضا نحو المترو";

"S2.P8.N" = "تتوقف ميا تحت المطر: «إذا أمسكوا بي، سيمسحون وجودي.. وأنت أيضاً لمساعدتك لي».";
"S2.P8.Q" = "هل تطمئنها؟";
"S2.P8.O1" = "أنا معكِ في هذا";
"S2.P8.O2" = "فلنتحرك بسرعة فحسب";

"S2.P9.N" = "تمر الطائرة. تصلان إلى سيارتك. تنظر ميا إليك بمزيج من الخوف والامتنان.";
"S2.P9.Q" = "هل تشغل المحرك؟";
"S2.P9.O1" = "انطلق بأقصى سرعة!";
"S2.P9.O2" = "قد ببطء لنندمج مع الحركة";

"S2.P10.N" = "بالكاد تصلان إلى المحطة. الحشود ضخمة وتوفر غطاءً مثالياً. تبقى ميا قريبة منك، لدرجة أن كتفها يلامس كتفك.";
"S2.P10.Q" = "هل تواصلان التحرك؟";
"S2.P10.O1" = "استقلا القطار السريع";
"S2.P10.O2" = "سِيرا عبر الأنفاق";

"S2.P11.N" = "تتحركان عبر حي الأبراج العالية. إعلانات الهولوغرام تضيء وجه ميا باللونين الوردي والأزرق.";
"S2.P11.Q" = "هل تكسر حاجز الصمت؟";
"S2.P11.O1" = "لماذا أنا يا ميا؟";
"S2.P11.O2" = "حدثيني عن الشريحة";

"S2.P12.N" = "تبدو المدينة كأنها متاهة. تتوقفان عند محل «رامن» مخفي للاستراحة لدقيقة.";
"S2.P12.Q" = "هل تراقب الشارع؟";
"S2.P12.O1" = "تحقق مما إذا كان أحد يلحق بنا";
"S2.P12.O2" = "تحدث مع ميا";

"S2.P13.N" = "تنظر ميا للأسفل: «كنت الوحيد الذي لم يبدُ كحيوان مفترس الليلة. كنت بحاجة إلى إنسان، لا إلى مرتزق».";
"S2.P13.Q" = "هل ترد بلطف؟";
"S2.P13.O1" = "أنا سعيد لأنني كنت هناك";
"S2.P13.O2" = "أنا مجرد رجل صادفتِه في حانة";

"S2.P14.N" = "تنقر ميا على الشريحة: «هذا وعي شقيقتي. كانت مخترقة شبكات رأت أكثر مما ينبغي، فقاموا بـ (قتل) جسدها».";
"S2.P14.Q" = "هل تظهر تعاطفك؟";
"S2.P14.O1" = "هذا مروع...";
"S2.P14.O2" = "هل يمكن إنقاذها؟";

"S2.P15.N" = "تمسح دمعة من عينها: «نقطة الرفع في برج التلفزيون القديم. لكن الجسر مغلق بنقطة تفتيش للشرطة».";
"S2.P15.Q" = "كيف تعبران؟";
"S2.P15.O1" = "استخدم مهاراتك في الاختراق";
"S2.P15.O2" = "ارْشِ الحراس";

"S2.P16.N" = "تريك ميا خريطة: «إذا سلكنا طريق المجاري، سيكون الأمر أكثر أماناً، لكن الطريق طويل».";
"S2.P16.Q" = "أي طريق تختار؟";
"S2.P16.O1" = "فلنسلك طريق المجاري";
"S2.P16.O2" = "لا، نحن بحاجة للسرعة";

"S2.P17.N" = "المكان متسخ ومظلم، لكنه فعال. تعتمد ميا على توجيهاتك، وتشعر بثقل ثقتها فيك.";
"S2.P17.Q" = "هل تساعدها على تجاوز فجوة؟";
"S2.P17.O1" = "مد يدك لها";
"S2.P17.O2" = "تقدم الطريق";

"S2.P18.N" = "الجسر يعمه الفوضى. تستغلان هذا الارتباك للتسلل. نبضات قلب ميا سريعة جداً لدرجة أنك تكاد تسمعها.";
"S2.P18.Q" = "هل تهدئ من روعها؟";
"S2.P18.O1" = "لقد اقتربنا من الوصول";
"S2.P18.O2" = "ابقي مركزة يا ميا";

"S2.P19.N" = "برج التلفزيون يلوح في الأفق. إنه أثر من العالم القديم محاط بالفولاذ الحديث. تبدو ميا منهكة.";
"S2.P19.Q" = "هل تعرض عليها استراحة؟";
"S2.P19.O1" = "استريحا لمدة 5 دقائق";
"S2.P19.O2" = "واصلا الضغط حتى النهاية";

"S2.P20.N" = "تصلان إلى قاعدة البرج. تتنهد ميا: «المصعد معطل. علينا التسلّق».";
"S2.P20.Q" = "هل تشجعها؟";
"S2.P20.O1" = "خطوة بخطوة";
"S2.P20.O2" = "سأحمل المعدات عنكِ";

"S2.P21.N" = "تجلسان على الدرج. تتكئ ميا عليك: «إذا نجحنا.. ماذا ستفعل غداً؟»";
"S2.P21.Q" = "هل تفكر في المستقبل؟";
"S2.P21.O1" = "ربما يمكننا احتساء القهوة معاً";
"S2.P21.O2" = "سأكون سعيداً بالنوم فقط";

"S2.P22.N" = "التسلق شاق. في منتصف الطريق، تسمعان صفارات الإنذار بالأسفل. لقد وجدوا سيارتك.";
"S2.P22.Q" = "هل تسرعان؟";
"S2.P22.O1" = "ضاعف السرعة!";
"S2.P22.O2" = "ابحث عن مكان للاختباء";

"S2.P23.N" = "تصلان إلى غرفة الخادم. الهواء بارد ويعج بالطاقة. توصل ميا الشريحة وتقول: «بدء التهيئة...»";
"S2.P23.Q" = "هل تراقب الشاشة؟";
"S2.P23.O1" = "احرس الباب";
"S2.P23.O2" = "ابقَ بجانب ميا";

"S2.P24.N" = "الجهاز قديم ولكنه يعمل. أصابع ميا تطير فوق المفاتيح: «جدار الحماية ضخم!»";
"S2.P24.Q" = "هل تساعدها في الاختراق؟";
"S2.P24.O1" = "تجاوز نظام الطاقة";
"S2.P24.O2" = "حافظ على ثباتها";

"S2.P25.N" = "يصدر الباب فحيحاً. فريق «أراساكا» التكتيكي وصل. تشهر سلاحك. تصرخ ميا: «دقيقتان فقط!»";
"S2.P25.Q" = "هل تصمد؟";
"S2.P25.O1" = "افتح النار!";
"S2.P25.O2" = "ضع حاجزاً على الباب";

"S2.P26.N" = "عينا ميا تلمعان باللون الأزرق، إنها في أعماق الشبكة. الجنود يقتحمون السقف الزجاجي.";
"S2.P26.Q" = "هل تحمي ميا؟";
"S2.P26.O1" = "غطِّها بجسدك";
"S2.P26.O2" = "اسحبها لمكان آمن";

"S2.P27.N" = "وميض ضوء مبهر. اكتمل الرفع بنسبة 100%. الجنود يتجمدون.. فقد تعطلت أجهزتهم السيبرانية من الشبكة.";
"S2.P27.Q" = "هل تطمئن على ميا؟";
"S2.P27.O1" = "هل انتهى الأمر؟";
"S2.P27.O2" = "هل أنتِ بخير؟";

"S2.P28.N" = "يظلم كل شيء. ثم تضيء كل شاشة في طوكيو برسالة واحدة: «الحرية». تنهار ميا بين ذراعيك.";
"S2.P28.Q" = "هل توقظها؟";
"S2.P28.O1" = "ميا! كلميني!";
"S2.P28.O2" = "احتضنها بقوة";

"S2.P29.N" = "تبدأ الشمس بالشروق فوق طوكيو مختلفة. تبتسم ميا، وعيناها عادت لطبيعتها: «إنها في أمان.. نحن في أمان».";
"S2.P29.Q" = "النهاية";
"S2.P29.O1" = "إعادة القصة";
"S2.P29.O2" = "إنهاء";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "الليلة الأخيرة في المخيم الصيفي. نار المخيم تخمد، ورائحة صنوبر الغابة تملأ الأرجاء. «يوكي»، الخجولة عادة، تجذب انتباهك وتشير نحو الطريق المظلم المؤدي للبحيرة.";
"S3.P0.Q" = "هل تتبعها في سكون الليل؟";
"S3.P0.O1" = "لطالما انتظرتُ هذه اللحظة";
"S3.P0.O2" = "بالتأكيد، لنذهب";

"S3.P1.N" = "تلحق بها. الغابة تنبض بصوت صرصار الليل. تلامس يد يوكي يدك أحياناً أثناء المشي. تبدو متوترة.";
"S3.P1.Q" = "كيف تكسر حاجز الصمت؟";
"S3.P1.O1" = "أمسك يدها بثبات";
"S3.P1.O2" = "اسألها عما يدور في ذهنها";

"S3.P2.N" = "تمشيان جنباً إلى جنب. ضوء القمر بالكاد يخترق الأشجار الكثيفة. تنظر إليك يوكي بنصف نظرة مبتسمة بهدوء: «لم أظن أنك ستأتي حقاً»، تهمس.";
"S3.P2.Q" = "بماذا تجيب؟";
"S3.P2.O1" = "ما كنت لأفوت هذا أبداً";
"S3.P2.O2" = "كنت فضولياً فحسب";

"S3.P3.N" = "تصلان إلى الرصيف الخشبي. الماء يبدو كمرآة مظلمة تعكس بحراً من النجوم. تخلع يوكي حذاءها وتجلس على الحافة، وتدلي قدميها.";
"S3.P3.Q" = "هل تجلس بالقرب منها؟";
"S3.P3.O1" = "اجلس بجانبها تماماً";
"S3.P3.O2" = "اترك لها بعض المساحة";

"S3.P4.N" = "يصدر الرصيف صريراً تحت وزنك. هواء البحيرة البارد يجعل يوكي ترتجف قليلاً، لكنها لا تبتعد حين تقترب منها.";
"S3.P4.Q" = "هل تعطيها سُترتك؟";
"S3.P4.O1" = "ضع سُترتك على كتفيها";
"S3.P4.O2" = "اجلس وتحدث معها فقط";

"S3.P5.N" = "تنظر يوكي إلى النجوم: «هل تتذكر أول يوم لنا هنا؟ ساعدتني في حمل حقائبي بينما كان الجميع مشغولاً».";
"S3.P5.Q" = "هل تتذكر ذلك؟";
"S3.P5.O1" = "أتذكر كل تفصيل";
"S3.P5.O2" = "يبدو الأمر كأنه حدث منذ دهر";

"S3.P6.N" = "تضحك بهدوء: «كنت خائفة جداً حينها. لكن رؤيتك جعلتني أشعر بأنني أنتمي لهذا المكان». ثم تنظر إلى الماء.";
"S3.P6.Q" = "هل تعترف بمشاعرك؟";
"S3.P6.O1" = "كنتُ أشعر بنفس الشيء";
"S3.P6.O2" = "أنا سعيد لأنني استطعت المساعدة";

"S3.P7.N" = "الليل ساكن تماماً. فجأة، تقف يوكي قائلة: «الماء يبدو مغرياً جداً.. هل نغوص؟» تسألك بلمعة شقاوة في عينيها.";
"S3.P7.Q" = "هل تملك الشجاعة؟";
"S3.P7.O1" = "لنقفز معاً!";
"S3.P7.O2" = "الماء بارد جداً يا يوكي";

"S3.P8.N" = "تنظر إلى البحيرة ثم إليك: «أريد أن أفعل شيئاً شجاعاً الليلة. شيئاً أتذكره طوال الشتاء».";
"S3.P8.Q" = "هل تشجعها؟";
"S3.P8.O1" = "هل تقفزين معي؟";
"S3.P8.O2" = "فلنبقَ هنا";

"S3.P9.N" = "بوم! الماء بارد لكنه منعش. تطفو أنت ويوكي على السطح، تلهثان وتضحكان، وترشقان بعضكما بالماء كالأطفال.";
"S3.P9.Q" = "هل تسبح مقترباً منها؟";
"S3.P9.O1" = "اجذبها لعناق دافئ";
"S3.P9.O2" = "استمرا في اللعب بالماء!";

"S3.P10.N" = "تبقيان على الرصيف. تتحدثان لساعات عن كل شيء.. المدرسة، الأهل، والمستقبل. الرابط بينكما يقوى في صمت الليل.";
"S3.P10.Q" = "هل تقترب أكثر؟";
"S3.P10.O1" = "أرح رأسك على رأسها";
"S3.P10.O2" = "انظر في عينيها مباشرة";

"S3.P11.N" = "يتغير الجو العام. تتوقف يوكي عن الكلام. في الضوء الخافت، تبحث عيناها في عينيك. تهمس: «لا أريد العودة إلى المدينة غداً».";
"S3.P11.Q" = "ماذا تقول؟";
"S3.P11.O1" = "سنتقابل هناك بالتأكيد";
"S3.P11.O2" = "لنؤجل التفكير في الغد";

"S3.P12.N" = "تأخذ يوكي نفساً عميقاً: «إذا لم أقل هذا الآن، فلن أقوله أبداً. لقد أعجبتُ بك منذ ذلك اليوم الأول في موقف الحافلة».";
"S3.P12.Q" = "كيف تكون ردة فعلك؟";
"S3.P12.O1" = "أنا أيضاً معجب بكِ";
"S3.P12.O2" = "أخيراً.. ظهرت الحقيقة!";

"S3.P13.N" = "تخرج من جيبها سوار صداقة صنعته يدوياً باللونين الأزرق والأبيض، ألوان البحيرة. تقول بخجل: «صنعتُ هذا من أجلك».";
"S3.P13.Q" = "هل تقبل الهدية؟";
"S3.P13.O1" = "دعها تربطه حول معصمك";
"S3.P13.O2" = "بادرها بقبلة بدلاً من ذلك";

"S3.P14.N" = "السوار بسيط، لكنك تعلم أنه استغرق منها ساعات. تنتظر رد فعلك، وشفتاها ترتجفان قليلاً.";
"S3.P14.Q" = "ما هي خطوتك التالية؟";
"S3.P14.O1" = "اشكرها بعناق";
"S3.P14.O2" = "أخبرها أنه رائع حقاً";

"S3.P15.N" = "تبتسم يوكي ابتسامة مشرقة: «كنت قلقة من أن تظنه طفولياً». تنظر إلى القمر وهي تبدو أكثر ثقة الآن.";
"S3.P15.Q" = "هل تعدها بشيء؟";
"S3.P15.O1" = "عِدها بالاتصال بها يومياً";
"S3.P15.O2" = "عِدها بزيارتها قريباً";

"S3.P16.N" = "الأجواء مشحونة بالمشاعر. يوكي تحدق في شفتيك. العالم من حولكما يختفي، ولا يتبقى سوى أنتما وليلة الصيف.";
"S3.P16.Q" = "هل هذه هي اللحظة؟";
"S3.P16.O1" = "اقترب لتقبيلها";
"S3.P16.O2" = "اهمس بشيء عذب";

"S3.P17.N" = "في تلك اللحظة، يمر شهاب في السماء مخلفاً وراءه ذيلاً فضياً. تشهق يوكي: «بسرعة! تمنّ أمنية!»";
"S3.P17.Q" = "بماذا تتمنى؟";
"S3.P17.O1" = "تمنّ مستقبلاً يجمعكما";
"S3.P17.O2" = "تمنّ أن تدوم هذه الليلة للأبد";

"S3.P18.N" = "يختفي الشهاب بسرعة. تغلق يوكي عينيها بقوة: «لقد تمنيتُ شيئاً مهماً جداً»، تقول وهي محمرة الخجل.";
"S3.P18.Q" = "هل تسألها عن أمنيتها؟";
"S3.P18.O1" = "أخبريني بماذا تمنيتِ؟";
"S3.P18.O2" = "أعتقد أنني أعرف أمنيتكِ";

"S3.P19.N" = "نار المخيم انطفأت تماماً الآن. تبدآن السير عائدين يداً بيد. الغابة تبدو مختلفة الآن.. أقل رعباً وأكثر سحراً.";
"S3.P19.Q" = "هل تمشيان ببطء؟";
"S3.P19.O1" = "اسلكا الطريق الأطول للعودة";
"S3.P19.O2" = "استمتعا بالصمت معاً";

"S3.P20.N" = "تمران بشجرة البلوط القديمة حيث التقيتما أول مرة. تتوقف يوكي للحظة: «كل شيء سيتغير الآن، أليس كذلك؟» تسأل بنعومة.";
"S3.P20.Q" = "هل تواسيها؟";
"S3.P20.O1" = "التغيير قد يكون للأفضل";
"S3.P20.O2" = "ليس بالضرورة أن يتغير كل شيء";

"S3.P21.N" = "أكواخ المخيم تظهر في الأفق، والجميع نائمون. تتوقف يوكي عند باب كوخها، ولا يبدو أنها تريد ترك يدك.";
"S3.P21.Q" = "شيء أخير؟";
"S3.P21.O1" = "اطلب قبلة وداع";
"S3.P21.O2" = "اطلب رقم هاتفها";

"S3.P22.N" = "تتردد يوكي عند الباب. ضوء الشرفة يلقي ظلاً ناعماً على وجهها: «شكراً على هذه الليلة. لقد كانت أجمل ليلة في حياتي».";
"S3.P22.Q" = "هل تودعها؟";
"S3.P22.O1" = "أراكِ في الصباح";
"S3.P22.O2" = "طابت ليلتك يا يوكي";

"S3.P23.N" = "شروق الشمس. المخيم يضج بالناس الذين يحزمون أمتعتهم ويصعدون الحافلات. تبحث عن يوكي بين الزحام وقلبك يخفق بشدة.";
"S3.P23.Q" = "هل تجدها؟";
"S3.P23.O1" = "ابحث بجانب الحافلة";
"S3.P23.O2" = "تحقق من الرصيف للمرة الأخيرة";

"S3.P24.N" = "محركات الحافلات تعمل. لقد رأيتها! إنها تقف عند البوابة، وتنظر حولها بلهفة حتى تراك.";
"S3.P24.Q" = "هل تركض نحوها؟";
"S3.P24.O1" = "اركض وعانقها";
"S3.P24.O2" = "لوح لها بابتسامة";

"S3.P25.N" = "تصل إليها في الوقت المناسب. تهمس في أذنك بشيء لن تنساه أبداً: «لا تجعل هذا مجرد ذكرى صيفية».";
"S3.P25.Q" = "بماذا تجيب؟";
"S3.P25.O1" = "أعدكِ بذلك";
"S3.P25.O2" = "سأراكِ في عطلة نهاية الأسبوع القادمة";

"S3.P26.N" = "يطلق سائق الحافلة بوقه. يجب على يوكي المغادرة. ترسل لك قبلة في الهواء وهي تصعد. تقف هناك تراقب الحافلة وهي تختفي وسط الغبار.";
"S3.P26.Q" = "بماذا تشعر؟";
"S3.P26.O1" = "سعيد ومليء بالأمل";
"S3.P26.O2" = "حزين لكنني مرتاح";

"S3.P27.N" = "بعد عدة أشهر.. أنت في المدينة، هاتفك يهتز. إنها صورة من يوكي.. ترتدي السوار الذي أعطتك إياه. الصيف لم ينتهِ حقاً.";
"S3.P27.Q" = "النهاية";
"S3.P27.O1" = "إعادة القصة";
"S3.P27.O2" = "إنهاء";

"S3.P28.N" = "تنظر إلى السوار حول معصمك. لقد بلي قليلاً، لكن الذكريات لا تزال حية. أحياناً، صيف واحد يكفي ليدوم مدى الحياة.";
"S3.P28.Q" = "النهاية";
"S3.P28.O1" = "حاول مجدداً";
"S3.P28.O2" = "إنهاء";
