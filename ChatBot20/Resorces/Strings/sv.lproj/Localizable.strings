/* STORY 1: THE MAID'S SECRET */

/* Page 0 */
"S1.P0.N" = "Herrgården är tyst när du kommer hem. Ett svagt ljus flimrar i din arbetslystnad. Du hittar Elena, din tystlåtna tjänsteflicka, som nervöst städar ditt skrivbord mitt i natten.";
"S1.P0.Q" = "Gå fram till henne?";
"S1.P0.O1" = "Elena, varför ligger du inte i din säng?";
"S1.P0.O2" = "(Betrakta henne från skuggorna)";

/* Page 1 */
"S1.P1.N" = "Hon flämtar till och tappar dammvippan. 'Herre! Jag... jag kunde inte sova. Dammet störde mig.' Hon ser blek ut och undviker din blick.";
"S1.P1.Q" = "Tror du på henne?";
"S1.P1.O1" = "Det är för sent för att städa";
"S1.P1.O2" = "Du är verkligen hängiven ditt arbete";

/* Page 2 */
"S1.P2.N" = "Du ser hur hon drar fram en liten silvernyckel ur sitt förkläde. Hon stirrar på den med en blandning av längtan och rädsla innan hon märker din skugga.";
"S1.P2.Q" = "Ta ett steg framåt?";
"S1.P2.O1" = "Vad är det för nyckel, Elena?";
"S1.P2.O2" = "Förklara dig omedelbart";

/* Page 3 */
"S1.P3.N" = "Hon darrar. 'Det här huset... det bär på så många hemligheter, herre. Ibland känns de tunga att bära.' Hon pekar mot det gamla kassaskåpet bakom bokhyllan.";
"S1.P3.Q" = "Fråga om kassaskåpet?";
"S1.P3.O1" = "Går nyckeln dit?";
"S1.P3.O2" = "Kassaskåpet är strikt förbjudet";

/* Page 4 */
"S1.P4.N" = "Hon försöker gömma nyckeln, men den faller i golvet. 'Jag är ingen tjuv, jag lovar! Jag bara... jag såg den i korridoren och trodde den var er.'";
"S1.P4.Q" = "Plocka upp nyckeln?";
"S1.P4.O1" = "(Plocka upp den)";
"S1.P4.O2" = "Låt oss se vad den öppnar";

/* Page 5 */
"S1.P5.N" = "Nyckeln passar i ett dolt fack inuti kassaskåpet. Elena tittar på med spänning när du tar fram en bunt gamla, gulnade brev sammanbundna med ett svart sidenband.";
"S1.P5.Q" = "Läs det översta brevet?";
"S1.P5.O1" = "Läs det högt";
"S1.P5.O2" = "Fråga Elena vad hon vet";

/* Page 6 */
"S1.P6.N" = "Elenas röst sänks till en viskning. 'Min mor var också tjänsteflicka här. Hon berättade att Husherren bevarade minnen av en kvinna han en gång älskat. En kvinna som såg ut precis som jag.'";
"S1.P6.Q" = "Vänta, vad sa du?";
"S1.P6.O1" = "Berätta allt";
"S1.P6.O2" = "Detta är omöjligt";

/* Page 7 */
"S1.P7.N" = "Breven beskriver en förbjuden romans. Elena tar ett steg närmare, och månskenet glittrar i hennes tårar. 'Jag ville inte stjäla. Jag ville bara veta om jag hör hemma här.'";
"S1.P7.Q" = "Trösta henne?";
"S1.P7.O1" = "Lägg en hand på hennes axel";
"S1.P7.O2" = "Ge henne lite utrymme";

/* Page 8 */
"S1.P8.N" = "Hon förklarar att hennes mors dagbok nämnde en dold sanning i det här rummet. 'Jag har bott i det här huset hela mitt liv, herre, men jag känner mig som ett spöke.'";
"S1.P8.Q" = "Ge henne ett löfte?";
"S1.P8.O1" = "Jag ska hjälpa dig att finna sanningen";
"S1.P8.O2" = "Vi ska lösa detta tillsammans";

/* Page 9 */
"S1.P9.N" = "Du tillbringar nästa timme med att gå igenom dokumenten. Du hittar ett födelsebevis med ett bekant namn, men fältet för fadern är tomt.";
"S1.P9.Q" = "Titta på Elena?";
"S1.P9.O1" = "Kan det ha varit min farbror?";
"S1.P9.O2" = "Kanske är det bäst att inte veta";

/* Page 10 */
"S1.P10.N" = "Sökandet blir mer intensivt. Elena hittar ett smyckeskrin gömt bakom breven. Inuti finns en medaljong med ett porträtt av en kvinna som är hennes avbild.";
"S1.P10.Q" = "Visa henne?";
"S1.P10.O1" = "Titta på den här medaljongen";
"S1.P10.O2" = "Är detta din mor?";

/* Page 11 */
"S1.P11.N" = "Plötsligt knarrar ett golvbräde utanför. Någon är i korridoren. Elenas ögon spärras upp av panik. 'Om hovmästaren hittar oss...!'";
"S1.P11.Q" = "Gömma er?";
"S1.P11.O1" = "Göm dig i garderoben med henne";
"S1.P11.O2" = "Stanna kvar och möt dem";

/* Page 12 */
"S1.P12.N" = "Fotsteg närmar sig. Elena tar tag i din ärm. 'Snälla herre, ingen får veta att vi hittat dessa. Det är farligt för mig.'";
"S1.P12.Q" = "Din reaktion?";
"S1.P12.O1" = "Släck ljusen";
"S1.P12.O2" = "Lås dörren";

/* Page 13 */
"S1.P13.N" = "Rummet är kolsvart. I det trånga utrymmet hör du Elenas snabba hjärtslag och doften av rosenblad från hennes hud. Hon är otroligt nära.";
"S1.P13.Q" = "Viska till henne?";
"S1.P13.O1" = "Du är säker hos mig";
"S1.P13.O2" = "(Var tyst och vänta)";

/* Page 14 */
"S1.P14.N" = "Du håller dörren stängd. Personen utanför dröjer kvar ett ögonblick och går sedan sin väg. Elena lutar sig mot dig, darrande av adrenalin.";
"S1.P14.Q" = "Lugna henne?";
"S1.P14.O1" = "De är borta nu";
"S1.P14.O2" = "Gick det bra?";

/* Page 15 */
"S1.P15.N" = "Hon drar sig undan en aning, men hennes hand dröjer kvar mot ditt bröst. 'Herre... jag har alltid beundrat er på avstånd. Den här hemligheten... den är för tung att bära ensam.'";
"S1.P15.Q" = "Dina känslor?";
"S1.P15.O1" = "Jag har lagt märke till dig också";
"S1.P15.O2" = "Du är mer än bara en tjänsteflicka";

/* Page 16 */
"S1.P16.N" = "'Jag trodde att jag bara var en tjänare för er,' viskar hon. 'Bara en del av inredningen. Men i natt känns det som början på något äkta.'";
"S1.P16.Q" = "Håller du med?";
"S1.P16.O1" = "Det är äkta, Elena";
"S1.P16.O2" = "Låt oss se var detta leder";

/* Page 17 */
"S1.P17.N" = "Hon öppnar medaljongen. Inuti finns en liten lapp: 'Till min dotter, den sanna arvtagerskan.' Elena flämtar. Herrgården kan i själva verket tillhöra henne.";
"S1.P17.Q" = "Konsekvenserna?";
"S1.P17.O1" = "Vi måste avslöja detta";
"S1.P17.O2" = "Vi borde hålla det hemligt";

/* Page 18 */
"S1.P18.N" = "Lappen bevisar att Elena är den rättmätige ägaren till egendomen. Hon ser sig om i rummet, omtumlad. 'Jag... jag vill inte ha huset. Jag vill bara ha en familj.'";
"S1.P18.Q" = "Vad vill du?";
"S1.P18.O1" = "Du har mig nu";
"S1.P18.O2" = "Vad tänker du göra?";

/* Page 19 */
"S1.P19.N" = "Hon tittar mot eldstaden. 'Om jag bränner upp detta är jag bara Elena igen. Om jag behåller det förändras allt. Herre, vad ska jag göra?'";
"S1.P19.Q" = "Ge henne råd?";
"S1.P19.O1" = "Bränn det och stanna hos mig";
"S1.P19.O2" = "Behåll det och ta din rättmätiga plats";

/* Page 20 */
"S1.P20.N" = "Elena håller beviset på sin härkomst. 'Släktnamnet är förbannat, herre. Jag är hellre en lycklig ingen än en olycklig dam.'";
"S1.P20.Q" = "Ditt val?";
"S1.P20.O1" = "Följ ditt hjärta";
"S1.P20.O2" = "Tänk på din framtid";

/* Page 21 */
"S1.P21.N" = "Hon kastar pappret i den falnande glöden. Hemligheten blir till aska. Elena ler och ser mer fri ut än någonsin tidigare.";
"S1.P21.Q" = "Framtiden?";
"S1.P21.O1" = "En ny början";
"S1.P21.O2" = "Bara vi två";

/* Page 22 */
"S1.P22.N" = "Hon stoppar ner pappret i sitt snörliv. 'Då ska jag bli damen i detta hus. Och jag kommer att behöva en partner vid min sida.'";
"S1.P22.Q" = "Är du redo?";
"S1.P22.O1" = "Alltid";
"S1.P22.O2" = "Det kommer att bli en lång väg";

/* Final 1 */
"S1.P23.N" = "Elena är inte längre din tjänsteflicka. Hon är din jämlike, din partner och din hemlighet. Herrgården förblir din, men dess hjärta tillhör henne.";
"S1.P23.Q" = "SLUT";
"S1.P23.O1" = "Börja om";
"S1.P23.O2" = "Avsluta";

/* Final 2 */
"S1.P24.N" = "Sanningen kommer fram. Elena blir hushållets överhuvud. Maktbalansen har skiftat, men bandet ni knöt den natten är obrytbart.";
"S1.P24.Q" = "SLUT";
"S1.P24.O1" = "Börja om";
"S1.P24.O2" = "Avsluta";

/* STORY 2: MIDNIGHT TOKYO */
"S2.P0.N" = "Regnet piskar mot Shinjukus neonbelysta gator. Du sitter i en lugn bar när en kvinna i våt trenchcoat sätter sig bredvid dig. Hon doftar jasmin och krut.";
"S2.P0.Q" = "Hur börjar du samtala?";
"S2.P0.O1" = "Bjud henne på en drink";
"S2.P0.O2" = "Tuff natt, eller hur?";

"S2.P1.N" = "Hon tittar på glaset, sedan på dig. 'Du är modig,' viskar hon. Hon skjuter fram ett litet datachip över disken.";
"S2.P1.Q" = "Ta emot chippet?";
"S2.P1.O1" = "Ta det och göm det";
"S2.P1.O2" = "Jag vill inte ha några problem";

"S2.P2.N" = "Hon ger ifrån sig ett bittert skratt. 'Du har ingen aning.' Hon tittar över axeln. Två män i svarta kostymer har precis klivit in i baren.";
"S2.P2.Q" = "Hjälpa henne att gömma sig?";
"S2.P2.O1" = "Följ med mig till bakdörren";
"S2.P2.O2" = "Låtsas att vi är ett par";

"S2.P3.N" = "Du drar henne intill dig. Männen söker av rummet och går sedan. Hon ser lättad ut men hennes händer darrar. 'Jag är Mia,' viskar hon.";
"S2.P3.Q" = "Fråga om faran?";
"S2.P3.O1" = "Vem var det där, Mia?";
"S2.P3.O2" = "Är vi säkra nu?";

"S2.P4.N" = "Männen närmar sig, men du spelar kall. De går förbi. Hon viskar: 'Du räddade mig. Jag är Mia. Men det här chippet... det är värt en miljon liv.'";
"S2.P4.Q" = "Fråga om chippet?";
"S2.P4.O1" = "Vad finns på det?";
"S2.P4.O2" = "Vi borde ta oss härifrån";

"S2.P5.N" = "Mia tittar mot dörren. 'Företaget Arasaka vill ha det här. Det är inte bara data, det är en digital själ.'";
"S2.P5.Q" = "Tror du på henne?";
"S2.P5.O1" = "En digital själ? På riktigt?";
"S2.P5.O2" = "Jag har hört rykten...";

"S2.P6.N" = "Mia tar din hand. 'Ingenstans är säkert förrän vi laddar upp detta. Vi måste nå Tech-distriktet.'";
"S2.P6.Q" = "Följa med henne?";
"S2.P6.O1" = "Jag tar dig dit";
"S2.P6.O2" = "Bara om du berättar mer";

"S2.P7.N" = "Ni slinker ut genom bakvägen. Gränden är mörk och luktar ozon. Plötsligt surrar en drönare ovanför, sökande efter värmesignaturer.";
"S2.P7.Q" = "Hur undviker ni drönaren?";
"S2.P7.O1" = "Göm er under markisen";
"S2.P7.O2" = "Spring mot tunnelbanan";

"S2.P8.N" = "Mia stannar i regnet. 'Om de fångar mig kommer de att radera mig. Och dig också, för att du hjälpte till.'";
"S2.P8.Q" = "Lugna henne?";
"S2.P8.O1" = "Jag är med dig i det här";
"S2.P8.O2" = "Låt oss bara röra oss, snabbt";

"S2.P9.N" = "Drönaren passerar. Ni når din bil. Mia tittar på dig med en blandning av rädsla och tacksamhet.";
"S2.P9.Q" = "Starta motorn?";
"S2.P9.O1" = "Plattan i mattan!";
"S2.P9.O2" = "Kör långsamt, smält in i mängden";

"S2.P10.N" = "Ni hinner precis till stationen. Folkmassan är enorm och ger perfekt skydd. Mia håller sig nära, hennes axel nuddar din.";
"S2.P10.Q" = "Fortsätta gå?";
"S2.P10.O1" = "Ta expresståget";
"S2.P10.O2" = "Gå genom tunnlarna";

"S2.P11.N" = "Ni rör er genom skyskrapsdistriktet. De holografiska reklamerna lyser upp Mias ansikte i rosa och blått.";
"S2.P11.Q" = "Bryta tystnaden?";
"S2.P11.O1" = "Varför jag, Mia?";
"S2.P11.O2" = "Berätta om chippet";

"S2.P12.N" = "Staden känns som en labyrint. Ni stannar vid ett dolt ramenställe för att vila en minut.";
"S2.P12.Q" = "Bevaka gatan?";
"S2.P12.O1" = "Kolla om vi är förföljda";
"S2.P12.O2" = "Prata med Mia";

"S2.P13.N" = "Mia tittar ner. 'Du var den enda som inte såg ut som ett rovdjur i natt. Jag behövde en människa, inte en legosoldat.'";
"S2.P13.Q" = "Svara vänligt?";
"S2.P13.O1" = "Jag är glad att jag var där";
"S2.P13.O2" = "Jag är bara en kille i en bar";

"S2.P14.N" = "Mia rör vid chippet. 'Det här är min systers medvetande. Hon var en netrunner som såg för mycket. De 'dödade' hennes kropp.'";
"S2.P14.Q" = "Visa medkänsla?";
"S2.P14.O1" = "Det är hemskt...";
"S2.P14.O2" = "Kan hon räddas?";

"S2.P15.N" = "Hon torkar en tår. 'Uppladdningspunkten finns i det gamla TV-tornet. Men bron är blockerad av en poliskontroll.'";
"S2.P15.Q" = "Hur tar ni er över?";
"S2.P15.O1" = "Använd dina hackerkunskaper";
"S2.P15.O2" = "Muta vakterna";

"S2.P16.N" = "Mia visar en karta. 'Om vi går genom kloakerna är det säkrare, men det är en lång väg.'";
"S2.P16.Q" = "Välj väg?";
"S2.P16.O1" = "Låt oss ta kloakerna";
"S2.P16.O2" = "Nej, vi måste vara snabba";

"S2.P17.N" = "Det är smutsigt och mörkt, men effektivt. Mia litar på din vägledning. Du känner tyngden av hennes förtroende.";
"S2.P17.Q" = "Hjälpa henne över ett hinder?";
"S2.P17.O1" = "Ge henne en hand";
"S2.P17.O2" = "Visa vägen";

"S2.P18.N" = "Det är kaos vid bron. Ni utnyttjar förvirringen för att slinka förbi. Mias hjärta slår så snabbt att du nästan kan höra det.";
"S2.P18.Q" = "Hålla henne lugn?";
"S2.P18.O1" = "Vi är nästan framme";
"S2.P18.O2" = "Håll fokus, Mia";

"S2.P19.N" = "TV-tornet tornar upp sig framför er. Det är en relik från den gamla världen, omgiven av modernt stål. Mia ser utmattad ut.";
"S2.P19.Q" = "Erbjuda en paus?";
"S2.P19.O1" = "Vila i fem minuter";
"S2.P19.O2" = "Fortsätt ända till slutet";

"S2.P20.N" = "Ni når tornets bas. 'Hissen fungerar inte,' suckar Mia. 'Vi måste klättra.'";
"S2.P20.Q" = "Uppmuntra henne?";
"S2.P20.O1" = "Ett steg i taget";
"S2.P20.O2" = "Jag bär utrustningen";

"S2.P21.N" = "Ni sitter i trappan. Mia lutar sig mot dig. 'Om vi klarar det... vad gör du i morgon?'";
"S2.P21.Q" = "Tänka på framtiden?";
"S2.P21.O1" = "Kanske kan vi ta en kaffe";
"S2.P21.O2" = "Jag kommer bara vara glad över att få sova";

"S2.P22.N" = "Klättringen är brutal. Halvvägs upp hör ni sirener nedanför. De har hittat din bil.";
"S2.P22.Q" = "Skynda på?";
"S2.P22.O1" = "Dubbla tempot!";
"S2.P22.O2" = "Hitta ett ställe att gömma er på";

"S2.P23.N" = "Ni når serverrummet. Luften är kall och surrar av kraft. Mia ansluter chippet. 'Initierar...' säger hon.";
"S2.P23.Q" = "Bevaka skärmen?";
"S2.P23.O1" = "Vakta dörren";
"S2.P23.O2" = "Stanna vid Mias sida";

"S2.P24.N" = "Terminalen är urgammal men fungerar. Mias fingrar flyger över tangenterna. 'Brandväggen är enorm!'";
"S2.P24.Q" = "Hjälpa henne hacka?";
"S2.P24.O1" = "Forcera strömtillförseln";
"S2.P24.O2" = "Håll henne stadig";

"S2.P25.N" = "Dörrarna pyser. Arasakas insatsstyrka är här. Du drar ditt vapen. 'Bara två minuter till!' skriker Mia.";
"S2.P25.Q" = "Hålla ställningarna?";
"S2.P25.O1" = "Öppna eld!";
"S2.P25.O2" = "Barrikadera dörren";

"S2.P26.N" = "Mias ögon lyser blått. Hon är djupt inne i nätet. Soldaterna bryter sig igenom glastaket.";
"S2.P26.Q" = "Skydda Mia?";
"S2.P26.O1" = "Skydda henne med din kropp";
"S2.P26.O2" = "Dra henne i skydd";

"S2.P27.N" = "En bländande ljusblixt. Uppladdningen är klar. Soldaterna stelnar – deras cybernetik har störts ut från nätet.";
"S2.P27.Q" = "Se hur det gick för Mia?";
"S2.P27.O1" = "Är det klart?";
"S2.P27.O2" = "Är du okej?";

"S2.P28.N" = "Allt blir mörkt. Sedan tänds varenda skärm i Tokyo med ett enda meddelande: 'FRIHET'. Mia faller ihop i dina armar.";
"S2.P28.Q" = "Väcka henne?";
"S2.P28.O1" = "Mia! Prata med mig!";
"S2.P28.O2" = "Håll henne hårt";

"S2.P29.N" = "Solen börjar gå upp över ett annorlunda Tokyo. Mia ler, hennes ögon är normala igen. 'Hon är säker. Vi är säkra.'";
"S2.P29.Q" = "SLUT";
"S2.P29.O1" = "Börja om";
"S2.P29.O2" = "Avsluta";

/* STORY 3: SUMMER CAMP */
"S3.P0.N" = "Sista natten på sommarlägret. Den sprakande lägerelden falnar och doften av tallbarr finns överallt. Yuki, som brukar vara blyg, möter din blick och pekar mot den mörka stigen som leder ner till sjön.";
"S3.P0.Q" = "Följer du henne ut i natten?";
"S3.P0.O1" = "Jag har väntat på det här";
"S3.P0.O2" = "Visst, vi går";

"S3.P1.N" = "Du hinner ifatt henne. Skogen lever av ljudet från syrsor. Yukis hand nuddar din då och då när ni går. Hon verkar nervös.";
"S3.P1.Q" = "Hur bryter du tystnaden?";
"S3.P1.O1" = "Ta hennes hand med ett stadigt grepp";
"S3.P1.O2" = "Fråga vad hon tänker på";

"S3.P2.N" = "Ni går sida vid sida. Månskenet tränger knappt igenom det täta lövverket. Yuki tittar på dig från sidan och ler svagt. 'Jag trodde faktiskt inte att du skulle komma,' viskar hon.";
"S3.P2.Q" = "Vad svarar du?";
"S3.P2.O1" = "Jag skulle aldrig missa det";
"S3.P2.O2" = "Jag var nyfiken";

"S3.P3.N" = "Ni når bryggan. Vattnet är som en mörk spegel som reflekterar det enorma stjärnhavet. Yuki tar av sig skorna och sätter sig på kanten med fötterna dinglande över vattnet.";
"S3.P3.Q" = "Sätta dig nära henne?";
"S3.P3.O1" = "Sätt dig precis bredvid henne";
"S3.P3.O2" = "Ge henne lite utrymme";

"S3.P4.N" = "Bryggan knarrar under din tyngd. Den kalla luften från sjön får Yuki att huttra till lite. Hon flyttar sig inte när du närmar dig.";
"S3.P4.Q" = "Erbjuda din jacka?";
"S3.P4.O1" = "Svep din jacka om henne";
"S3.P4.O2" = "Bara sitt och prata";

"S3.P5.N" = "Yuki tittar upp på stjärnorna. 'Kommer du ihåg vår första dag här?' frågar hon. 'Du hjälpte mig med väskorna när alla andra var upptagna.'";
"S3.P5.Q" = "Kommer du ihåg?";
"S3.P5.O1" = "Jag minns varenda detalj";
"S3.P5.O2" = "Det känns som en evighet sedan";

"S3.P6.N" = "Hon skrattar till mjukt. 'Jag var så rädd då. Men när jag såg dig kändes det som om jag hörde hemma här.' Hon tittar ut över vattnet.";
"S3.P6.Q" = "Erkänna dina egna känslor?";
"S3.P6.O1" = "Jag kände likadant";
"S3.P6.O2" = "Jag är glad att jag kunde hjälpa till";

"S3.P7.N" = "Natten är helt stilla. Plötsligt ställer sig Yuki upp. 'Vattnet ser så inbjudande ut. Ska vi... hoppa i?' frågar hon med en busig blick.";
"S3.P7.Q" = "Är du tillräckligt modig?";
"S3.P7.O1" = "Vi dyker i!";
"S3.P7.O2" = "Det är för kallt, Yuki";

"S3.P8.N" = "Hon tittar på sjön, sedan på dig. 'Jag vill göra något modigt i natt. Något jag kommer att minnas hela vintern.'";
"S3.P8.Q" = "Uppmuntra henne?";
"S3.P8.O1" = "Hoppar du i med mig?";
"S3.P8.O2" = "Vi stannar här";

"S3.P9.N" = "PLASK! Vattnet är iskallt men uppfriskande. Du och Yuki kommer upp till ytan, flämtande och skrattande, och stänker vatten på varandra som barn.";
"S3.P9.Q" = "Simma närmare henne?";
"S3.P9.O1" = "Dra in henne i en kram";
"S3.P9.O2" = "Fortsätt stänka vatten!";

"S3.P10.N" = "Ni stannar på bryggan. Ni pratar i timmar om allt – skolan, föräldrar och framtiden. Bandet mellan er växer sig starkare i tystnaden.";
"S3.P10.Q" = "Luta dig närmare?";
"S3.P10.O1" = "Vila ditt huvud mot hennes";
"S3.P10.O2" = "Se henne i ögonen";

"S3.P11.N" = "Stämningen förändras. Yuki slutar prata. I det svaga ljuset söker hennes ögon dina. 'Jag vill inte åka tillbaka till stan i morgon,' viskar hon.";
"S3.P11.Q" = "Vad säger du?";
"S3.P11.O1" = "Vi kommer att ses där";
"S3.P11.O2" = "Låt oss inte tänka på morgondagen";

"S3.P12.N" = "Yuki tar ett djupt andetag. 'Om jag inte säger det här nu, kommer jag aldrig att göra det. Jag har tyckt om dig ända sedan den där första dagen vid busshållplatsen.'";
"S3.P12.Q" = "Hur reagerar du?";
"S3.P12.O1" = "Jag har tyckt om dig också";
"S3.P12.O2" = "Äntligen kommer sanningen fram!";

"S3.P13.N" = "Hon sträcker sig ner i fickan och tar fram ett handgjort vänskapsband. Det är blått och vitt, som sjöns färger. 'Jag gjorde det här till dig,' säger hon blygt.";
"S3.P13.Q" = "Ta emot gåvan?";
"S3.P13.O1" = "Låt henne knyta det på dig";
"S3.P13.O2" = "Ge henne en kyss i stället";

"S3.P14.N" = "Armbandet är enkelt, men du vet att det tog henne timmar att göra. Hon väntar på din reaktion, hennes underläpp darrar en aning.";
"S3.P14.Q" = "Vad gör du?";
"S3.P14.O1" = "Tacka henne med en kram";
"S3.P14.O2" = "Säg att det är perfekt";

"S3.P15.N" = "Yuki ler, ett äkta, strålande leende. 'Jag var så orolig att du skulle tycka det var barnsligt.' Hon tittar upp mot månen och ser mer självsäker ut nu.";
"S3.P15.Q" = "Ge henne ett löfte?";
"S3.P15.O1" = "Lova att ringa varje dag";
"S3.P15.O2" = "Lova att besöka henne snart";

"S3.P16.N" = "Atmosfären är elektrisk. Yuki stirrar på dina läppar. Världen runt omkring er försvinner; det är bara ni två och sommarnatten.";
"S3.P16.Q" = "Är det dags nu?";
"S3.P16.O1" = "Luta dig fram för en kyss";
"S3.P16.O2" = "Viska något sött";

"S3.P17.N" = "Just då sveper ett stjärnskott över himlen och lämnar ett silverfärgat spår efter sig. Yuki flämtar till. 'Snabbt! Önska dig något!' ropar hon.";
"S3.P17.Q" = "Vad önskar du dig?";
"S3.P17.O1" = "Önska en framtid tillsammans";
"S3.P17.O2" = "Önska att natten aldrig tar slut";

"S3.P18.N" = "Stjärnan försvinner lika snabbt som den kom. Yuki kniper ihop ögonen. 'Jag önskade mig något viktigt,' säger hon och rodnar.";
"S3.P18.Q" = "Fråga vad det var?";
"S3.P18.O1" = "Berätta vad du önskade";
"S3.P18.O2" = "Jag tror jag vet vad det var";

"S3.P19.N" = "Elden vid lägret har slocknat helt nu. Ni börjar gå tillbaka, hand i hand. Skogen känns annorlunda nu – mindre skrämmande, mer magisk.";
"S3.P19.Q" = "Gå långsamt?";
"S3.P19.O1" = "Ta den långa vägen tillbaka";
"S3.P19.O2" = "Njut av tystnaden";

"S3.P20.N" = "Ni passerar den gamla eken där ni först träffades. Yuki stannar upp ett ögonblick. 'Allt kommer att förändras nu, eller hur?' frågar hon mjukt.";
"S3.P20.Q" = "Trösta henne?";
"S3.P20.O1" = "Förändring kan vara bra";
"S3.P20.O2" = "Allt behöver inte förändras";

"S3.P21.N" = "Lägerstugorna är i sikte. De andra lägerdeltagarna sover. Yuki stannar vid sin dörr. Hon vill inte släppa din hand.";
"S3.P21.Q" = "En sista sak?";
"S3.P21.O1" = "Be om en sista kyss";
"S3.P21.O2" = "Be om hennes telefonnummer";

"S3.P22.N" = "Yuki dröjer sig kvar i dörröppningen. Lampan på verandan kastar ett mjukt sken över hennes ansikte. 'Tack för i natt. Det var den bästa natten i mitt liv.'";
"S3.P22.Q" = "Säga hejdå?";
"S3.P22.O1" = "Vi ses i morgon bitti";
"S3.P22.O2" = "God natt, Yuki";

"S3.P23.N" = "Soluppgång. Lägret sjuder av liv när folk packar sina väskor och går ombord på bussarna. Du letar efter Yuki i folkmassan, med hjärtat i halsgropen.";
"S3.P23.Q" = "Hittar du henne?";
"S3.P23.O1" = "Leta vid bussen";
"S3.P23.O2" = "Kolla bryggan en sista gång";

"S3.P24.N" = "Bussarnas motorer brummar. Där är hon! Hon står vid grinden och ser sig febrilt omkring tills hon får syn på dig.";
"S3.P24.Q" = "Springa fram till henne?";
"S3.P24.O1" = "Spring fram och krama henne";
"S3.P24.O2" = "Vinka och le";

"S3.P25.N" = "Du når henne precis i tid. Hon viskar något i ditt öra som du aldrig kommer att glömma. 'Låt inte det här bara bli ett sommarminne.'";
"S3.P25.Q" = "Ge henne ditt svar?";
"S3.P25.O1" = "Jag lovar";
"S3.P25.O2" = "Vi ses nästa helg";

"S3.P26.N" = "Bussföraren tutar. Yuki måste gå. Hon blåser dig en kyss när hon kliver på. Du står kvar och ser bussen försvinna i dammet.";
"S3.P26.Q" = "Hur känner du dig?";
"S3.P26.O1" = "Lycklig och hoppfull";
"S3.P26.O2" = "Sorgsen men nöjd";

"S3.P27.N" = "Månader senare. Du är i stan och din telefon vibrerar. Det är en bild från Yuki – hon har på sig armbandet ni delade. Sommaren tog aldrig riktigt slut.";
"S3.P27.Q" = "SLUT";
"S3.P27.O1" = "Börja om";
"S3.P27.O2" = "Avsluta";

"S3.P28.N" = "Du tittar på armbandet runt din handled. Det är lite slitet, men minnena är färska. Ibland räcker en sommar för att räcka en hel livstid.";
"S3.P28.Q" = "SLUT";
"S3.P28.O1" = "Försök igen";
"S3.P28.O2" = "Avsluta";

